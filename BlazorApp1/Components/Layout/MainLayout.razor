@inherits LayoutComponentBase

<div class="app-shell">
    <AppTopbar @rendermode="InteractiveServer" />

    <div class="app-content">
        <aside class="app-sidebar">
            <h2>Danh mục bài</h2>
            <NavMenu />
        </aside>

        <main class="app-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    Đã xảy ra lỗi ngoài dự kiến.
    <a href="" class="reload">Tải lại</a>
    <a class="dismiss">x</a>
</div>
