@page "/danh-muc/kho"
@rendermode InteractiveServer
@using BlazorApp1.Infrastructure.Excel
@using BlazorApp1.Models.Kho
@using BlazorApp1.Services.Interfaces
@inject IKhoService KhoService
@inject IJSRuntime JS
@inject ILogger<KhoPage> Logger

<PageTitle>Kho</PageTitle>

<section class="warehouse-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Kho</h1>
        <div class="page-header__actions">
            <button type="button" class="app-button" style="display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;" @onclick="ExportTemplateAsync" disabled="@(isSaving || isImporting || isApplyingImport)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                <span>Xuất file mẫu</span>
            </button>
            <label class="app-button" style="position:relative;overflow:hidden;display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;@(isSaving || isImporting || isApplyingImport ? "pointer-events:none;opacity:0.65;cursor:wait;" : "cursor:pointer;")">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21V9" />
                    <path d="m17 14-5-5-5 5" />
                    <path d="M5 3h14" />
                </svg>
                <span>Nhập file excel</span>
                <InputFile style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;"
                           @key="importFileInputVersion"
                           OnChange="ImportExcelAsync"
                           accept=".xlsx"
                           disabled="@(isSaving || isImporting || isApplyingImport)" />
            </label>
            <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@(isSaving || isImporting || isApplyingImport)">
                Thêm mới
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <ExcelImportPreviewDialog Visible="@showImportPreview"
                              FileName="@importPreviewFileName"
                              SheetName="@importPreviewSheetName"
                              ColumnHeaders="@ImportPreviewHeaders"
                              Rows="@importPreviewRows"
                              IsApplying="@isApplyingImport"
                              OnClose="CloseImportPreview"
                              OnConfirm="ApplyImportAsync" />

    <div class="warehouse-layout @(IsFormVisible ? string.Empty : "warehouse-layout--single")">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Tên kho hoặc ghi chú" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Tên kho</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(formModel.Kho_ID == item.Kho_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        @onclick="() => StartEditAsync(item.Kho_ID)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__name">@item.Ten_Kho</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Kho_ID, item.Ten_Kho)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @if (IsFormVisible)
        {
            <section class="card card--form">
                <header class="card__header card__header--form">
                    <h2>@FormTitle</h2>
                    <span class="card__tag">@FormModeLabel</span>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="KhoForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-field form-field--name">
                                <div class="form-field__head">
                                    <label class="form-field__label">Tên kho <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ten_Kho?.Length ?? 0))/150</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ten_Kho"
                                           @oninput="HandleTenKhoInput"
                                           maxlength="150"
                                           placeholder="Nhập tên kho" />
                                <p class="form-field__hint">Tên kho không được để trống và phải duy nhất.</p>
                                <ValidationMessage For="@(() => formModel.Ten_Kho)" />
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhiChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <p class="form-field__hint">Tùy chọn. Dùng để mô tả ngắn.</p>
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@isSaving">
                                    @(isSaving ? "Đang lưu..." : "Lưu")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        }
    </div>
</section>

@code {
    private readonly List<KhoListItemVm> items = [];
    private KhoUpsertVm formModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isImporting;
    private bool isApplyingImport;
    private int importFileInputVersion;
    private bool showImportPreview;
    private string importPreviewFileName = string.Empty;
    private string importPreviewSheetName = string.Empty;
    private List<ExcelImportPreviewRow> importPreviewRows = [];
    private List<ExcelImportRow> importSourceRows = [];
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string searchKeyword = string.Empty;
    private FormMode currentFormMode = FormMode.None;
    private static readonly IReadOnlyList<string> ImportPreviewHeaders = ["Tên kho", "Ghi chú"];

    private bool IsFormVisible => currentFormMode != FormMode.None;
    private bool IsEditing => currentFormMode == FormMode.Edit;
    private string FormTitle => IsEditing ? "Sửa kho" : "Tạo kho";
    private string FormModeLabel => IsEditing ? "Đang sửa" : "Đang tạo";

    private IReadOnlyList<KhoListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();
            return items
                .Where(x =>
                    ContainsKeyword(x.Ten_Kho, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            items.Clear();
            items.AddRange(await KhoService.GetAllAsync());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load Kho list failed.");
            pageMessage = "Không thể tải danh mục kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        currentFormMode = FormMode.Create;
        ResetFormModel();
        ClearPageMessage();
        ClearFormMessage();
    }

    private async Task StartEditAsync(int id)
    {
        ClearPageMessage();
        ClearFormMessage();

        var result = await KhoService.GetByIdAsync(id);
        if (!result.Success || result.Data is null)
        {
            pageMessage = result.Message;
            pageMessageIsError = true;
            return;
        }

        formModel = new KhoUpsertVm
        {
            Kho_ID = result.Data.Kho_ID,
            Ten_Kho = result.Data.Ten_Kho,
            Ghi_Chu = result.Data.Ghi_Chu
        };
        currentFormMode = FormMode.Edit;
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            var result = formModel.Kho_ID == 0
                ? await KhoService.CreateAsync(formModel)
                : await KhoService.UpdateAsync(formModel);

            formMessage = result.Message;
            formMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save Kho failed. Kho_ID={Kho_ID}", formModel.Kho_ID);
            formMessage = "Không thể lưu dữ liệu do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string tenKho)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa kho '{tenKho}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await KhoService.DeleteAsync(id);
        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (formModel.Kho_ID == id)
        {
            CancelForm();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

    private void CancelForm()
    {
        currentFormMode = FormMode.None;
        ResetFormModel();
        ClearFormMessage();
    }

    private void ResetFormModel()
    {
        formModel = new KhoUpsertVm();
    }

    private void ClearSearch()
    {
        searchKeyword = string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        searchKeyword = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleTenKhoInput(ChangeEventArgs args)
    {
        formModel.Ten_Kho = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleGhiChuInput(ChangeEventArgs args)
    {
        formModel.Ghi_Chu = args.Value?.ToString();
    }

    private async Task ExportTemplateAsync()
    {
        try
        {
            var bytes = ExcelWorkbookHelper.CreateTemplate(
                "Kho",
                ["Tên kho", "Ghi chú"],
                []);

            await DownloadExcelAsync("kho-template.xlsx", bytes);
            pageMessage = "Đã xuất file mẫu kho.";
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Export Kho template failed.");
            pageMessage = "Không thể xuất file mẫu kho.";
            pageMessageIsError = true;
        }
    }

    private async Task ImportExcelAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            pageMessage = "Chỉ hỗ trợ file Excel định dạng .xlsx.";
            pageMessageIsError = true;
            return;
        }

        isImporting = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var readResult = await ExcelWorkbookHelper.ReadRowsWithContextAsync(stream);
            var rows = readResult.Rows;
            if (rows.Count == 0)
            {
                pageMessage = "File Excel không có dữ liệu để nhập.";
                pageMessageIsError = true;
                return;
            }

            importPreviewFileName = file.Name;
            importPreviewSheetName = string.IsNullOrWhiteSpace(readResult.SheetName) ? "Sheet1" : readResult.SheetName;
            importSourceRows = rows.ToList();
            importPreviewRows = BuildImportPreviewRows(rows);
            showImportPreview = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import Kho from Excel failed.");
            pageMessage = $"Không thể nhập file Excel kho: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isImporting = false;
            importFileInputVersion++;
        }
    }

    private async Task ApplyImportAsync()
    {
        var candidates = importPreviewRows
            .Where(x => x.CanImport)
            .ToList();

        if (candidates.Count == 0)
        {
            pageMessage = "Không có dòng hợp lệ để nhập.";
            pageMessageIsError = true;
            return;
        }

        isApplyingImport = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            var successCount = 0;
            var skippedDuplicates = new List<string>();
            var errors = new List<string>();

            foreach (var preview in candidates)
            {
                if (preview.SourceIndex < 0 || preview.SourceIndex >= importSourceRows.Count)
                {
                    continue;
                }

                var row = importSourceRows[preview.SourceIndex];
                var ten = row.Get("Tên kho").Trim();
                var ghiChuRaw = row.Get("Ghi chú").Trim();
                var ghiChu = string.IsNullOrWhiteSpace(ghiChuRaw) ? null : ghiChuRaw;

                var result = await KhoService.CreateAsync(new KhoUpsertVm
                {
                    Ten_Kho = ten,
                    Ghi_Chu = ghiChu
                });

                if (result.Success)
                {
                    successCount++;
                }
                else if (IsDuplicateImportMessage(result.Message))
                {
                    skippedDuplicates.Add($"Dòng {row.RowNumber}: {result.Message}");
                }
                else
                {
                    errors.Add($"Dòng {row.RowNumber}: {result.Message}");
                }
            }

            await LoadDataAsync();
            pageMessage = BuildImportSummary(successCount, skippedDuplicates, errors);
            pageMessageIsError = errors.Count > 0;
            CloseImportPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Apply Kho import failed.");
            pageMessage = $"Không thể nhập dữ liệu từ file Excel: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isApplyingImport = false;
        }
    }

    private void CloseImportPreview()
    {
        showImportPreview = false;
        importPreviewFileName = string.Empty;
        importPreviewSheetName = string.Empty;
        importPreviewRows = [];
        importSourceRows = [];
    }

    private static List<ExcelImportPreviewRow> BuildImportPreviewRows(IReadOnlyList<ExcelImportRow> rows)
    {
        var previewRows = new List<ExcelImportPreviewRow>(rows.Count);

        for (var index = 0; index < rows.Count; index++)
        {
            var row = rows[index];
            var ten = row.Get("Tên kho").Trim();
            var ghiChu = row.Get("Ghi chú").Trim();

            var status = ExcelImportPreviewStatus.Valid;
            var message = string.Empty;

            if (string.IsNullOrWhiteSpace(ten))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Tên kho không được để trống.";
            }

            previewRows.Add(new ExcelImportPreviewRow(
                DisplayIndex: index + 1,
                SourceIndex: index,
                ExcelRowNumber: row.RowNumber,
                Cells: [ten, ghiChu],
                Status: status,
                Message: message));
        }

        return previewRows;
    }

    private void ClearPageMessage()
    {
        pageMessage = null;
        pageMessageIsError = false;
    }

    private void ClearFormMessage()
    {
        formMessage = null;
        formMessageIsError = false;
    }

    private static bool ContainsKeyword(string? source, string keyword)
    {
        return !string.IsNullOrWhiteSpace(source)
               && source.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private async Task DownloadExcelAsync(string fileName, byte[] bytes)
    {
        await JS.InvokeVoidAsync(
            "blazorFileDownload.downloadFileFromBase64",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(bytes));
    }

    private static bool IsDuplicateImportMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
               || message.Contains("bị trùng", StringComparison.OrdinalIgnoreCase)
               || message.Contains("đã được", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildImportSummary(
        int successCount,
        IReadOnlyList<string> skippedDuplicates,
        IReadOnlyList<string> errors)
    {
        if (errors.Count == 0 && skippedDuplicates.Count == 0)
        {
            return $"Nhập Excel thành công {successCount} dòng.";
        }

        if (errors.Count == 0 && skippedDuplicates.Count > 0)
        {
            var skippedText = string.Join(" | ", skippedDuplicates.Take(3));
            if (skippedDuplicates.Count > 3)
            {
                skippedText += $" | ... thêm {skippedDuplicates.Count - 3} dòng trùng.";
            }

            return $"Đã nhập {successCount} dòng. Bỏ qua {skippedDuplicates.Count} dòng trùng: {skippedText}";
        }

        var firstErrors = string.Join(" | ", errors.Take(3));
        if (errors.Count > 3)
        {
            firstErrors += $" | ... thêm {errors.Count - 3} lỗi.";
        }

        var summary = $"Đã nhập {successCount} dòng. Có {errors.Count} lỗi: {firstErrors}";
        if (skippedDuplicates.Count > 0)
        {
            summary += $" | Bỏ qua {skippedDuplicates.Count} dòng trùng.";
        }

        return summary;
    }

    private enum FormMode
    {
        None = 0,
        Create = 1,
        Edit = 2
    }
}
