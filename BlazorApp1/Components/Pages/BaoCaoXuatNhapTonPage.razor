@page "/bao-cao/xuat-nhap-ton"
@rendermode InteractiveServer
@using BlazorApp1.Models.BaoCao
@using BlazorApp1.Models.Common
@using BlazorApp1.Services.Interfaces
@inject IBaoCaoService BaoCaoService
@inject ILogger<BaoCaoXuatNhapTonPage> Logger

<PageTitle>Báo cáo xuất nhập tồn</PageTitle>

<section class="report-page">
    <header class="report-page__header">
        <h1>Báo cáo xuất nhập tồn</h1>
    </header>

    <section class="report-card report-card--filter">

        <div class="period-switch">
            @foreach (var option in PeriodOptions)
            {
                <button type="button"
                        class="period-switch__button @(filter.Kieu_Loc == option.Value ? "period-switch__button--active" : null)"
                        @onclick="() => SelectPeriodAsync(option.Value)"
                        disabled="@isLoading">
                    @option.Label
                </button>
            }
        </div>

        <div class="filter-panel">
            @if (filter.Kieu_Loc == BaoCaoKieuLoc.KhoangNgay)
            {
                <div class="filter-grid filter-grid--range">
                    <label class="filter-field">
                        <span class="filter-field__label">Từ ngày</span>
                        <div class="picker-shell picker-shell--date">
                            <InputDate class="filter-field__input filter-field__input--date"
                                       @bind-Value="filter.Tu_Ngay"
                                       @bind-Value:after="SearchAsync" />
                        </div>
                    </label>
                    <label class="filter-field">
                        <span class="filter-field__label">Đến ngày</span>
                        <div class="picker-shell picker-shell--date">
                            <InputDate class="filter-field__input filter-field__input--date"
                                       @bind-Value="filter.Den_Ngay"
                                       @bind-Value:after="SearchAsync" />
                        </div>
                    </label>
                </div>
            }
            else if (filter.Kieu_Loc == BaoCaoKieuLoc.Thang)
            {
                <div class="filter-grid filter-grid--month">
                    <label class="filter-field">
                        <span class="filter-field__label">Tháng</span>
                        <div class="picker-shell picker-shell--select">
                            <InputSelect class="filter-field__input filter-field__input--select"
                                         @bind-Value="filter.Thang"
                                         @bind-Value:after="SearchAsync">
                                @foreach (var thang in ThangOptions)
                                {
                                    <option value="@thang">Tháng @thang</option>
                                }
                            </InputSelect>
                        </div>
                    </label>
                    <label class="filter-field">
                        <span class="filter-field__label">Năm</span>
                        <div class="picker-shell picker-shell--select">
                            <InputSelect class="filter-field__input filter-field__input--select"
                                         @bind-Value="filter.Nam"
                                         @bind-Value:after="SearchAsync">
                                @foreach (var nam in NamOptions)
                                {
                                    <option value="@nam">@nam</option>
                                }
                            </InputSelect>
                        </div>
                    </label>
                </div>
            }
            else if (filter.Kieu_Loc == BaoCaoKieuLoc.Quy)
            {
                <div class="filter-grid filter-grid--quarter">
                    <label class="filter-field">
                        <span class="filter-field__label">Quý</span>
                        <div class="picker-shell picker-shell--select">
                            <InputSelect class="filter-field__input filter-field__input--select"
                                         @bind-Value="filter.Quy"
                                         @bind-Value:after="SearchAsync">
                                @foreach (var quy in QuyOptions)
                                {
                                    <option value="@quy">Quý @quy</option>
                                }
                            </InputSelect>
                        </div>
                    </label>
                    <label class="filter-field">
                        <span class="filter-field__label">Năm</span>
                        <div class="picker-shell picker-shell--select">
                            <InputSelect class="filter-field__input filter-field__input--select"
                                         @bind-Value="filter.Nam"
                                         @bind-Value:after="SearchAsync">
                                @foreach (var nam in NamOptions)
                                {
                                    <option value="@nam">@nam</option>
                                }
                            </InputSelect>
                        </div>
                    </label>
                </div>
            }
            else
            {
                <div class="filter-grid filter-grid--year">
                    <label class="filter-field">
                        <span class="filter-field__label">Năm</span>
                        <div class="picker-shell picker-shell--select">
                            <InputSelect class="filter-field__input filter-field__input--select"
                                         @bind-Value="filter.Nam"
                                         @bind-Value:after="SearchAsync">
                                @foreach (var nam in NamOptions)
                                {
                                    <option value="@nam">@nam</option>
                                }
                            </InputSelect>
                        </div>
                    </label>
                </div>
            }
        </div>

    </section>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <section class="metrics-grid metrics-grid--5">
        <article class="metric-card metric-card--range">
            <span>Khoảng áp dụng</span>
            <strong>@($"{filter.Tu_Ngay:dd/MM/yyyy} - {filter.Den_Ngay:dd/MM/yyyy}")</strong>
        </article>
        <article class="metric-card">
            <span>Tổng đầu kỳ</span>
            <strong>@TongDauKy.ToString("N0")</strong>
        </article>
        <article class="metric-card">
            <span>Tổng nhập</span>
            <strong>@TongNhap.ToString("N0")</strong>
        </article>
        <article class="metric-card">
            <span>Tổng xuất</span>
            <strong>@TongXuat.ToString("N0")</strong>
        </article>
        <article class="metric-card">
            <span>Tổng cuối kỳ</span>
            <strong>@TongTonCuoiKy.ToString("N0")</strong>
        </article>
    </section>

    <section class="report-card report-card--grid">
        <header class="grid-header">
            <h2>Lưới dữ liệu (@items.Count)</h2>
        </header>

        @if (isLoading)
        {
            <div class="state-box">Đang tải dữ liệu báo cáo...</div>
        }
        else if (items.Count == 0)
        {
            <div class="state-box state-box--empty">Không có dữ liệu trong kỳ đã chọn.</div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="data-table__index">STT</th>
                            <th>Mã sản phẩm</th>
                            <th>Tên sản phẩm</th>
                            <th class="data-table__number">SL đầu kỳ</th>
                            <th class="data-table__number">SL nhập</th>
                            <th class="data-table__number">SL xuất</th>
                            <th class="data-table__number">SL cuối kỳ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < items.Count; i++)
                        {
                            var item = items[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@item.Ma_San_Pham</td>
                                <td>@item.Ten_San_Pham</td>
                                <td class="data-table__number">@item.SL_Dau_Ky.ToString("N0")</td>
                                <td class="data-table__number">@item.SL_Nhap.ToString("N0")</td>
                                <td class="data-table__number">@item.SL_Xuat.ToString("N0")</td>
                                <td class="data-table__number">@item.SL_Cuoi_Ky.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">Tổng</td>
                            <td class="data-table__number">@TongDauKy.ToString("N0")</td>
                            <td class="data-table__number">@TongNhap.ToString("N0")</td>
                            <td class="data-table__number">@TongXuat.ToString("N0")</td>
                            <td class="data-table__number">@TongTonCuoiKy.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </section>
</section>

@code {
    private static readonly IReadOnlyList<(BaoCaoKieuLoc Value, string Label)> PeriodOptions =
    [
        (BaoCaoKieuLoc.KhoangNgay, "Từ ngày - Đến ngày"),
        (BaoCaoKieuLoc.Thang, "Theo tháng"),
        (BaoCaoKieuLoc.Quy, "Theo quý"),
        (BaoCaoKieuLoc.Nam, "Theo năm")
    ];

    private static readonly IReadOnlyList<int> ThangOptions = Enumerable.Range(1, 12).ToArray();
    private static readonly IReadOnlyList<int> QuyOptions = [1, 2, 3, 4];
    private static readonly IReadOnlyList<int> NamOptions = BuildNamOptions();

    private readonly List<BaoCaoXuatNhapTonItemVm> items = [];
    private BaoCaoDieuKienVm filter = CreateDefaultFilter();
    private bool isLoading;
    private string? pageMessage;
    private bool pageMessageIsError;

    private decimal TongDauKy => items.Sum(x => x.SL_Dau_Ky);
    private decimal TongNhap => items.Sum(x => x.SL_Nhap);
    private decimal TongXuat => items.Sum(x => x.SL_Xuat);
    private decimal TongTonCuoiKy => items.Sum(x => x.SL_Cuoi_Ky);

    protected override async Task OnInitializedAsync()
    {
        await SearchAsync();
    }

    private async Task SelectPeriodAsync(BaoCaoKieuLoc periodType)
    {
        if (filter.Kieu_Loc == periodType)
        {
            return;
        }

        filter.Kieu_Loc = periodType;
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        ClearPageMessage();
        items.Clear();

        if (!TryApplyDateRangeByPeriod())
        {
            return;
        }

        isLoading = true;

        try
        {
            var result = await BaoCaoService.GetBaoCaoXuatNhapTonAsync(filter);
            if (!result.Success || result.Data is null)
            {
                pageMessage = result.Message;
                pageMessageIsError = true;
                return;
            }

            items.AddRange(result.Data);

            if (items.Count == 0)
            {
                pageMessage = "Không có dữ liệu phù hợp trong kỳ đã chọn.";
                pageMessageIsError = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Load report xuat nhap ton failed. TuNgay={TuNgay}, DenNgay={DenNgay}",
                filter.Tu_Ngay,
                filter.Den_Ngay);
            pageMessage = "Không thể tải báo cáo xuất nhập tồn do lỗi hệ thống.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool TryApplyDateRangeByPeriod()
    {
        var nam = Math.Clamp(filter.Nam, BusinessValidationRules.MinReportYear, BusinessValidationRules.MaxReportYear);
        filter.Nam = nam;

        switch (filter.Kieu_Loc)
        {
            case BaoCaoKieuLoc.KhoangNgay:
                filter.Tu_Ngay = filter.Tu_Ngay.Date;
                filter.Den_Ngay = filter.Den_Ngay.Date;

                if (filter.Tu_Ngay > filter.Den_Ngay)
                {
                    pageMessage = "Khoảng ngày không hợp lệ: Từ ngày phải nhỏ hơn hoặc bằng đến ngày.";
                    pageMessageIsError = true;
                    return false;
                }

                if (filter.Den_Ngay > DateTime.Today)
                {
                    pageMessage = $"Khoảng ngày không được lớn hơn ngày hiện tại ({DateTime.Today:dd/MM/yyyy}).";
                    pageMessageIsError = true;
                    return false;
                }

                return true;

            case BaoCaoKieuLoc.Thang:
                filter.Thang = Math.Clamp(filter.Thang, 1, 12);
                filter.Tu_Ngay = new DateTime(nam, filter.Thang, 1);
                filter.Den_Ngay = filter.Tu_Ngay.AddMonths(1).AddDays(-1);
                return true;

            case BaoCaoKieuLoc.Quy:
                filter.Quy = Math.Clamp(filter.Quy, 1, 4);
                var startMonth = ((filter.Quy - 1) * 3) + 1;
                filter.Tu_Ngay = new DateTime(nam, startMonth, 1);
                filter.Den_Ngay = filter.Tu_Ngay.AddMonths(3).AddDays(-1);
                return true;

            case BaoCaoKieuLoc.Nam:
                filter.Tu_Ngay = new DateTime(nam, 1, 1);
                filter.Den_Ngay = new DateTime(nam, 12, 31);
                return true;

            default:
                pageMessage = "Kiểu lọc thời gian không hợp lệ.";
                pageMessageIsError = true;
                return false;
        }
    }

    private void ClearPageMessage()
    {
        pageMessage = null;
        pageMessageIsError = false;
    }

    private static BaoCaoDieuKienVm CreateDefaultFilter()
    {
        return new BaoCaoDieuKienVm
        {
            Kieu_Loc = BaoCaoKieuLoc.KhoangNgay,
            Tu_Ngay = DateTime.Today.AddDays(-30),
            Den_Ngay = DateTime.Today,
            Thang = DateTime.Today.Month,
            Quy = ((DateTime.Today.Month - 1) / 3) + 1,
            Nam = DateTime.Today.Year
        };
    }

    private static IReadOnlyList<int> BuildNamOptions()
    {
        var endYear = BusinessValidationRules.MaxReportYear;
        var startYear = Math.Max(BusinessValidationRules.MinReportYear, DateTime.Today.Year - 9);
        return Enumerable.Range(startYear, endYear - startYear + 1)
            .Reverse()
            .ToArray();
    }
}
