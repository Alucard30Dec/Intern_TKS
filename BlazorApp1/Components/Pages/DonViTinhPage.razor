@page "/"
@page "/danh-muc/don-vi-tinh"
@rendermode InteractiveServer
@using BlazorApp1.Models.DonViTinh
@using BlazorApp1.Services.Interfaces
@inject IDonViTinhService DonViTinhService
@inject IJSRuntime JS
@inject ILogger<DonViTinhPage> Logger

<PageTitle>Đơn vị tính</PageTitle>

<section class="unit-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Đơn vị tính</h1>
        <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@isSaving">
            Thêm mới
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <div class="unit-layout @(IsFormVisible ? string.Empty : "unit-layout--single")">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Tên hoặc ghi chú" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Tên</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(formModel.Don_Vi_Tinh_ID == item.Don_Vi_Tinh_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        @onclick="() => StartEditAsync(item.Don_Vi_Tinh_ID)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__name">@item.Ten_Don_Vi_Tinh</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Don_Vi_Tinh_ID, item.Ten_Don_Vi_Tinh)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @if (IsFormVisible)
        {
            <section class="card card--form">
                <header class="card__header card__header--form">
                    <h2>@FormTitle</h2>
                    <span class="card__tag">@FormModeLabel</span>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="DonViTinhForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-field form-field--name">
                                <div class="form-field__head">
                                    <label class="form-field__label">Tên <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ten_Don_Vi_Tinh?.Length ?? 0))/100</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ten_Don_Vi_Tinh"
                                           @oninput="HandleTen_Don_Vi_TinhInput"
                                           maxlength="100"
                                           placeholder="Nhập tên" />
                                <p class="form-field__hint">Tên ngắn gọn, không trùng.</p>
                                <ValidationMessage For="@(() => formModel.Ten_Don_Vi_Tinh)" />
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhi_ChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <p class="form-field__hint">Tùy chọn. Dùng để mô tả ngắn.</p>
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@isSaving">
                                    @(isSaving ? "Đang lưu..." : "Lưu")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        }
    </div>
</section>

@code {
    private readonly List<DonViTinhListItemVm> items = [];
    private DonViTinhUpsertVm formModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string searchKeyword = string.Empty;
    private FormMode currentFormMode = FormMode.None;

    private bool IsFormVisible => currentFormMode != FormMode.None;
    private bool IsEditing => currentFormMode == FormMode.Edit;
    private string FormTitle => IsEditing ? "Sửa đơn vị tính" : "Tạo đơn vị tính";
    private string FormModeLabel => IsEditing ? "Đang sửa" : "Đang tạo";

    private IReadOnlyList<DonViTinhListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();

            // Loc tren bo nho de cap nhat UI tuc thi theo oninput, khong tao round-trip DB cho moi ky tu.
            return items
                .Where(x =>
                    ContainsKeyword(x.Ten_Don_Vi_Tinh, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            items.Clear();
            items.AddRange(await DonViTinhService.GetAllAsync());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load DonViTinh list failed.");
            pageMessage = "Không thể tải dữ liệu.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        currentFormMode = FormMode.Create;
        ResetFormModel();
        ClearPageMessage();
        ClearFormMessage();
    }

    private async Task StartEditAsync(int id)
    {
        ClearPageMessage();
        ClearFormMessage();

        // Luon tai lai tu DB de tranh sua tren du lieu cu khi danh sach da bi thay doi boi nguoi dung khac.
        var result = await DonViTinhService.GetByIdAsync(id);

        if (!result.Success || result.Data is null)
        {
            pageMessage = result.Message;
            pageMessageIsError = true;
            return;
        }

        formModel = new DonViTinhUpsertVm
        {
            Don_Vi_Tinh_ID = result.Data.Don_Vi_Tinh_ID,
            Ten_Don_Vi_Tinh = result.Data.Ten_Don_Vi_Tinh,
            Ghi_Chu = result.Data.Ghi_Chu
        };
        currentFormMode = FormMode.Edit;
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            var result = formModel.Don_Vi_Tinh_ID == 0
                ? await DonViTinhService.CreateAsync(formModel)
                : await DonViTinhService.UpdateAsync(formModel);

            formMessage = result.Message;
            formMessageIsError = !result.Success;

            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save DonViTinh failed. Don_Vi_Tinh_ID={Don_Vi_Tinh_ID}", formModel.Don_Vi_Tinh_ID);
            formMessage = "Không thể lưu dữ liệu.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string tenDonViTinh)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa đơn vị tính '{tenDonViTinh}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await DonViTinhService.DeleteAsync(id);

        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (formModel.Don_Vi_Tinh_ID == id)
        {
            CancelForm();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

    private void CancelForm()
    {
        currentFormMode = FormMode.None;
        ResetFormModel();
        ClearFormMessage();
    }

    private void ResetFormModel()
    {
        formModel = new DonViTinhUpsertVm();
    }

    private void ClearSearch()
    {
        searchKeyword = string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        searchKeyword = args.Value?.ToString() ?? string.Empty;
    }

    private void ClearPageMessage()
    {
        pageMessage = null;
        pageMessageIsError = false;
    }

    private void ClearFormMessage()
    {
        formMessage = null;
        formMessageIsError = false;
    }

    private void HandleTen_Don_Vi_TinhInput(ChangeEventArgs args)
    {
        // Dung oninput de bo dem ky tu cap nhat ngay khi go/phim xoa.
        formModel.Ten_Don_Vi_Tinh = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleGhi_ChuInput(ChangeEventArgs args)
    {
        // Dung oninput de bo dem ky tu cap nhat ngay khi go/phim xoa.
        formModel.Ghi_Chu = args.Value?.ToString();
    }

    private static bool ContainsKeyword(string? source, string keyword)
    {
        return !string.IsNullOrWhiteSpace(source)
               && source.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private enum FormMode
    {
        None = 0,
        Create = 1,
        Edit = 2
    }
}



