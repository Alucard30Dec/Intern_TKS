    private static bool MatchesKeywords(DonViTinhListItemVm item, IReadOnlyList<string> keywords)
    {
        if (keywords.Count == 0)
        {
            return true;
        }

        var searchIndex = NormalizeForSearch($"{item.Ten_Don_Vi_Tinh} {item.Ghi_Chu}");
        if (string.IsNullOrWhiteSpace(searchIndex))
        {
            return false;
        }

        return keywords.All(searchIndex.Contains);
    }

    private static string NormalizeForSearch(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Normalize(NormalizationForm.FormD);
        var result = new StringBuilder(normalized.Length);
        var previousWhiteSpace = false;

        foreach (var ch in normalized)
        {
            var unicodeCategory = CharUnicodeInfo.GetUnicodeCategory(ch);
            if (unicodeCategory == UnicodeCategory.NonSpacingMark)
            {
                continue;
            }

            var loweredChar = char.ToLowerInvariant(ch);
            if (loweredChar == 'đ')
            {
                loweredChar = 'd';
            }

            if (char.IsWhiteSpace(loweredChar))
            {
                if (previousWhiteSpace)
                {
                    continue;
                }

                result.Append(' ');
                previousWhiteSpace = true;
                continue;
            }

            result.Append(loweredChar);
            previousWhiteSpace = false;
        }

        return result.ToString().Trim();
    }

    private async Task DownloadExcelAsync(string fileName, byte[] bytes)
    {
        await JS.InvokeVoidAsync(
            "blazorFileDownload.downloadFileFromBase64",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(bytes));
    }

    private static bool IsDuplicateImportMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
               || message.Contains("bị trùng", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildImportSummary(
        int successCount,
        IReadOnlyList<string> skippedDuplicates,
        IReadOnlyList<string> errors)
    {
        if (errors.Count == 0 && skippedDuplicates.Count == 0)
        {
            return $"Nhập Excel thành công {successCount} dòng.";
        }

        if (errors.Count == 0 && skippedDuplicates.Count > 0)
        {
            var skippedText = string.Join(" | ", skippedDuplicates.Take(3));
            if (skippedDuplicates.Count > 3)
            {
                skippedText += $" | ... thêm {skippedDuplicates.Count - 3} dòng trùng.";
            }

            return $"Đã nhập {successCount} dòng. Bỏ qua {skippedDuplicates.Count} dòng trùng: {skippedText}";
        }

        var firstErrors = string.Join(" | ", errors.Take(3));
        if (errors.Count > 3)
        {
            firstErrors += $" | ... thêm {errors.Count - 3} lỗi.";
        }

        var summary = $"Đã nhập {successCount} dòng. Có {errors.Count} lỗi: {firstErrors}";
        if (skippedDuplicates.Count > 0)
        {
            summary += $" | Bỏ qua {skippedDuplicates.Count} dòng trùng.";
        }

        return summary;
    }

