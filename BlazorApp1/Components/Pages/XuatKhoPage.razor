    private void ToggleNgayXuatKhoCalendar()
    {
        if (isSaving)
        {
            return;
        }

        if (isNgayXuatKhoCalendarOpen)
        {
            isNgayXuatKhoCalendarOpen = false;
            return;
        }

        InitNgayXuatKhoCalendarState();
        isNgayXuatKhoCalendarOpen = true;
    }

    private void InitNgayXuatKhoCalendarState()
    {
        if (TryParseNgayXuatKho(out var parsedDate))
        {
            ngayXuatKhoCalendarSelection = parsedDate.Date;
            ngayXuatKhoCalendarMonth = new DateTime(parsedDate.Year, parsedDate.Month, 1);
            return;
        }

        var fallback = formModel.Ngay_Xuat_Kho == default ? DateTime.Today : formModel.Ngay_Xuat_Kho.Date;
        ngayXuatKhoCalendarSelection = fallback;
        ngayXuatKhoCalendarMonth = new DateTime(fallback.Year, fallback.Month, 1);
    }

    private string GetNgayXuatKhoCalendarMonthTitle()
    {
        return $"Tháng {ngayXuatKhoCalendarMonth.Month}, {ngayXuatKhoCalendarMonth.Year}";
    }

    private IReadOnlyList<DateTime> GetNgayXuatKhoCalendarDays()
    {
        var firstDayOfMonth = new DateTime(ngayXuatKhoCalendarMonth.Year, ngayXuatKhoCalendarMonth.Month, 1);
        var offset = ((int)firstDayOfMonth.DayOfWeek + 6) % 7;
        var gridStart = firstDayOfMonth.AddDays(-offset);

        return Enumerable.Range(0, 42)
            .Select(index => gridStart.AddDays(index))
            .ToList();
    }

    private bool IsNgayXuatKhoCalendarCurrentMonth(DateTime day)
    {
        return day.Month == ngayXuatKhoCalendarMonth.Month
            && day.Year == ngayXuatKhoCalendarMonth.Year;
    }

    private bool IsNgayXuatKhoCalendarSelected(DateTime day)
    {
        return ngayXuatKhoCalendarSelection.HasValue
            && ngayXuatKhoCalendarSelection.Value.Date == day.Date;
    }

    private void MoveNgayXuatKhoCalendarMonth(int months)
    {
        ngayXuatKhoCalendarMonth = ngayXuatKhoCalendarMonth.AddMonths(months);
    }

    private void MoveNgayXuatKhoCalendarYear(int years)
    {
        ngayXuatKhoCalendarMonth = ngayXuatKhoCalendarMonth.AddYears(years);
    }

    private void SelectNgayXuatKhoCalendarDate(DateTime day)
    {
        ngayXuatKhoCalendarSelection = day.Date;
        if (!IsNgayXuatKhoCalendarCurrentMonth(day))
        {
            ngayXuatKhoCalendarMonth = new DateTime(day.Year, day.Month, 1);
        }
    }

    private void ClearNgayXuatKhoCalendar()
