    private string GetLineSanPhamKeyword(XuatKhoRawDataUpsertVm line)
    {
        if (lineSanPhamKeywords.TryGetValue(line, out var keyword))
        {
            return keyword;
        }

        var selected = sanPhamOptions.FirstOrDefault(x => x.San_Pham_ID == line.San_Pham_ID);
        keyword = selected?.Ten_San_Pham ?? string.Empty;
        lineSanPhamKeywords[line] = keyword;
        return keyword;
    }

    private IReadOnlyList<SanPhamListItemVm> GetFilteredSanPhamOptions(XuatKhoRawDataUpsertVm line)
    {
        var keyword = GetLineSanPhamKeyword(line).Trim();
        IEnumerable<SanPhamListItemVm> query = sanPhamOptions;

        if (!string.IsNullOrWhiteSpace(keyword))
        {
            query = query.Where(x =>
                ContainsKeyword(x.Ma_San_Pham, keyword)
                || ContainsKeyword(x.Ten_San_Pham, keyword));
        }

        return query
            .Take(MaxSanPhamComboboxOptions)
            .ToList();
    }

    private bool IsSanPhamDropdownOpen(XuatKhoRawDataUpsertVm line)
    {
        return openedLineSanPhamDropdowns.Contains(line);
    }

    private void OpenSanPhamDropdown(XuatKhoRawDataUpsertVm line)
    {
        if (isEditMode || isSaving)
        {
            return;
        }

        openedLineSanPhamDropdowns.Add(line);
    }

    private void HandleLineSanPhamKeywordInput(XuatKhoRawDataUpsertVm line, ChangeEventArgs args)
    {
        if (isEditMode || isSaving)
        {
            return;
        }

        var keyword = args.Value?.ToString() ?? string.Empty;
        lineSanPhamKeywords[line] = keyword;
        openedLineSanPhamDropdowns.Add(line);

        if (line.San_Pham_ID <= 0)
        {
            return;
        }

        var selected = sanPhamOptions.FirstOrDefault(x => x.San_Pham_ID == line.San_Pham_ID);
        if (selected is null)
        {
            line.San_Pham_ID = 0;
            return;
        }

        if (!string.Equals(keyword, selected.Ten_San_Pham, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(keyword, selected.Ma_San_Pham, StringComparison.OrdinalIgnoreCase))
        {
            line.San_Pham_ID = 0;
        }
    }

    private void HandleLineSanPhamKeyDown(XuatKhoRawDataUpsertVm line, KeyboardEventArgs args)
    {
        if (isEditMode || isSaving)
        {
            return;
        }

        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            openedLineSanPhamDropdowns.Remove(line);
            return;
        }

        if (string.Equals(args.Key, "ArrowDown", StringComparison.Ordinal))
        {
            openedLineSanPhamDropdowns.Add(line);
            return;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            var selected = GetFilteredSanPhamOptions(line).FirstOrDefault();
            if (selected is null)
            {
                openedLineSanPhamDropdowns.Remove(line);
                return;
            }

            SelectSanPhamForLine(line, selected);
        }
    }

    private async Task HandleLineSanPhamBlurAsync(XuatKhoRawDataUpsertVm line)
    {
        await Task.Delay(120);
        openedLineSanPhamDropdowns.Remove(line);

        if (line.San_Pham_ID > 0)
        {
            return;
        }

        var keyword = GetLineSanPhamKeyword(line).Trim();
        if (keyword.Length == 0)
        {
            return;
        }

        var exact = sanPhamOptions.FirstOrDefault(x =>
            string.Equals(x.Ma_San_Pham, keyword, StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.Ten_San_Pham, keyword, StringComparison.OrdinalIgnoreCase));

        if (exact is not null)
        {
            SelectSanPhamForLine(line, exact);
        }
    }

    private void SelectSanPhamForLine(XuatKhoRawDataUpsertVm line, SanPhamListItemVm option)
    {
        line.San_Pham_ID = option.San_Pham_ID;
        lineSanPhamKeywords[line] = option.Ten_San_Pham;
        openedLineSanPhamDropdowns.Remove(line);
    }

    private void ResetLineSanPhamComboboxState()
    {
        lineSanPhamKeywords.Clear();
        openedLineSanPhamDropdowns.Clear();
    }

    private void InitializeLineSanPhamComboboxState(IEnumerable<XuatKhoRawDataUpsertVm> lines)
    {
        ResetLineSanPhamComboboxState();

        foreach (var line in lines)
        {
            var selected = sanPhamOptions.FirstOrDefault(x => x.San_Pham_ID == line.San_Pham_ID);
            lineSanPhamKeywords[line] = selected?.Ten_San_Pham ?? string.Empty;
        }
    }

