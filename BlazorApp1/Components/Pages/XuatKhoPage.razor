@page "/xuat-kho"
@rendermode InteractiveServer
@implements IDisposable
@using System.Globalization
@using BlazorApp1.Infrastructure.Excel
@using BlazorApp1.Models.Kho
@using BlazorApp1.Models.Common
@using BlazorApp1.Models.XuatKho
@using BlazorApp1.Models.SanPham
@using BlazorApp1.Services.Interfaces
@inject IXuatKhoService XuatKhoService
@inject ISanPhamService SanPhamService
@inject ICurrencyExchangeRateService CurrencyExchangeRateService
@inject IAppSelectionContextService AppSelectionContext
@inject IJSRuntime JS
@inject ILogger<XuatKhoPage> Logger

<PageTitle>Quản lý phiếu xuất kho</PageTitle>

<section class="import-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Quản lý phiếu xuất kho</h1>
        <div class="page-header__actions">
            <button type="button" class="app-button" style="display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;" @onclick="ExportTemplateAsync" disabled="@(isSaving || isImporting || isApplyingImport)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                <span>Xuất file mẫu</span>
            </button>
            <label class="app-button" style="position:relative;overflow:hidden;display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;@(isSaving || isImporting || isApplyingImport ? "pointer-events:none;opacity:0.65;cursor:wait;" : "cursor:pointer;")">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21V9" />
                    <path d="m17 14-5-5-5 5" />
                    <path d="M5 3h14" />
                </svg>
                <span>Nhập file excel</span>
                <InputFile style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;"
                           @key="importFileInputVersion"
                           OnChange="ImportExcelAsync"
                           accept=".xlsx"
                           disabled="@(isSaving || isImporting || isApplyingImport)" />
            </label>
            <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@(isSaving || isImporting || isApplyingImport)">
                Thêm phiếu xuất
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <ExcelImportPreviewDialog Visible="@showImportPreview"
                              FileName="@importPreviewFileName"
                              SheetName="@importPreviewSheetName"
                              ColumnHeaders="@ImportPreviewHeaders"
                              Rows="@importPreviewRows"
                              IsApplying="@isApplyingImport"
                              OnClose="CloseImportPreview"
                              OnConfirm="ApplyImportAsync" />

    <div class="import-layout import-layout--single">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách phiếu xuất (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Số phiếu, kho" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Số phiếu</th>
                                    <th>Ngày xuất</th>
                                    <th>Kho</th>
                                    <th class="data-table__number">Số dòng</th>
                                    <th class="data-table__number">Tổng trị giá</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(selectedXuatKhoId == item.Xuat_Kho_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        title="Bấm để mở phiếu xuất và chỉnh sửa"
                                        @onclick="() => StartEditAsync(item)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.So_Phieu_Xuat_Kho</td>
                                        <td>@item.Ngay_Xuat_Kho.ToString("dd/MM/yyyy")</td>
                                        <td class="data-table__name">@item.Ten_Kho</td>
                                        <td class="data-table__number">@item.So_Dong_Chi_Tiet</td>
                                        <td class="data-table__number">@FormatAmountWithCurrency(item.Tong_Tri_Gia, item.Don_Vi_Tien)</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => OpenPrintFormAsync(item.Xuat_Kho_ID)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    In
                                                </button>
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => StartDetailEditorAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Chi tiết
                                                </button>
                                                <button class="app-button app-button--secondary"
                                                        @onclick="() => StartEditAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Sửa
                                                </button>
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Xuat_Kho_ID, item.So_Phieu_Xuat_Kho)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (selectedXuatKhoId.HasValue)
                {
                    <section class="detail-panel">
                        <header class="detail-panel__header">
                            <h3>Chi tiết phiếu xuất: @selectedSoPhieu</h3>
                            <span class="card__tag">Đơn vị tiền: @SelectedDonViTien</span>
                        </header>

                        @if (isDetailLoading)
                        {
                            <div class="state-box">Đang tải chi tiết...</div>
                        }
                        else if (selectedDetails.Count == 0)
                        {
                            <div class="state-box state-box--empty">Phiếu xuất chưa có dòng chi tiết.</div>
                        }
                        else
                        {
                            <div class="table-wrap">
                                <table class="detail-table">
                                    <thead>
                                        <tr>
                                            <th>STT</th>
                                            <th>Mã SP</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="detail-table__number">SL xuất</th>
                                            <th class="detail-table__number">Đơn giá</th>
                                            <th class="detail-table__number">Trị giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < selectedDetails.Count; i++)
                                        {
                                            var detail = selectedDetails[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@detail.Ma_San_Pham</td>
                                                <td>@detail.Ten_San_Pham</td>
                                                <td class="detail-table__number">@FormatQuantity(detail.SL_Xuat)</td>
                                                <td class="detail-table__number">@FormatAmount(detail.Don_Gia_Xuat, SelectedDonViTien)</td>
                                                <td class="detail-table__number">@FormatAmountWithCurrency(detail.Tri_Gia, SelectedDonViTien)</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="detail-table__number">@FormatAmountWithCurrency(selectedDetails.Sum(x => x.Tri_Gia), SelectedDonViTien)</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    </section>
                }
            </div>
        </section>
    </div>

    @if (IsFormVisible)
    {
        <div class="modal-overlay receipt-modal-overlay" @onclick="HandleModalBackdropClick">
            <section class="card card--form modal-card modal-card--nhap-form receipt-modal" @onclick:stopPropagation="true">
                <header class="card__header card__header--form nk-modal-header receipt-header">
                    <h2 class="receipt-title">@(isEditMode ? "Sửa phiếu xuất kho" : "Tạo phiếu xuất kho")</h2>
                    <div class="modal-header-actions nk-modal-header-actions receipt-header-right">
                        <span class="card__tag nk-mode-tag receipt-badge">@(isEditMode ? "Chế độ chỉnh sửa" : "Chỉ thêm mới")</span>
                        <button type="button"
                                class="nk-close-button receipt-close"
                                title="Đóng"
                                @onclick="CancelForm"
                                disabled="@isSaving">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m6 6 12 12M18 6 6 18" />
                            </svg>
                        </button>
                    </div>
                </header>

                <div class="card__body nk-modal-body receipt-body receipt-modal-body">
                    <div class="form-shell nk-form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="XuatKhoForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="receipt-workspace">
                                <section class="receipt-info-panel receipt-left">
                                    <h3 class="receipt-panel-title receipt-section-title">Thông tin phiếu xuất kho</h3>

                                    <div class="form-grid nk-form-grid receipt-grid">
                                        <div class="form-field form-field--code nk-field-card nk-field-card--so-phieu field-card">
                                            <div class="nk-field-icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" />
                                                    <path d="M14 3v5h5" />
                                                    <path d="M9 13h6M9 17h6M9 9h3" />
                                                </svg>
                                            </div>
                                            <div class="nk-field-content">
                                                <div class="form-field__head field-label-row">
                                                    <label class="form-field__label field-label">Số phiếu xuất <span class="required-mark field-required">*</span></label>
                                                    <span class="form-field__count field-counter">@((formModel.So_Phieu_Xuat_Kho?.Length ?? 0))/50</span>
                                                </div>
                                                <InputText class="form-field__input input-ui"
                                                           @bind-Value="formModel.So_Phieu_Xuat_Kho"
                                                           @oninput="HandleSoPhieuInput"
                                                           maxlength="50"
                                                           placeholder="Nhập số phiếu xuất kho" />
                                                <p class="form-field__hint field-help">Không được để trống và phải duy nhất.</p>
                                                <ValidationMessage For="@(() => formModel.So_Phieu_Xuat_Kho)" />
                                            </div>
                                        </div>

                                        <div class="form-field form-field--lookup nk-field-card nk-field-card--kho field-card">
                                            <div class="nk-field-icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M3 10.25 12 5l9 5.25v9.25A1.5 1.5 0 0 1 19.5 21h-15A1.5 1.5 0 0 1 3 19.5z" />
                                                    <path d="M5 11.41V19h14v-7.59L12 7.33z" />
                                                    <path d="M9 13h6v6H9z" />
                                                </svg>
                                            </div>
                                            <div class="nk-field-content">
                                                <div class="form-field__head field-label-row">
                                                    <label class="form-field__label field-label">Kho <span class="required-mark field-required">*</span></label>
                                                </div>
                                                <input class="form-field__input form-field__input--readonly select-ui"
                                                       value="@GetSelectedKhoDisplayName()"
                                                       placeholder="Chọn kho trên header"
                                                       readonly
                                                       aria-readonly="true" />
                                                <p class="form-field__hint field-help">Kho lấy theo bộ lọc trên header, không chỉnh sửa tại đây.</p>
                                                <ValidationMessage For="@(() => formModel.Kho_ID)" />
                                            </div>
                                        </div>

                                        <div class="form-field form-field--date nk-field-card nk-field-card--ngay field-card full">
                                            <div class="nk-field-icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M7 2v4M17 2v4M3 9h18" />
                                                    <rect x="3" y="4" width="18" height="18" rx="2" />
                                                </svg>
                                            </div>
                                            <div class="nk-field-content">
                                                <div class="form-field__head field-label-row">
                                                    <label class="form-field__label field-label">Ngày xuất kho <span class="required-mark field-required">*</span></label>
                                                </div>
                                                <div class="nk-date-input-wrap">
                                                    <InputText class="form-field__input nk-date-input input-ui"
                                                               @bind-Value="ngayXuatKhoText"
                                                               @oninput="HandleNgayXuatKhoInput"
                                                               maxlength="10"
                                                               placeholder="dd/MM/yyyy" />
                                                    <button type="button"
                                                            class="nk-date-input-icon nk-date-input-button"
                                                            title="Chọn ngày xuất kho"
                                                            aria-label="Chọn ngày xuất kho"
                                                            @onclick="ToggleNgayXuatKhoCalendar"
                                                            disabled="@isSaving">
                                                        <svg viewBox="0 0 24 24">
                                                            <path d="M7 2v4M17 2v4M3 9h18" />
                                                            <rect x="3" y="4" width="18" height="18" rx="2" />
                                                        </svg>
                                                    </button>

                                                    @if (isNgayXuatKhoCalendarOpen)
                                                    {
                                                        <div class="nk-calendar-popover" role="dialog" aria-label="Bảng chọn ngày xuất kho">
                                                            <div class="nk-calendar-header">
                                                                <div class="nk-calendar-nav">
                                                                    <button type="button" class="nk-calendar-nav-btn" @onclick="() => MoveNgayXuatKhoCalendarYear(-1)">«</button>
                                                                    <button type="button" class="nk-calendar-nav-btn" @onclick="() => MoveNgayXuatKhoCalendarMonth(-1)">‹</button>
                                                                </div>
                                                                <div class="nk-calendar-title">@GetNgayXuatKhoCalendarMonthTitle()</div>
                                                                <div class="nk-calendar-nav">
                                                                    <button type="button" class="nk-calendar-nav-btn" @onclick="() => MoveNgayXuatKhoCalendarMonth(1)">›</button>
                                                                    <button type="button" class="nk-calendar-nav-btn" @onclick="() => MoveNgayXuatKhoCalendarYear(1)">»</button>
                                                                </div>
                                                            </div>

                                                            <div class="nk-calendar-grid">
                                                                @foreach (var dayName in CalendarDayHeaders)
                                                                {
                                                                    <div class="nk-calendar-weekday">@dayName</div>
                                                                }

                                                                @foreach (var day in GetNgayXuatKhoCalendarDays())
                                                                {
                                                                    var dayClasses = "nk-calendar-day";
                                                                    if (!IsNgayXuatKhoCalendarCurrentMonth(day))
                                                                    {
                                                                        dayClasses += " nk-calendar-day--outside";
                                                                    }
                                                                    if (IsNgayXuatKhoCalendarSelected(day))
                                                                    {
                                                                        dayClasses += " nk-calendar-day--selected";
                                                                    }
                                                                    else if (day.Date == DateTime.Today)
                                                                    {
                                                                        dayClasses += " nk-calendar-day--today";
                                                                    }

                                                                    <button type="button"
                                                                            class="@dayClasses"
                                                                            @onclick="() => SelectNgayXuatKhoCalendarDate(day)">
                                                                        @day.Day
                                                                    </button>
                                                                }
                                                            </div>

                                                            <div class="nk-calendar-footer">
                                                                <button type="button" class="nk-calendar-action nk-calendar-action--clear" @onclick="ClearNgayXuatKhoCalendar">Xóa</button>
                                                                <button type="button" class="nk-calendar-action nk-calendar-action--today" @onclick="SelectNgayXuatKhoCalendarToday">Hôm nay</button>
                                                                <button type="button" class="nk-calendar-action nk-calendar-action--confirm" @onclick="ConfirmNgayXuatKhoCalendar">Đồng ý</button>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                                <p class="form-field__hint field-help">Định dạng bắt buộc: dd/MM/yyyy.</p>
                                                <ValidationMessage For="@(() => formModel.Ngay_Xuat_Kho)" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-field form-field--note nk-field-card nk-field-card--note field-card full">
                                        <div class="nk-field-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M7 3h9l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" />
                                                <path d="M16 3v5h5" />
                                                <path d="M9 13h6M9 17h4M9 9h3" />
                                            </svg>
                                        </div>
                                        <div class="nk-field-content">
                                            <div class="form-field__head field-label-row">
                                                <label class="form-field__label field-label">Ghi chú</label>
                                                <span class="form-field__count field-counter">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                            </div>
                                            <InputTextArea class="form-field__input form-field__input--multiline textarea-ui"
                                                           @bind-Value="formModel.Ghi_Chu"
                                                           @oninput="HandleGhiChuInput"
                                                           maxlength="255"
                                                           placeholder="Nhập ghi chú (nếu có)" />
                                            <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                                        </div>
                                    </div>

                                    <div class="form-actions nk-form-actions receipt-footer receipt-footer--left receipt-footer-inline">
                                        <button type="button" class="app-button nk-cancel-button btn-cancel" @onclick="CancelForm" disabled="@isSaving">
                                            Hủy
                                        </button>
                                        <button type="submit" class="app-button nk-save-button btn-save" disabled="@(!HasRequiredLookupData || isSaving)">
                                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                                <path d="M5 4h11l3 3v13H5z" />
                                                <path d="M8 4v6h8V4M9 18h6" />
                                            </svg>
                                            @(isSaving ? "Đang lưu..." : isEditMode ? "Lưu cập nhật" : "Lưu phiếu xuất")
                                        </button>
                                    </div>
                                </section>

                                <section class="line-section nk-line-section detail-card receipt-detail-panel receipt-right">
                                    <header class="line-section__header detail-head receipt-right-header">
                                        <h3 class="detail-title receipt-section-title">Chi tiết xuất kho</h3>
                                        <div class="line-section__tools nk-line-tools detail-tools receipt-right-tools">
                                            <label class="currency-picker nk-currency-picker money-wrap">
                                                <span class="currency-picker__label money-label">Đơn vị tiền</span>
                                                <select class="currency-picker__input money-select"
                                                        value="@formModel.Don_Vi_Tien"
                                                        @onchange="HandleFormDonViTienChanged"
                                                        disabled="@(isSaving || isEditMode)">
                                                    @foreach (var currency in SupportedCurrencies)
                                                    {
                                                        <option value="@currency">@currency</option>
                                                    }
                                                </select>
                                            </label>
                                            <button type="button" class="app-button app-button--secondary nk-add-line-button btn-add-row" @onclick="AddDetailRow" disabled="@(isSaving || isEditMode)">
                                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                                    <path d="M12 5v14M5 12h14" />
                                                </svg>
                                                <span>Thêm dòng</span>
                                            </button>
                                        </div>
                                    </header>

                                    <div class="table-wrap detail-table-wrap">
                                        <table class="line-table nk-line-table detail-table">
                                            <thead>
                                                <tr>
                                                    <th class="line-table__index col-stt">STT</th>
                                                    <th class="col-product">Sản phẩm <span class="required-mark">*</span></th>
                                                    <th class="col-unit">Đơn vị tính</th>
                                                    <th class="line-table__number col-qty">SL xuất <span class="required-mark">*</span></th>
                                                    <th class="line-table__number col-price">Đơn giá xuất <span class="required-mark">*</span></th>
                                                    <th class="line-table__number col-total">Trị giá</th>
                                                    <th class="line-table__actions col-action">Thao tác</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (var i = 0; i < formModel.Chi_Tiets.Count; i++)
                                                {
                                                    var index = i;
                                                    var line = formModel.Chi_Tiets[index];
                                                    <tr>
                                                        <td>@(index + 1)</td>
                                                        <td>
                                                            <div class="combo-box">
                                                                <input class="form-field__input combo-ui"
                                                                       value="@(isEditMode ? GetSanPhamNameById(line.San_Pham_ID) : GetLineSanPhamKeyword(line))"
                                                                       @onfocus="() => OpenSanPhamDropdown(line)"
                                                                       @oninput="e => HandleLineSanPhamKeywordInput(line, e)"
                                                                       @onkeydown="e => HandleLineSanPhamKeyDown(line, e)"
                                                                       @onblur="() => HandleLineSanPhamBlurAsync(line)"
                                                                       placeholder="Nhập mã / tên sản phẩm"
                                                                       autocomplete="off"
                                                                       disabled="@(isSaving || isEditMode)" />
                                                                <span class="combo-arrow">⌄</span>
                                                                @if (!isEditMode && IsSanPhamDropdownOpen(line))
                                                                {
                                                                    var filteredSanPhamOptions = GetFilteredSanPhamOptions(line);
                                                                    <div class="combo-dropdown">
                                                                        @if (filteredSanPhamOptions.Count == 0)
                                                                        {
                                                                            <div class="combo-option combo-option--empty">
                                                                                <span class="combo-name">Không tìm thấy sản phẩm phù hợp.</span>
                                                                            </div>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach (var option in filteredSanPhamOptions)
                                                                            {
                                                                                <div class="@(line.San_Pham_ID == option.San_Pham_ID ? "combo-option active" : "combo-option")"
                                                                                     @onmousedown="() => SelectSanPhamForLine(line, option)">
                                                                                    <span class="combo-code">@option.Ma_San_Pham</span>
                                                                                    <span class="combo-name">@option.Ten_San_Pham</span>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </td>
                                                        <td class="line-table__unit">
                                                            <span class="unit-readonly">@GetDonViTinhBySanPhamId(line.San_Pham_ID)</span>
                                                        </td>
                                                        <td>
                                                            <div class="quantity-stepper qty-box">
                                                                <button type="button"
                                                                        class="quantity-stepper__button qty-btn"
                                                                        @onclick="() => DecreaseFormLineQuantity(line)"
                                                                        disabled="@(isSaving || isEditMode)">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input qty-input"
                                                                       value="@(isEditMode ? FormatQuantity(GetLineSoLuong(line)) : line.SL_Xuat_Text)"
                                                                       @oninput="e => line.SL_Xuat_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0"
                                                                       disabled="@(isSaving || isEditMode)" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button qty-btn"
                                                                        @onclick="() => IncreaseFormLineQuantity(line)"
                                                                        disabled="@(isSaving || isEditMode)">
                                                                    +
                                                                </button>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <input class="form-field__input line-input--number price-input"
                                                                   value="@line.Don_Gia_Xuat_Text"
                                                                   @oninput="e => line.Don_Gia_Xuat_Text = e.Value?.ToString() ?? string.Empty"
                                                                   @onblur="() => NormalizeFormLineDonGiaText(line)"
                                                                   disabled="@(isSaving || isEditMode)"
                                                                   inputmode="decimal"
                                                                   placeholder="Nhập đơn giá" />
                                                        </td>
                                                        <td class="line-table__number">@FormatAmountWithCurrency(GetLineTriGia(line), formModel.Don_Vi_Tien)</td>
                                                        <td>
                                                            <button type="button"
                                                                    class="app-button app-button--danger btn-delete-row"
                                                                    @onclick="() => RemoveDetailRow(index)"
                                                                    disabled="@(isSaving || isEditMode)">
                                                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                                                    <path d="M8 7h8m-7 0V5h6v2m-7 3v7m4-7v7m4-11v13a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V6h10z" />
                                                                </svg>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="total-row receipt-total-box">
                                        <span class="total-label">Tổng trị giá</span>
                                        <span class="total-value">@FormatAmountWithCurrency(formModel.Chi_Tiets.Sum(GetLineTriGia), formModel.Don_Vi_Tien)</span>
                                    </div>
                                </section>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        </div>
    }

    @if (isDetailEditorVisible && detailHeaderItem is not null)
    {
        <div class="modal-overlay" @onclick="HandleDetailEditorBackdropClick">
            <section class="card card--form modal-card modal-card--detail" @onclick:stopPropagation="true">
                <header class="card__header card__header--form">
                    <h2>Hiệu chỉnh chi tiết phiếu xuất</h2>
                    <div class="modal-header-actions">
                        <span class="card__tag">Bài 9</span>
                        <button type="button"
                                class="app-button app-button--ghost app-button--icon"
                                title="Đóng"
                                @onclick="CloseDetailEditor"
                                disabled="@isDetailLineSaving">
                            ×
                        </button>
                    </div>
                </header>

                <div class="card__body">
                    @if (isDetailEditorLoading)
                    {
                        <div class="state-box">Đang tải dữ liệu chi tiết phiếu xuất...</div>
                    }
                    else
                    {
                        <section class="header-info">
                            <h3 class="header-info__title">Thông tin phiếu xuất</h3>
                            <div class="header-info__grid">
                                <div class="header-info__item">
                                    <span class="header-info__label">Số phiếu xuất</span>
                                    <span class="header-info__value">@detailHeaderItem.So_Phieu_Xuat_Kho</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Ngày xuất kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ngay_Xuat_Kho.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ten_Kho</span>
                                </div>
                                <div class="header-info__item header-info__item--wide">
                                    <span class="header-info__label">Ghi chú</span>
                                    <span class="header-info__value">@(string.IsNullOrWhiteSpace(detailHeaderItem.Ghi_Chu) ? "Trống" : detailHeaderItem.Ghi_Chu)</span>
                                </div>
                            </div>
                        </section>

                        @if (!string.IsNullOrWhiteSpace(detailEditorMessage))
                        {
                            <div class="status-banner @(detailEditorMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                @detailEditorMessage
                            </div>
                        }

                        <section class="line-section">
                            <header class="line-section__header">
                                <h3>Lưới hiệu chỉnh chi tiết</h3>
                                <div class="line-section__tools">
                                    @if (!IsDetailEditorInEditMode)
                                    {
                                        <label class="currency-picker">
                                            <span class="currency-picker__label">Đơn vị tiền</span>
                                            <select class="currency-picker__input"
                                                    value="@CurrentDetailEditorDonViTien"
                                                    @onchange="HandleDetailEditorDonViTienChanged"
                                                    disabled="@isDetailLineSaving">
                                                @foreach (var currency in SupportedCurrencies)
                                                {
                                                    <option value="@currency">@currency</option>
                                                }
                                            </select>
                                        </label>
                                    }
                                    <button type="button"
                                            class="app-button app-button--secondary"
                                            @onclick="AddDetailEditorRow"
                                            disabled="@isDetailLineSaving">
                                        Thêm dòng
                                    </button>
                                </div>
                            </header>

                            <div class="table-wrap">
                                <table class="line-table line-table--editor">
                                    <thead>
                                        <tr>
                                            <th class="line-table__index">STT</th>
                                            <th>Mã sản phẩm</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="line-table__number">Số lượng</th>
                                            <th class="line-table__number">Đơn giá</th>
                                            <th class="line-table__number">Trị giá</th>
                                            <th class="line-table__actions">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (detailEditorLines.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="7">
                                                    <span class="data-table__muted">Phiếu xuất chưa có dòng chi tiết.</span>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @for (var i = 0; i < detailEditorLines.Count; i++)
                                            {
                                                var line = detailEditorLines[i];
                                                <tr class="@(line.IsEditing ? "line-editor__row line-editor__row--editing" : "line-editor__row")">
                                                    <td>@(i + 1)</td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            <InputSelect class="form-field__input"
                                                                         @bind-Value="line.San_Pham_ID">
                                                                <option value="0">-- Chọn sản phẩm --</option>
                                                                @foreach (var option in sanPhamOptions)
                                                                {
                                                                    <option value="@option.San_Pham_ID">@option.Ma_San_Pham</option>
                                                                }
                                                            </InputSelect>
                                                        }
                                                        else
                                                        {
                                                            <span class="data-table__code-value">@line.Ma_San_Pham</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            @GetSanPhamNameById(line.San_Pham_ID)
                                                        }
                                                        else
                                                        {
                                                            @line.Ten_San_Pham
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <div class="quantity-stepper">
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => DecreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input"
                                                                       value="@line.SL_Xuat_Text"
                                                                       @oninput="e => line.SL_Xuat_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => IncreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    +
                                                                </button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatQuantity(line.SL_Xuat)</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <input class="form-field__input line-input--number"
                                                                   value="@line.Don_Gia_Xuat_Text"
                                                                   @oninput="e => line.Don_Gia_Xuat_Text = e.Value?.ToString() ?? string.Empty"
                                                                   @onblur="() => NormalizeDetailLineDonGiaText(line)"
                                                                   inputmode="decimal"
                                                                   placeholder="Nhập đơn giá" />
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatAmount(line.Don_Gia_Xuat, CurrentDetailEditorDonViTien)</span>
                                                        }
                                                    </td>
                                                    <td class="line-table__number">@FormatAmountWithCurrency(GetDetailLineTriGia(line), CurrentDetailEditorDonViTien)</td>
                                                    <td>
                                                        <div class="action-group">
                                                            @if (line.IsEditing)
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--success"
                                                                        @onclick="() => SaveDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Lưu
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => CancelEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Hủy
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => StartEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Sửa
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--danger"
                                                                        @onclick="() => DeleteDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Xóa
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="line-table__number">@FormatAmountWithCurrency(detailEditorLines.Sum(GetDetailLineTriGia), CurrentDetailEditorDonViTien)</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </section>
                    }
                </div>
            </section>
        </div>
    }
</section>

@code {
    private readonly List<XuatKhoListItemVm> items = [];
    private readonly List<KhoListItemVm> khoOptions = [];
    private readonly List<SanPhamListItemVm> sanPhamOptions = [];
    private readonly Dictionary<XuatKhoRawDataUpsertVm, string> lineSanPhamKeywords = [];
    private readonly HashSet<XuatKhoRawDataUpsertVm> openedLineSanPhamDropdowns = [];
    private readonly List<XuatKhoDetailListItemVm> selectedDetails = [];
    private readonly List<XuatKhoDetailEditorLineVm> detailEditorLines = [];
    private XuatKhoCreateVm formModel = new();
    private XuatKhoListItemVm? detailHeaderItem;
    private bool isLoading = true;
    private bool isSaving;
    private bool isImporting;
    private bool isApplyingImport;
    private int importFileInputVersion;
    private bool showImportPreview;
    private string importPreviewFileName = string.Empty;
    private string importPreviewSheetName = string.Empty;
    private List<ExcelImportPreviewRow> importPreviewRows = [];
    private List<ExcelImportRow> importSourceRows = [];
    private bool isDetailLoading;
    private bool isDetailEditorLoading;
    private bool isDetailEditorVisible;
    private bool isDetailLineSaving;
    private bool isCreateFormVisible;
    private bool isEditMode;
    private int? editingXuatKhoId;
    private int? selectedXuatKhoId;
    private string? selectedSoPhieu;
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string? detailEditorMessage;
    private bool detailEditorMessageIsError;
    private string searchKeyword = string.Empty;
    private string ngayXuatKhoText = string.Empty;
    private bool isNgayXuatKhoCalendarOpen;
    private DateTime ngayXuatKhoCalendarMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? ngayXuatKhoCalendarSelection;
    private const string ImportHeaderSoPhieuXuat = "Số phiếu xuất";
    private const string ImportHeaderNgayXuatKho = "Ngày xuất kho";
    private const string ImportHeaderSanPham = "Sản phẩm";
    private const string ImportHeaderSoLuongXuat = "Số lượng xuất";
    private const string ImportHeaderDonGiaXuat = "Đơn giá xuất";
    private const string ImportHeaderDonViTien = "Đơn vị tiền";
    private const string ImportHeaderGhiChu = "Ghi chú";
    private const int MaxSanPhamComboboxOptions = 8;
    private static readonly IReadOnlyList<string> CalendarDayHeaders = ["T2", "T3", "T4", "T5", "T6", "T7", "CN"];

    private static readonly IReadOnlyList<string> ImportPreviewHeaders =
    [
        ImportHeaderSoPhieuXuat,
        ImportHeaderNgayXuatKho,
        ImportHeaderSanPham,
        ImportHeaderSoLuongXuat,
        ImportHeaderDonGiaXuat,
        ImportHeaderDonViTien,
        ImportHeaderGhiChu
    ];
    private IReadOnlyList<string> SupportedCurrencies => DonViTienOptions.SupportedValues;
    private string CurrentDetailEditorDonViTien => DonViTienOptions.Normalize(detailHeaderItem?.Don_Vi_Tien);
    private string SelectedDonViTien =>
        items.FirstOrDefault(x => x.Xuat_Kho_ID == selectedXuatKhoId)?.Don_Vi_Tien ?? DonViTienOptions.Vnd;
    private bool IsDetailEditorInEditMode => detailEditorLines.Any(x => x.IsEditing);

    private bool IsFormVisible => isCreateFormVisible;
    private bool HasRequiredLookupData => khoOptions.Count > 0 && sanPhamOptions.Count > 0;

    private IReadOnlyList<XuatKhoListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();
            return items
                .Where(x =>
                    ContainsKeyword(x.So_Phieu_Xuat_Kho, keyword)
                    || ContainsKeyword(x.Ten_Kho, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        AppSelectionContext.SelectionChanged += HandleSelectionChanged;
        await AppSelectionContext.EnsureInitializedAsync();
        await LoadDataAsync();
    }

    public void Dispose()
    {
        AppSelectionContext.SelectionChanged -= HandleSelectionChanged;
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var selectedKhoId = AppSelectionContext.SelectedKhoId;
            var getXuatKhoTask = XuatKhoService.GetAllAsync(selectedKhoId);
            var getSanPhamTask = SanPhamService.GetAllAsync();

            await Task.WhenAll(getXuatKhoTask, getSanPhamTask);

            items.Clear();
            items.AddRange(getXuatKhoTask.Result);

            khoOptions.Clear();
            khoOptions.AddRange(AppSelectionContext.KhoOptions);

            sanPhamOptions.Clear();
            sanPhamOptions.AddRange(getSanPhamTask.Result);

            if (khoOptions.Count == 0)
            {
                pageMessage = "Tài khoản đang chọn chưa được phân quyền kho nào.";
                pageMessageIsError = true;
            }
            else if (!HasRequiredLookupData)
            {
                pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi tạo phiếu xuất.";
                pageMessageIsError = true;
            }

            if (selectedXuatKhoId.HasValue)
            {
                var selectedExists = items.Any(x => x.Xuat_Kho_ID == selectedXuatKhoId.Value);
                if (!selectedExists)
                {
                    selectedXuatKhoId = null;
                    selectedSoPhieu = null;
                    selectedDetails.Clear();
                }
                else
                {
                    await LoadDetailsAsync(selectedXuatKhoId.Value, selectedSoPhieu);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load XuatKho page data failed.");
            pageMessage = "Không thể tải dữ liệu quản lý phiếu xuất kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi tạo phiếu xuất.";
            pageMessageIsError = true;
            return;
        }

        isCreateFormVisible = true;
        isEditMode = false;
        editingXuatKhoId = null;
        ResetFormModel();
    }

    private void CancelForm()
    {
        isCreateFormVisible = false;
        isEditMode = false;
        editingXuatKhoId = null;
        ResetFormModel();
        ClearFormMessage();
    }

    private void HandleModalBackdropClick()
    {
        if (isSaving)
        {
            return;
        }

        CancelForm();
    }

    private void ResetFormModel()
    {
        var defaultKhoId = AppSelectionContext.SelectedKhoId
            ?? khoOptions.FirstOrDefault()?.Kho_ID
            ?? 0;

        formModel = new XuatKhoCreateVm
        {
            Xuat_Kho_ID = 0,
            Kho_ID = defaultKhoId,
            Ngay_Xuat_Kho = DateTime.Today,
            Don_Vi_Tien = DonViTienOptions.Vnd
        };
        ResetLineSanPhamComboboxState();
        ReformatFormLineValues();
        ngayXuatKhoText = formModel.Ngay_Xuat_Kho.ToString("dd/MM/yyyy");
        isNgayXuatKhoCalendarOpen = false;
        ngayXuatKhoCalendarSelection = null;
        ngayXuatKhoCalendarMonth = new DateTime(formModel.Ngay_Xuat_Kho.Year, formModel.Ngay_Xuat_Kho.Month, 1);
    }

    private void HandleSelectionChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();

            if (IsFormVisible)
            {
                ApplySelectedKhoToForm();
            }

            StateHasChanged();
        });
    }

    private void ApplySelectedKhoToForm()
    {
        if (!AppSelectionContext.SelectedKhoId.HasValue)
        {
            return;
        }

        formModel.Kho_ID = AppSelectionContext.SelectedKhoId.Value;
    }

    private string GetSelectedKhoDisplayName()
    {
        if (!string.IsNullOrWhiteSpace(AppSelectionContext.SelectedKhoName))
        {
            return AppSelectionContext.SelectedKhoName;
        }

        return khoOptions.FirstOrDefault(x => x.Kho_ID == formModel.Kho_ID)?.Ten_Kho ?? string.Empty;
    }

    private bool TrySyncKhoFromHeader(out string validationMessage)
    {
        validationMessage = string.Empty;
        var selectedKhoId = AppSelectionContext.SelectedKhoId;
        if (!selectedKhoId.HasValue || selectedKhoId.Value <= 0)
        {
            formModel.Kho_ID = 0;
            validationMessage = "Vui lòng chọn kho trên bộ lọc header trước khi lưu phiếu xuất.";
            return false;
        }

        formModel.Kho_ID = selectedKhoId.Value;
        return true;
    }

    private async Task StartEditAsync(XuatKhoListItemVm item)
    {
        if (isSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi sửa phiếu xuất.";
            pageMessageIsError = true;
            return;
        }

        try
        {
            var detailResult = await XuatKhoService.GetDetailsAsync(item.Xuat_Kho_ID);
            if (!detailResult.Success || detailResult.Data is null)
            {
                pageMessage = detailResult.Message;
                pageMessageIsError = true;
                return;
            }

            var donViTien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
            var detailRows = detailResult.Data
                .Select(x => new XuatKhoRawDataUpsertVm
                {
                    San_Pham_ID = x.San_Pham_ID,
                    SL_Xuat = x.SL_Xuat,
                    Don_Gia_Xuat = x.Don_Gia_Xuat,
                    SL_Xuat_Text = FormatQuantityForInput(x.SL_Xuat),
                    Don_Gia_Xuat_Text = FormatAmountInput(x.Don_Gia_Xuat, donViTien)
                })
                .ToList();

            formModel = new XuatKhoCreateVm
            {
                Xuat_Kho_ID = item.Xuat_Kho_ID,
                So_Phieu_Xuat_Kho = item.So_Phieu_Xuat_Kho,
                Kho_ID = AppSelectionContext.SelectedKhoId ?? item.Kho_ID,
                Ngay_Xuat_Kho = item.Ngay_Xuat_Kho,
                Don_Vi_Tien = donViTien,
                Ghi_Chu = item.Ghi_Chu,
                Chi_Tiets = detailRows
            };

            InitializeLineSanPhamComboboxState(detailRows);
            ReformatFormLineValues();

            ngayXuatKhoText = formModel.Ngay_Xuat_Kho.ToString("dd/MM/yyyy");
            isNgayXuatKhoCalendarOpen = false;
            ngayXuatKhoCalendarSelection = null;
            ngayXuatKhoCalendarMonth = new DateTime(formModel.Ngay_Xuat_Kho.Year, formModel.Ngay_Xuat_Kho.Month, 1);
            isEditMode = true;
            editingXuatKhoId = item.Xuat_Kho_ID;
            isCreateFormVisible = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Start edit XuatKho failed. Xuat_Kho_ID={Xuat_Kho_ID}", item.Xuat_Kho_ID);
            pageMessage = "Không thể mở dữ liệu phiếu xuất để chỉnh sửa.";
            pageMessageIsError = true;
        }
    }

    private async Task StartDetailEditorAsync(XuatKhoListItemVm item)
    {
        if (isSaving || isDetailLineSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();
        ClearDetailEditorMessage();

        item.Don_Vi_Tien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
        detailHeaderItem = item;
        isDetailEditorVisible = true;

        await ReloadDetailEditorLinesAsync();
    }

