@page "/xuat-kho"
@rendermode InteractiveServer
@using System.Globalization
@using BlazorApp1.Models.Kho
@using BlazorApp1.Models.Common
@using BlazorApp1.Models.XuatKho
@using BlazorApp1.Models.SanPham
@using BlazorApp1.Services.Interfaces
@inject IXuatKhoService XuatKhoService
@inject IKhoService KhoService
@inject ISanPhamService SanPhamService
@inject IJSRuntime JS
@inject ILogger<XuatKhoPage> Logger

<PageTitle>Quản lý phiếu xuất kho</PageTitle>

<section class="import-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Quản lý phiếu xuất kho</h1>
        <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@isSaving">
            Thêm phiếu xuất
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <div class="import-layout import-layout--single">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách phiếu xuất (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Số phiếu, kho" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Số phiếu</th>
                                    <th>Ngày xuất</th>
                                    <th>Kho</th>
                                    <th class="data-table__number">Số dòng</th>
                                    <th class="data-table__number">Tổng trị giá</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(selectedXuatKhoId == item.Xuat_Kho_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        title="Bấm để mở phiếu xuất và chỉnh sửa"
                                        @onclick="() => StartEditAsync(item)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.So_Phieu_Xuat_Kho</td>
                                        <td>@item.Ngay_Xuat_Kho.ToString("dd/MM/yyyy")</td>
                                        <td class="data-table__name">@item.Ten_Kho</td>
                                        <td class="data-table__number">@item.So_Dong_Chi_Tiet</td>
                                        <td class="data-table__number">@FormatAmountWithCurrency(item.Tong_Tri_Gia, item.Don_Vi_Tien)</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => OpenPrintFormAsync(item.Xuat_Kho_ID)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    In
                                                </button>
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => StartDetailEditorAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Chi tiết
                                                </button>
                                                <button class="app-button app-button--secondary"
                                                        @onclick="() => StartEditAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Sửa
                                                </button>
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Xuat_Kho_ID, item.So_Phieu_Xuat_Kho)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (selectedXuatKhoId.HasValue)
                {
                    <section class="detail-panel">
                        <header class="detail-panel__header">
                            <h3>Chi tiết phiếu xuất: @selectedSoPhieu</h3>
                            <span class="card__tag">Đơn vị tiền: @SelectedDonViTien</span>
                        </header>

                        @if (isDetailLoading)
                        {
                            <div class="state-box">Đang tải chi tiết...</div>
                        }
                        else if (selectedDetails.Count == 0)
                        {
                            <div class="state-box state-box--empty">Phiếu xuất chưa có dòng chi tiết.</div>
                        }
                        else
                        {
                            <div class="table-wrap">
                                <table class="detail-table">
                                    <thead>
                                        <tr>
                                            <th>STT</th>
                                            <th>Mã SP</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="detail-table__number">SL xuất</th>
                                            <th class="detail-table__number">Đơn giá</th>
                                            <th class="detail-table__number">Trị giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < selectedDetails.Count; i++)
                                        {
                                            var detail = selectedDetails[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@detail.Ma_San_Pham</td>
                                                <td>@detail.Ten_San_Pham</td>
                                                <td class="detail-table__number">@FormatQuantity(detail.SL_Xuat)</td>
                                                <td class="detail-table__number">@FormatAmount(detail.Don_Gia_Xuat, SelectedDonViTien)</td>
                                                <td class="detail-table__number">@FormatAmountWithCurrency(detail.Tri_Gia, SelectedDonViTien)</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="detail-table__number">@FormatAmountWithCurrency(selectedDetails.Sum(x => x.Tri_Gia), SelectedDonViTien)</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    </section>
                }
            </div>
        </section>
    </div>

    @if (IsFormVisible)
    {
        <div class="modal-overlay" @onclick="HandleModalBackdropClick">
            <section class="card card--form modal-card" @onclick:stopPropagation="true">
                <header class="card__header card__header--form">
                    <h2>@(isEditMode ? "Sửa phiếu xuất kho" : "Tạo phiếu xuất kho")</h2>
                    <div class="modal-header-actions">
                        <span class="card__tag">@(isEditMode ? "Chế độ chỉnh sửa" : "Chỉ thêm mới")</span>
                        <button type="button"
                                class="app-button app-button--ghost app-button--icon"
                                title="Đóng"
                                @onclick="CancelForm"
                                disabled="@isSaving">
                            ×
                        </button>
                    </div>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="XuatKhoForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-grid">
                                <div class="form-field form-field--code">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Số phiếu xuất <span class="required-mark">*</span></label>
                                        <span class="form-field__count">@((formModel.So_Phieu_Xuat_Kho?.Length ?? 0))/50</span>
                                    </div>
                                    <InputText class="form-field__input"
                                               @bind-Value="formModel.So_Phieu_Xuat_Kho"
                                               @oninput="HandleSoPhieuInput"
                                               maxlength="50"
                                               placeholder="Nhập số phiếu xuất kho" />
                                    <p class="form-field__hint">Không được để trống và phải duy nhất.</p>
                                    <ValidationMessage For="@(() => formModel.So_Phieu_Xuat_Kho)" />
                                </div>

                                <div class="form-field form-field--lookup">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Kho <span class="required-mark">*</span></label>
                                    </div>
                                    <InputSelect class="form-field__input" @bind-Value="formModel.Kho_ID">
                                        <option value="0">-- Chọn kho --</option>
                                        @foreach (var option in khoOptions)
                                        {
                                            <option value="@option.Kho_ID">@option.Ten_Kho</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => formModel.Kho_ID)" />
                                </div>

                                <div class="form-field form-field--date">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Ngày xuất kho <span class="required-mark">*</span></label>
                                    </div>
                                    <InputText class="form-field__input"
                                               @bind-Value="ngayXuatKhoText"
                                               @oninput="HandleNgayXuatKhoInput"
                                               maxlength="10"
                                               placeholder="dd/MM/yyyy" />
                                    <p class="form-field__hint">Định dạng bắt buộc: dd/MM/yyyy.</p>
                                    <ValidationMessage For="@(() => formModel.Ngay_Xuat_Kho)" />
                                </div>
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhiChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <section class="line-section">
                                <header class="line-section__header">
                                    <h3>Chi tiết xuất kho</h3>
                                    @if (!isEditMode)
                                    {
                                        <div class="line-section__tools">
                                            <label class="currency-picker">
                                                <span class="currency-picker__label">Đơn vị tiền</span>
                                                <select class="currency-picker__input"
                                                        value="@formModel.Don_Vi_Tien"
                                                        @onchange="HandleFormDonViTienChanged"
                                                        disabled="@isSaving">
                                                    @foreach (var currency in SupportedCurrencies)
                                                    {
                                                        <option value="@currency">@currency</option>
                                                    }
                                                </select>
                                            </label>
                                            <button type="button" class="app-button app-button--secondary" @onclick="AddDetailRow" disabled="@isSaving">
                                                Thêm dòng
                                            </button>
                                        </div>
                                    }
                                </header>

                                <div class="table-wrap">
                                    <table class="line-table">
                                        <thead>
                                            <tr>
                                                <th class="line-table__index">STT</th>
                                                <th>Sản phẩm <span class="required-mark">*</span></th>
                                                <th>Đơn vị tính</th>
                                                <th class="line-table__number">SL xuất <span class="required-mark">*</span></th>
                                                <th class="line-table__number">Đơn giá xuất <span class="required-mark">*</span></th>
                                                <th class="line-table__number">Trị giá</th>
                                                @if (!isEditMode)
                                                {
                                                    <th class="line-table__actions">Thao tác</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < formModel.Chi_Tiets.Count; i++)
                                            {
                                                var index = i;
                                                var line = formModel.Chi_Tiets[index];
                                                <tr>
                                                    <td>@(index + 1)</td>
                                                    <td>
                                                        <InputSelect class="form-field__input"
                                                                     @bind-Value="line.San_Pham_ID"
                                                                     disabled="@isEditMode">
                                                            <option value="0">-- Chọn sản phẩm --</option>
                                                            @foreach (var option in sanPhamOptions)
                                                            {
                                                                <option value="@option.San_Pham_ID">@option.Ten_San_Pham (@option.Ma_San_Pham)</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td class="line-table__unit">
                                                        @GetDonViTinhBySanPhamId(line.San_Pham_ID)
                                                    </td>
                                                    <td>
                                                        @if (isEditMode)
                                                        {
                                                            <span class="line-table__number">@FormatQuantity(GetLineSoLuong(line))</span>
                                                        }
                                                        else
                                                        {
                                                            <div class="quantity-stepper">
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => DecreaseFormLineQuantity(line)"
                                                                        disabled="@isSaving">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input"
                                                                       value="@line.SL_Xuat_Text"
                                                                       @oninput="e => line.SL_Xuat_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => IncreaseFormLineQuantity(line)"
                                                                        disabled="@isSaving">
                                                                    +
                                                                </button>
                                                            </div>
                                                        }
                                                    </td>
                                                    <td>
                                                        <input class="form-field__input line-input--number"
                                                               value="@line.Don_Gia_Xuat_Text"
                                                               @oninput="e => line.Don_Gia_Xuat_Text = e.Value?.ToString() ?? string.Empty"
                                                               @onblur="() => NormalizeFormLineDonGiaText(line)"
                                                               disabled="@isEditMode"
                                                               inputmode="decimal"
                                                               placeholder="Nhập đơn giá" />
                                                    </td>
                                                    <td class="line-table__number">@FormatAmountWithCurrency(GetLineTriGia(line), formModel.Don_Vi_Tien)</td>
                                                    @if (!isEditMode)
                                                    {
                                                        <td>
                                                            <button type="button"
                                                                    class="app-button app-button--danger"
                                                                    @onclick="() => RemoveDetailRow(index)"
                                                                    disabled="@isSaving">
                                                                Xóa dòng
                                                            </button>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="5">Tổng trị giá</td>
                                                <td class="line-table__number">@FormatAmountWithCurrency(formModel.Chi_Tiets.Sum(GetLineTriGia), formModel.Don_Vi_Tien)</td>
                                                @if (!isEditMode)
                                                {
                                                    <td></td>
                                                }
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </section>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@(!HasRequiredLookupData || isSaving)">
                                    @(isSaving ? "Đang lưu..." : isEditMode ? "Lưu cập nhật" : "Lưu phiếu xuất")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        </div>
    }

    @if (isDetailEditorVisible && detailHeaderItem is not null)
    {
        <div class="modal-overlay" @onclick="HandleDetailEditorBackdropClick">
            <section class="card card--form modal-card modal-card--detail" @onclick:stopPropagation="true">
                <header class="card__header card__header--form">
                    <h2>Hiệu chỉnh chi tiết phiếu xuất</h2>
                    <div class="modal-header-actions">
                        <span class="card__tag">Bài 9</span>
                        <button type="button"
                                class="app-button app-button--ghost app-button--icon"
                                title="Đóng"
                                @onclick="CloseDetailEditor"
                                disabled="@isDetailLineSaving">
                            ×
                        </button>
                    </div>
                </header>

                <div class="card__body">
                    @if (isDetailEditorLoading)
                    {
                        <div class="state-box">Đang tải dữ liệu chi tiết phiếu xuất...</div>
                    }
                    else
                    {
                        <section class="header-info">
                            <h3 class="header-info__title">Thông tin phiếu xuất</h3>
                            <div class="header-info__grid">
                                <div class="header-info__item">
                                    <span class="header-info__label">Số phiếu xuất</span>
                                    <span class="header-info__value">@detailHeaderItem.So_Phieu_Xuat_Kho</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Ngày xuất kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ngay_Xuat_Kho.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ten_Kho</span>
                                </div>
                                <div class="header-info__item header-info__item--wide">
                                    <span class="header-info__label">Ghi chú</span>
                                    <span class="header-info__value">@(string.IsNullOrWhiteSpace(detailHeaderItem.Ghi_Chu) ? "Trống" : detailHeaderItem.Ghi_Chu)</span>
                                </div>
                            </div>
                        </section>

                        @if (!string.IsNullOrWhiteSpace(detailEditorMessage))
                        {
                            <div class="status-banner @(detailEditorMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                @detailEditorMessage
                            </div>
                        }

                        <section class="line-section">
                            <header class="line-section__header">
                                <h3>Lưới hiệu chỉnh chi tiết</h3>
                                <div class="line-section__tools">
                                    @if (!IsDetailEditorInEditMode)
                                    {
                                        <label class="currency-picker">
                                            <span class="currency-picker__label">Đơn vị tiền</span>
                                            <select class="currency-picker__input"
                                                    value="@CurrentDetailEditorDonViTien"
                                                    @onchange="HandleDetailEditorDonViTienChanged"
                                                    disabled="@isDetailLineSaving">
                                                @foreach (var currency in SupportedCurrencies)
                                                {
                                                    <option value="@currency">@currency</option>
                                                }
                                            </select>
                                        </label>
                                    }
                                    <button type="button"
                                            class="app-button app-button--secondary"
                                            @onclick="AddDetailEditorRow"
                                            disabled="@isDetailLineSaving">
                                        Thêm dòng
                                    </button>
                                </div>
                            </header>

                            <div class="table-wrap">
                                <table class="line-table line-table--editor">
                                    <thead>
                                        <tr>
                                            <th class="line-table__index">STT</th>
                                            <th>Mã sản phẩm</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="line-table__number">Số lượng</th>
                                            <th class="line-table__number">Đơn giá</th>
                                            <th class="line-table__number">Trị giá</th>
                                            <th class="line-table__actions">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (detailEditorLines.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="7">
                                                    <span class="data-table__muted">Phiếu xuất chưa có dòng chi tiết.</span>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @for (var i = 0; i < detailEditorLines.Count; i++)
                                            {
                                                var line = detailEditorLines[i];
                                                <tr class="@(line.IsEditing ? "line-editor__row line-editor__row--editing" : "line-editor__row")">
                                                    <td>@(i + 1)</td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            <InputSelect class="form-field__input"
                                                                         @bind-Value="line.San_Pham_ID">
                                                                <option value="0">-- Chọn sản phẩm --</option>
                                                                @foreach (var option in sanPhamOptions)
                                                                {
                                                                    <option value="@option.San_Pham_ID">@option.Ma_San_Pham</option>
                                                                }
                                                            </InputSelect>
                                                        }
                                                        else
                                                        {
                                                            <span class="data-table__code-value">@line.Ma_San_Pham</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            @GetSanPhamNameById(line.San_Pham_ID)
                                                        }
                                                        else
                                                        {
                                                            @line.Ten_San_Pham
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <div class="quantity-stepper">
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => DecreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input"
                                                                       value="@line.SL_Xuat_Text"
                                                                       @oninput="e => line.SL_Xuat_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => IncreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    +
                                                                </button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatQuantity(line.SL_Xuat)</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <input class="form-field__input line-input--number"
                                                                   value="@line.Don_Gia_Xuat_Text"
                                                                   @oninput="e => line.Don_Gia_Xuat_Text = e.Value?.ToString() ?? string.Empty"
                                                                   @onblur="() => NormalizeDetailLineDonGiaText(line)"
                                                                   inputmode="decimal"
                                                                   placeholder="Nhập đơn giá" />
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatAmount(line.Don_Gia_Xuat, CurrentDetailEditorDonViTien)</span>
                                                        }
                                                    </td>
                                                    <td class="line-table__number">@FormatAmountWithCurrency(GetDetailLineTriGia(line), CurrentDetailEditorDonViTien)</td>
                                                    <td>
                                                        <div class="action-group">
                                                            @if (line.IsEditing)
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--success"
                                                                        @onclick="() => SaveDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Lưu
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => CancelEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Hủy
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => StartEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Sửa
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--danger"
                                                                        @onclick="() => DeleteDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Xóa
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="line-table__number">@FormatAmountWithCurrency(detailEditorLines.Sum(GetDetailLineTriGia), CurrentDetailEditorDonViTien)</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </section>
                    }
                </div>
            </section>
        </div>
    }
</section>

@code {
    private readonly List<XuatKhoListItemVm> items = [];
    private readonly List<KhoListItemVm> khoOptions = [];
    private readonly List<SanPhamListItemVm> sanPhamOptions = [];
    private readonly List<XuatKhoDetailListItemVm> selectedDetails = [];
    private readonly List<XuatKhoDetailEditorLineVm> detailEditorLines = [];
    private XuatKhoCreateVm formModel = new();
    private XuatKhoListItemVm? detailHeaderItem;
    private bool isLoading = true;
    private bool isSaving;
    private bool isDetailLoading;
    private bool isDetailEditorLoading;
    private bool isDetailEditorVisible;
    private bool isDetailLineSaving;
    private bool isCreateFormVisible;
    private bool isEditMode;
    private int? editingXuatKhoId;
    private int? selectedXuatKhoId;
    private string? selectedSoPhieu;
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string? detailEditorMessage;
    private bool detailEditorMessageIsError;
    private string searchKeyword = string.Empty;
    private string ngayXuatKhoText = string.Empty;
    private IReadOnlyList<string> SupportedCurrencies => DonViTienOptions.SupportedValues;
    private string CurrentDetailEditorDonViTien => DonViTienOptions.Normalize(detailHeaderItem?.Don_Vi_Tien);
    private string SelectedDonViTien =>
        items.FirstOrDefault(x => x.Xuat_Kho_ID == selectedXuatKhoId)?.Don_Vi_Tien ?? DonViTienOptions.Vnd;
    private bool IsDetailEditorInEditMode => detailEditorLines.Any(x => x.IsEditing);

    private bool IsFormVisible => isCreateFormVisible;
    private bool HasRequiredLookupData => khoOptions.Count > 0 && sanPhamOptions.Count > 0;

    private IReadOnlyList<XuatKhoListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();
            return items
                .Where(x =>
                    ContainsKeyword(x.So_Phieu_Xuat_Kho, keyword)
                    || ContainsKeyword(x.Ten_Kho, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var getXuatKhoTask = XuatKhoService.GetAllAsync();
            var getKhoTask = KhoService.GetAllAsync();
            var getSanPhamTask = SanPhamService.GetAllAsync();

            await Task.WhenAll(getXuatKhoTask, getKhoTask, getSanPhamTask);

            items.Clear();
            items.AddRange(getXuatKhoTask.Result);

            khoOptions.Clear();
            khoOptions.AddRange(getKhoTask.Result);

            sanPhamOptions.Clear();
            sanPhamOptions.AddRange(getSanPhamTask.Result);

            if (!HasRequiredLookupData)
            {
                pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi tạo phiếu xuất.";
                pageMessageIsError = true;
            }

            if (selectedXuatKhoId.HasValue)
            {
                var selectedExists = items.Any(x => x.Xuat_Kho_ID == selectedXuatKhoId.Value);
                if (!selectedExists)
                {
                    selectedXuatKhoId = null;
                    selectedSoPhieu = null;
                    selectedDetails.Clear();
                }
                else
                {
                    await LoadDetailsAsync(selectedXuatKhoId.Value, selectedSoPhieu);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load XuatKho page data failed.");
            pageMessage = "Không thể tải dữ liệu quản lý phiếu xuất kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi tạo phiếu xuất.";
            pageMessageIsError = true;
            return;
        }

        isCreateFormVisible = true;
        isEditMode = false;
        editingXuatKhoId = null;
        ResetFormModel();
    }

    private void CancelForm()
    {
        isCreateFormVisible = false;
        isEditMode = false;
        editingXuatKhoId = null;
        ResetFormModel();
        ClearFormMessage();
    }

    private void HandleModalBackdropClick()
    {
        if (isSaving)
        {
            return;
        }

        CancelForm();
    }

    private void ResetFormModel()
    {
        formModel = new XuatKhoCreateVm
        {
            Xuat_Kho_ID = 0,
            Ngay_Xuat_Kho = DateTime.Today,
            Don_Vi_Tien = DonViTienOptions.Vnd
        };
        ReformatFormLineValues();
        ngayXuatKhoText = formModel.Ngay_Xuat_Kho.ToString("dd/MM/yyyy");
    }

    private async Task StartEditAsync(XuatKhoListItemVm item)
    {
        if (isSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi sửa phiếu xuất.";
            pageMessageIsError = true;
            return;
        }

        try
        {
            var detailResult = await XuatKhoService.GetDetailsAsync(item.Xuat_Kho_ID);
            if (!detailResult.Success || detailResult.Data is null)
            {
                pageMessage = detailResult.Message;
                pageMessageIsError = true;
                return;
            }

            var donViTien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
            var detailRows = detailResult.Data
                .Select(x => new XuatKhoRawDataUpsertVm
                {
                    San_Pham_ID = x.San_Pham_ID,
                    SL_Xuat = x.SL_Xuat,
                    Don_Gia_Xuat = x.Don_Gia_Xuat,
                    SL_Xuat_Text = FormatQuantityForInput(x.SL_Xuat),
                    Don_Gia_Xuat_Text = FormatAmountInput(x.Don_Gia_Xuat, donViTien)
                })
                .ToList();

            formModel = new XuatKhoCreateVm
            {
                Xuat_Kho_ID = item.Xuat_Kho_ID,
                So_Phieu_Xuat_Kho = item.So_Phieu_Xuat_Kho,
                Kho_ID = item.Kho_ID,
                Ngay_Xuat_Kho = item.Ngay_Xuat_Kho,
                Don_Vi_Tien = donViTien,
                Ghi_Chu = item.Ghi_Chu,
                Chi_Tiets = detailRows
            };

            ReformatFormLineValues();

            ngayXuatKhoText = formModel.Ngay_Xuat_Kho.ToString("dd/MM/yyyy");
            isEditMode = true;
            editingXuatKhoId = item.Xuat_Kho_ID;
            isCreateFormVisible = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Start edit XuatKho failed. Xuat_Kho_ID={Xuat_Kho_ID}", item.Xuat_Kho_ID);
            pageMessage = "Không thể mở dữ liệu phiếu xuất để chỉnh sửa.";
            pageMessageIsError = true;
        }
    }

    private async Task StartDetailEditorAsync(XuatKhoListItemVm item)
    {
        if (isSaving || isDetailLineSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();
        ClearDetailEditorMessage();

        item.Don_Vi_Tien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
        detailHeaderItem = item;
        isDetailEditorVisible = true;

        await ReloadDetailEditorLinesAsync();
    }

    private async Task OpenPrintFormAsync(int xuatKhoId)
    {
        if (xuatKhoId <= 0)
        {
            pageMessage = "Không thể mở phiếu in vì ID phiếu xuất không hợp lệ.";
            pageMessageIsError = true;
            return;
        }

        var printUrl = $"/xuat-kho/{xuatKhoId}/print";
        await JS.InvokeVoidAsync("open", printUrl, "_blank");
    }

    private async Task ReloadDetailEditorLinesAsync()
    {
        if (detailHeaderItem is null)
        {
            return;
        }

        isDetailEditorLoading = true;
        detailEditorLines.Clear();

        try
        {
            var result = await XuatKhoService.GetDetailsAsync(detailHeaderItem.Xuat_Kho_ID);
            if (!result.Success || result.Data is null)
            {
                detailEditorMessage = result.Message;
                detailEditorMessageIsError = true;
                return;
            }

            detailEditorLines.AddRange(result.Data.Select(ToDetailEditorLine));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load detail editor lines failed. Xuat_Kho_ID={Xuat_Kho_ID}", detailHeaderItem.Xuat_Kho_ID);
            detailEditorMessage = "Không thể tải dữ liệu hiệu chỉnh chi tiết phiếu xuất.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailEditorLoading = false;
        }
    }

    private void AddDetailEditorRow()
    {
        ClearDetailEditorMessage();

        if (detailHeaderItem is null)
        {
            detailEditorMessage = "Không tìm thấy thông tin phiếu xuất.";
            detailEditorMessageIsError = true;
            return;
        }

        if (detailEditorLines.Any(x => x.IsEditing))
        {
            detailEditorMessage = "Vui lòng lưu hoặc hủy dòng đang chỉnh sửa trước khi thêm dòng mới.";
            detailEditorMessageIsError = true;
            return;
        }

        detailEditorLines.Insert(0, new XuatKhoDetailEditorLineVm
        {
            IsNew = true,
            IsEditing = true,
            SL_Xuat = 1m,
            Don_Gia_Xuat = 0m,
            SL_Xuat_Text = "1",
            Don_Gia_Xuat_Text = FormatAmountInput(0m, CurrentDetailEditorDonViTien)
        });
    }

    private void StartEditDetailLine(XuatKhoDetailEditorLineVm line)
    {
        ClearDetailEditorMessage();

        if (detailEditorLines.Any(x => x != line && x.IsEditing))
        {
            detailEditorMessage = "Vui lòng lưu hoặc hủy dòng đang chỉnh sửa trước khi sửa dòng khác.";
            detailEditorMessageIsError = true;
            return;
        }

        line.IsEditing = true;
        line.SL_Xuat_Text = FormatQuantityForInput(line.SL_Xuat);
        line.Don_Gia_Xuat_Text = FormatAmountInput(line.Don_Gia_Xuat, CurrentDetailEditorDonViTien);
    }

    private void CancelEditDetailLine(XuatKhoDetailEditorLineVm line)
    {
        if (line.IsNew)
        {
            detailEditorLines.Remove(line);
            return;
        }

        line.IsEditing = false;
        line.SL_Xuat_Text = FormatQuantityForInput(line.SL_Xuat);
        line.Don_Gia_Xuat_Text = FormatAmountInput(line.Don_Gia_Xuat, CurrentDetailEditorDonViTien);
        ClearDetailEditorMessage();
    }

    private async Task SaveDetailLineAsync(XuatKhoDetailEditorLineVm line)
    {
        if (detailHeaderItem is null)
        {
            detailEditorMessage = "Không tìm thấy thông tin phiếu xuất.";
            detailEditorMessageIsError = true;
            return;
        }

        if (!TryParseDetailEditorLine(
                line,
                CurrentDetailEditorDonViTien,
                out var soLuong,
                out var donGia,
                out var validationMessage))
        {
            detailEditorMessage = validationMessage;
            detailEditorMessageIsError = true;
            return;
        }

        isDetailLineSaving = true;
        ClearDetailEditorMessage();

        try
        {
            ServiceResult result;
            if (line.IsNew)
            {
                if (line.San_Pham_ID <= 0)
                {
                    detailEditorMessage = "Mã sản phẩm không được để trống khi thêm dòng.";
                    detailEditorMessageIsError = true;
                    return;
                }

                result = await XuatKhoService.AddDetailAsync(detailHeaderItem.Xuat_Kho_ID, new XuatKhoDetailCreateVm
                {
                    San_Pham_ID = line.San_Pham_ID,
                    SL_Xuat = soLuong,
                    Don_Gia_Xuat = donGia
                });
            }
            else
            {
                result = await XuatKhoService.UpdateDetailAsync(new XuatKhoDetailUpdateVm
                {
                    Xuat_Kho_Raw_Data_ID = line.Xuat_Kho_Raw_Data_ID,
                    SL_Xuat = soLuong,
                    Don_Gia_Xuat = donGia
                });
            }

            detailEditorMessage = result.Message;
            detailEditorMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await ReloadDetailEditorLinesAsync();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save detail line failed. Xuat_Kho_ID={Xuat_Kho_ID}", detailHeaderItem.Xuat_Kho_ID);
            detailEditorMessage = "Không thể lưu dòng chi tiết do lỗi hệ thống.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailLineSaving = false;
        }
    }

    private async Task DeleteDetailLineAsync(XuatKhoDetailEditorLineVm line)
    {
        if (line.IsNew)
        {
            detailEditorLines.Remove(line);
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa dòng sản phẩm '{line.Ma_San_Pham}' khỏi phiếu xuất?");

        if (!confirmed)
        {
            return;
        }

        isDetailLineSaving = true;
        ClearDetailEditorMessage();

        try
        {
            var result = await XuatKhoService.DeleteDetailAsync(line.Xuat_Kho_Raw_Data_ID);
            detailEditorMessage = result.Message;
            detailEditorMessageIsError = !result.Success;

            if (!result.Success)
            {
                return;
            }

            await ReloadDetailEditorLinesAsync();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Delete detail line failed. Xuat_Kho_Raw_Data_ID={Xuat_Kho_Raw_Data_ID}", line.Xuat_Kho_Raw_Data_ID);
            detailEditorMessage = "Không thể xóa dòng chi tiết do lỗi hệ thống.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailLineSaving = false;
        }
    }

    private void CloseDetailEditor()
    {
        if (isDetailLineSaving)
        {
            return;
        }

        isDetailEditorVisible = false;
        isDetailEditorLoading = false;
        detailHeaderItem = null;
        detailEditorLines.Clear();
        ClearDetailEditorMessage();
    }

    private void HandleDetailEditorBackdropClick()
    {
        if (isDetailLineSaving)
        {
            return;
        }

        CloseDetailEditor();
    }

    private void ClearDetailEditorMessage()
    {
        detailEditorMessage = null;
        detailEditorMessageIsError = false;
    }

    private void AddDetailRow()
    {
        formModel.Chi_Tiets.Add(new XuatKhoRawDataUpsertVm
        {
            SL_Xuat = 1m,
            SL_Xuat_Text = "1",
            Don_Gia_Xuat = 0m,
            Don_Gia_Xuat_Text = FormatAmountInput(0m, formModel.Don_Vi_Tien)
        });
    }

    private void DecreaseFormLineQuantity(XuatKhoRawDataUpsertVm line)
    {
        var current = Math.Max(1m, GetLineSoLuong(line));
        var next = Math.Max(1m, current - 1m);
        line.SL_Xuat_Text = FormatQuantityForInput(next);
    }

    private void IncreaseFormLineQuantity(XuatKhoRawDataUpsertVm line)
    {
        var current = Math.Max(0m, GetLineSoLuong(line));
        var next = Math.Min(BusinessValidationRules.MaxQuantity, current + 1m);
        line.SL_Xuat_Text = FormatQuantityForInput(next);
    }

    private void DecreaseDetailLineQuantity(XuatKhoDetailEditorLineVm line)
    {
        var current = Math.Max(1m, GetDetailLineSoLuong(line));
        var next = Math.Max(1m, current - 1m);
        line.SL_Xuat_Text = FormatQuantityForInput(next);
    }

    private void IncreaseDetailLineQuantity(XuatKhoDetailEditorLineVm line)
    {
        var current = Math.Max(0m, GetDetailLineSoLuong(line));
        var next = Math.Min(BusinessValidationRules.MaxQuantity, current + 1m);
        line.SL_Xuat_Text = FormatQuantityForInput(next);
    }

    private void RemoveDetailRow(int index)
    {
        if (index < 0 || index >= formModel.Chi_Tiets.Count)
        {
            return;
        }

        if (formModel.Chi_Tiets.Count == 1)
        {
            formMessage = "Phiếu xuất phải có ít nhất 1 dòng chi tiết.";
            formMessageIsError = true;
            return;
        }

        formModel.Chi_Tiets.RemoveAt(index);
    }

    private async Task SelectXuatKhoAsync(int xuatKhoId, string soPhieu)
    {
        await LoadDetailsAsync(xuatKhoId, soPhieu);
    }

    private async Task LoadDetailsAsync(int xuatKhoId, string? soPhieu)
    {
        isDetailLoading = true;
        selectedXuatKhoId = xuatKhoId;
        selectedSoPhieu = soPhieu;
        selectedDetails.Clear();

        try
        {
            var result = await XuatKhoService.GetDetailsAsync(xuatKhoId);
            if (!result.Success || result.Data is null)
            {
                pageMessage = result.Message;
                pageMessageIsError = true;
                return;
            }

            selectedDetails.AddRange(result.Data);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load XuatKho details failed. Xuat_Kho_ID={Xuat_Kho_ID}", xuatKhoId);
            pageMessage = "Không thể tải chi tiết phiếu xuất kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isDetailLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (!HasRequiredLookupData)
        {
            formMessage = "Cần có dữ liệu Kho và Sản phẩm trước khi lưu.";
            formMessageIsError = true;
            return;
        }

        if (!TryParseNgayXuatKho(out var parsedNgayXuatKho))
        {
            formMessage = "Ngày xuất kho phải đúng định dạng dd/MM/yyyy.";
            formMessageIsError = true;
            return;
        }

        if (!BusinessValidationRules.IsValidVoucherDate(parsedNgayXuatKho))
        {
            formMessage = $"Ngày xuất kho phải trong khoảng {BusinessValidationRules.MinVoucherDate:dd/MM/yyyy} đến {BusinessValidationRules.MaxVoucherDate:dd/MM/yyyy}.";
            formMessageIsError = true;
            return;
        }

        if (!isEditMode && !TryApplyLineNumericValues(out var lineValidationMessage))
        {
            formMessage = lineValidationMessage;
            formMessageIsError = true;
            return;
        }

        formModel.Ngay_Xuat_Kho = parsedNgayXuatKho;

        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            ServiceResult result;
            if (isEditMode)
            {
                formModel.Xuat_Kho_ID = editingXuatKhoId ?? formModel.Xuat_Kho_ID;
                result = await XuatKhoService.UpdateHeaderAsync(formModel);
            }
            else
            {
                result = await XuatKhoService.CreateAsync(formModel);
            }

            formMessage = result.Message;
            formMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Save XuatKho failed. IsEditMode={IsEditMode}, Xuat_Kho_ID={Xuat_Kho_ID}, So_Phieu_Xuat_Kho={So_Phieu_Xuat_Kho}",
                isEditMode,
                formModel.Xuat_Kho_ID,
                formModel.So_Phieu_Xuat_Kho);
            formMessage = "Không thể lưu phiếu xuất do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string soPhieuXuatKho)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa phiếu xuất '{soPhieuXuatKho}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await XuatKhoService.DeleteAsync(id);
        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (selectedXuatKhoId == id)
        {
            selectedXuatKhoId = null;
            selectedSoPhieu = null;
            selectedDetails.Clear();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

    private void ClearSearch()
    {
        searchKeyword = string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        searchKeyword = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleSoPhieuInput(ChangeEventArgs args)
    {
        formModel.So_Phieu_Xuat_Kho = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleGhiChuInput(ChangeEventArgs args)
    {
        formModel.Ghi_Chu = args.Value?.ToString();
    }

    private void HandleNgayXuatKhoInput(ChangeEventArgs args)
    {
        ngayXuatKhoText = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleFormDonViTienChanged(ChangeEventArgs args)
    {
        formModel.Don_Vi_Tien = DonViTienOptions.Normalize(args.Value?.ToString());
        ReformatFormLineValues();
    }

    private async Task HandleDetailEditorDonViTienChanged(ChangeEventArgs args)
    {
        if (detailHeaderItem is null || isDetailLineSaving)
        {
            return;
        }

        var donViTien = DonViTienOptions.Normalize(args.Value?.ToString());
        if (string.Equals(donViTien, detailHeaderItem.Don_Vi_Tien, StringComparison.Ordinal))
        {
            return;
        }

        if (detailEditorLines.Any(x => x.IsEditing))
        {
            detailEditorMessage = "Vui lòng lưu hoặc hủy dòng đang chỉnh sửa trước khi đổi đơn vị tiền.";
            detailEditorMessageIsError = true;
            return;
        }

        isDetailLineSaving = true;
        ClearDetailEditorMessage();

        try
        {
            var result = await XuatKhoService.UpdateHeaderAsync(new XuatKhoCreateVm
            {
                Xuat_Kho_ID = detailHeaderItem.Xuat_Kho_ID,
                So_Phieu_Xuat_Kho = detailHeaderItem.So_Phieu_Xuat_Kho,
                Kho_ID = detailHeaderItem.Kho_ID,
                Ngay_Xuat_Kho = detailHeaderItem.Ngay_Xuat_Kho,
                Don_Vi_Tien = donViTien,
                Ghi_Chu = detailHeaderItem.Ghi_Chu,
                Chi_Tiets = []
            });

            detailEditorMessage = result.Message;
            detailEditorMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            detailHeaderItem.Don_Vi_Tien = donViTien;
            await LoadDataAsync();
            await ReloadDetailEditorLinesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Change currency failed in detail editor. Xuat_Kho_ID={Xuat_Kho_ID}", detailHeaderItem.Xuat_Kho_ID);
            detailEditorMessage = "Không thể đổi đơn vị tiền do lỗi hệ thống.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailLineSaving = false;
        }
    }

