    private static string FormatQuantityForInput(decimal value)
    {
        return decimal.Round(value, 0, MidpointRounding.AwayFromZero).ToString("0", CultureInfo.InvariantCulture);
    }

    private static string FormatAmountInput(decimal value, string? donViTien)
    {
        return DonViTienOptions.FormatAmountInput(value, donViTien);
    }

    private static string KeepDigitsOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsDigit).ToArray());
    }

    private string FormatAmount(decimal value, string? donViTien)
    {
        return DonViTienOptions.FormatAmount(value, donViTien);
    }

    private string FormatAmountWithCurrency(decimal value, string? donViTien)
    {
        var normalized = DonViTienOptions.Normalize(donViTien);
        return $"{FormatAmount(value, normalized)} {normalized}";
    }

    private string FormatQuantity(decimal value)
    {
        return DonViTienOptions.FormatQuantity(value);
    }

    private void ReformatFormLineValues()
    {
        formModel.Don_Vi_Tien = DonViTienOptions.Normalize(formModel.Don_Vi_Tien);
        foreach (var line in formModel.Chi_Tiets)
        {
            if (TryParsePositiveWholeNumber(line.SL_Xuat_Text, out var soLuong))
            {
                line.SL_Xuat_Text = FormatQuantityForInput(soLuong);
            }
            else
            {
                line.SL_Xuat_Text = FormatQuantityForInput(line.SL_Xuat);
            }

            if (TryParsePositiveDecimal(line.Don_Gia_Xuat_Text, formModel.Don_Vi_Tien, out var donGia)
                && BusinessValidationRules.HasValidAmountScale(donGia, formModel.Don_Vi_Tien))
            {
                line.Don_Gia_Xuat = DonViTienOptions.RoundAmount(donGia, formModel.Don_Vi_Tien);
            }

            line.Don_Gia_Xuat_Text = FormatAmountInput(line.Don_Gia_Xuat, formModel.Don_Vi_Tien);
        }
    }

    private void NormalizeFormLineDonGiaText(XuatKhoRawDataUpsertVm line)
    {
        if (TryParsePositiveDecimal(line.Don_Gia_Xuat_Text, formModel.Don_Vi_Tien, out var value)
            && BusinessValidationRules.HasValidAmountScale(value, formModel.Don_Vi_Tien))
        {
            line.Don_Gia_Xuat = DonViTienOptions.RoundAmount(value, formModel.Don_Vi_Tien);
            line.Don_Gia_Xuat_Text = FormatAmountInput(line.Don_Gia_Xuat, formModel.Don_Vi_Tien);
        }
    }

    private void NormalizeDetailLineDonGiaText(XuatKhoDetailEditorLineVm line)
    {
        if (TryParsePositiveDecimal(line.Don_Gia_Xuat_Text, CurrentDetailEditorDonViTien, out var value)
            && BusinessValidationRules.HasValidAmountScale(value, CurrentDetailEditorDonViTien))
        {
            line.Don_Gia_Xuat = DonViTienOptions.RoundAmount(value, CurrentDetailEditorDonViTien);
            line.Don_Gia_Xuat_Text = FormatAmountInput(line.Don_Gia_Xuat, CurrentDetailEditorDonViTien);
        }
    }

    private static string BuildAmountScaleMessage(string fieldLabel, string? donViTien)
    {
        return DonViTienOptions.UsesDecimalAmount(donViTien)
            ? $"{fieldLabel} tối đa 2 chữ số thập phân khi đơn vị tiền là USD."
            : $"{fieldLabel} không được có phần thập phân khi đơn vị tiền là VND.";
    }

    private string GetDonViTinhBySanPhamId(int sanPhamId)
    {
        if (sanPhamId <= 0)
        {
            return "—";
        }

        return sanPhamOptions.FirstOrDefault(x => x.San_Pham_ID == sanPhamId)?.Ten_Don_Vi_Tinh ?? "—";
    }

    private string GetSanPhamNameById(int sanPhamId)
    {
        if (sanPhamId <= 0)
        {
            return "—";
        }

        return sanPhamOptions.FirstOrDefault(x => x.San_Pham_ID == sanPhamId)?.Ten_San_Pham ?? "—";
    }

