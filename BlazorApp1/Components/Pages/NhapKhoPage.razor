    private async Task LoadDetailsAsync(int nhapKhoId, string? soPhieu)
    {
        isDetailLoading = true;
        selectedNhapKhoId = nhapKhoId;
        selectedSoPhieu = soPhieu;
        selectedDetails.Clear();

        try
        {
            var result = await NhapKhoService.GetDetailsAsync(nhapKhoId);
            if (!result.Success || result.Data is null)
            {
                pageMessage = result.Message;
                pageMessageIsError = true;
                return;
            }

            selectedDetails.AddRange(result.Data);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load NhapKho details failed. Nhap_Kho_ID={Nhap_Kho_ID}", nhapKhoId);
            pageMessage = "Không thể tải chi tiết phiếu nhập kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isDetailLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (!HasRequiredLookupData)
        {
            formMessage = "Cần có dữ liệu Kho, Nhà cung cấp và Sản phẩm trước khi lưu.";
            formMessageIsError = true;
            return;
        }

        if (!TryParseNgayNhapKho(out var parsedNgayNhapKho))
        {
            formMessage = "Ngày nhập kho phải đúng định dạng dd/MM/yyyy.";
            formMessageIsError = true;
            return;
        }

        if (!BusinessValidationRules.IsValidVoucherDate(parsedNgayNhapKho))
        {
            formMessage = $"Ngày nhập kho phải trong khoảng {BusinessValidationRules.MinVoucherDate:dd/MM/yyyy} đến {BusinessValidationRules.MaxVoucherDate:dd/MM/yyyy}.";
            formMessageIsError = true;
            return;
        }

        if (!isEditMode && !TryApplyLineNumericValues(out var lineValidationMessage))
        {
            formMessage = lineValidationMessage;
            formMessageIsError = true;
            return;
        }

        formModel.Ngay_Nhap_Kho = parsedNgayNhapKho;

        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            ServiceResult result;
            if (isEditMode)
            {
                formModel.Nhap_Kho_ID = editingNhapKhoId ?? formModel.Nhap_Kho_ID;
                result = await NhapKhoService.UpdateHeaderAsync(formModel);
            }
            else
            {
                result = await NhapKhoService.CreateAsync(formModel);
            }

            formMessage = result.Message;
            formMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Save NhapKho failed. IsEditMode={IsEditMode}, Nhap_Kho_ID={Nhap_Kho_ID}, So_Phieu_Nhap_Kho={So_Phieu_Nhap_Kho}",
                isEditMode,
                formModel.Nhap_Kho_ID,
                formModel.So_Phieu_Nhap_Kho);
            formMessage = "Không thể lưu phiếu nhập do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string soPhieuNhapKho)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa phiếu nhập '{soPhieuNhapKho}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await NhapKhoService.DeleteAsync(id);
        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (selectedNhapKhoId == id)
        {
            selectedNhapKhoId = null;
            selectedSoPhieu = null;
            selectedDetails.Clear();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

