    private async Task ImportExcelAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            pageMessage = "Chỉ hỗ trợ file Excel định dạng .xlsx.";
            pageMessageIsError = true;
            return;
        }

        var selectedKhoId = AppSelectionContext.SelectedKhoId;
        if (!selectedKhoId.HasValue || selectedKhoId.Value <= 0)
        {
            pageMessage = "Vui lòng chọn kho trên header trước khi nhập file phiếu nhập.";
            pageMessageIsError = true;
            return;
        }

        isImporting = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            await using var stream = file.OpenReadStream(15 * 1024 * 1024);
            var readResult = await ExcelWorkbookHelper.ReadRowsWithContextAsync(stream);
            var rows = readResult.Rows;
            if (rows.Count == 0)
            {
                pageMessage = "File Excel không có dữ liệu để nhập.";
                pageMessageIsError = true;
                return;
            }

            var nccLookup = BuildNhaCungCapLookup();
            var sanPhamLookup = BuildSanPhamLookup();

            var existingSoPhieuSet = items
                .Select(x => x.So_Phieu_Nhap_Kho?.Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x!)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            importPreviewFileName = file.Name;
            importPreviewSheetName = string.IsNullOrWhiteSpace(readResult.SheetName) ? "Sheet1" : readResult.SheetName;
            importSourceRows = rows.ToList();
            importPreviewRows = BuildImportPreviewRows(rows, nccLookup, sanPhamLookup, existingSoPhieuSet);
            showImportPreview = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import NhapKho from Excel failed.");
            pageMessage = $"Không thể nhập file Excel phiếu nhập: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isImporting = false;
            importFileInputVersion++;
        }
    }

    private async Task ApplyImportAsync()
    {
        var selectedKhoId = AppSelectionContext.SelectedKhoId;
        if (!selectedKhoId.HasValue || selectedKhoId.Value <= 0)
        {
            pageMessage = "Vui lòng chọn kho trên header trước khi nhập file phiếu nhập.";
            pageMessageIsError = true;
            return;
        }

        var groups = importPreviewRows
            .Select(x => new
            {
                Preview = x,
                Row = x.SourceIndex >= 0 && x.SourceIndex < importSourceRows.Count ? importSourceRows[x.SourceIndex] : null
            })
            .Where(x => x.Row is not null)
            .Select(x => new
            {
                x.Preview,
                Row = x.Row!,
                SoPhieu = GetImportCellValue(x.Row!, ImportHeaderSoPhieuNhap, "Số phiếu", "Số phiếu nhập kho").Trim()
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.SoPhieu))
            .GroupBy(x => x.SoPhieu, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (groups.Count == 0)
        {
            pageMessage = "Không đọc được cột 'Số phiếu nhập' hoặc dữ liệu số phiếu đang trống.";
            pageMessageIsError = true;
            return;
        }

        isApplyingImport = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            var nccLookup = BuildNhaCungCapLookup();
            var sanPhamLookup = BuildSanPhamLookup();

            var successCount = 0;
            var skippedDuplicates = new List<string>();
            var errors = new List<string>();

            foreach (var group in groups)
            {
                if (group.Any(x => x.Preview.Status == ExcelImportPreviewStatus.Error))
                {
                    errors.Add($"Phiếu {group.Key}: Có dòng dữ liệu không hợp lệ trong phần xem trước.");
                    continue;
                }

                var first = group.First().Row;
                var ngayNhapText = GetImportCellValue(first, ImportHeaderNgayNhapKho, "Ngày nhập").Trim();
                if (!TryParseNgayNhapKhoFromExcel(ngayNhapText, out var ngayNhap))
                {
                    errors.Add($"Phiếu {group.Key}: Ngày nhập kho không hợp lệ (dòng {first.RowNumber}).");
                    continue;
                }

                var nhaCungCapText = GetImportCellValue(first, ImportHeaderNhaCungCap, "Mã nhà cung cấp", "Mã NCC").Trim();
                if (!nccLookup.TryGetValue(nhaCungCapText, out var ncc))
                {
                    errors.Add($"Phiếu {group.Key}: Không tìm thấy nhà cung cấp '{nhaCungCapText}'.");
                    continue;
                }

                var donViTien = DonViTienOptions.Normalize(GetImportCellValue(first, ImportHeaderDonViTien).Trim());
                if (string.IsNullOrWhiteSpace(donViTien))
                {
                    donViTien = DonViTienOptions.Vnd;
                }

                var chiTiets = new List<NhapKhoRawDataUpsertVm>();
                var hasLineError = false;

                foreach (var item in group.Where(x => x.Preview.CanImport))
                {
                    var sanPhamText = GetImportCellValue(item.Row, ImportHeaderSanPham, "Mã sản phẩm", "Mã SP").Trim();
                    if (!sanPhamLookup.TryGetValue(sanPhamText, out var sanPham))
                    {
                        errors.Add($"Phiếu {group.Key}: Không tìm thấy sản phẩm '{sanPhamText}' (dòng {item.Row.RowNumber}).");
                        hasLineError = true;
                        continue;
                    }

                    if (!TryParsePositiveWholeNumber(GetImportCellValue(item.Row, ImportHeaderSoLuongNhap, "SL nhập"), out var soLuong))
                    {
                        errors.Add($"Phiếu {group.Key}: Số lượng nhập không hợp lệ (dòng {item.Row.RowNumber}).");
                        hasLineError = true;
                        continue;
                    }

                    if (!TryParsePositiveDecimal(GetImportCellValue(item.Row, ImportHeaderDonGiaNhap, "Đơn giá"), donViTien, out var donGia))
                    {
                        errors.Add($"Phiếu {group.Key}: Đơn giá nhập không hợp lệ (dòng {item.Row.RowNumber}).");
                        hasLineError = true;
                        continue;
                    }

                    chiTiets.Add(new NhapKhoRawDataUpsertVm
                    {
                        San_Pham_ID = sanPham.San_Pham_ID,
                        SL_Nhap = soLuong,
                        SL_Nhap_Text = FormatQuantityForInput(soLuong),
                        Don_Gia_Nhap = donGia,
                        Don_Gia_Nhap_Text = FormatAmountInput(donGia, donViTien)
                    });
                }

                if (hasLineError || chiTiets.Count == 0)
                {
                    continue;
                }

                var result = await NhapKhoService.CreateAsync(new NhapKhoCreateVm
                {
                    So_Phieu_Nhap_Kho = group.Key,
                    Kho_ID = selectedKhoId.Value,
                    NCC_ID = ncc.NCC_ID,
                    Ngay_Nhap_Kho = ngayNhap,
                    Don_Vi_Tien = donViTien,
                    Ghi_Chu = GetImportCellValue(first, ImportHeaderGhiChu).Trim(),
                    Chi_Tiets = chiTiets
                });

                if (result.Success)
                {
                    successCount++;
                }
                else if (IsDuplicateImportMessage(result.Message))
                {
                    skippedDuplicates.Add($"Phiếu {group.Key}: {result.Message}");
                }
                else
                {
                    errors.Add($"Phiếu {group.Key}: {result.Message}");
                }
            }

            await LoadDataAsync();
            pageMessage = BuildImportSummary(successCount, skippedDuplicates, errors);
            pageMessageIsError = errors.Count > 0;
            CloseImportPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Apply NhapKho import failed.");
            pageMessage = $"Không thể nhập dữ liệu từ file Excel: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isApplyingImport = false;
        }
    }

    private void CloseImportPreview()
    {
        showImportPreview = false;
        importPreviewFileName = string.Empty;
        importPreviewSheetName = string.Empty;
        importPreviewRows = [];
        importSourceRows = [];
    }

    private List<ExcelImportPreviewRow> BuildImportPreviewRows(
        IReadOnlyList<ExcelImportRow> rows,
        IReadOnlyDictionary<string, NhaCungCapListItemVm> nccLookup,
        IReadOnlyDictionary<string, SanPhamListItemVm> sanPhamLookup,
        ISet<string> existingSoPhieuSet)
    {
        var previewRows = new List<ExcelImportPreviewRow>(rows.Count);

        for (var index = 0; index < rows.Count; index++)
        {
            var row = rows[index];
            var soPhieu = GetImportCellValue(row, ImportHeaderSoPhieuNhap, "Số phiếu", "Số phiếu nhập kho").Trim();
            var ngayNhap = GetImportCellValue(row, ImportHeaderNgayNhapKho, "Ngày nhập").Trim();
            var nhaCungCapText = GetImportCellValue(row, ImportHeaderNhaCungCap, "Mã nhà cung cấp", "Mã NCC").Trim();
            var sanPhamText = GetImportCellValue(row, ImportHeaderSanPham, "Mã sản phẩm", "Mã SP").Trim();
            var slNhap = GetImportCellValue(row, ImportHeaderSoLuongNhap, "SL nhập").Trim();
            var donGiaNhap = GetImportCellValue(row, ImportHeaderDonGiaNhap, "Đơn giá").Trim();
            var donViTien = DonViTienOptions.Normalize(GetImportCellValue(row, ImportHeaderDonViTien).Trim());
            if (string.IsNullOrWhiteSpace(donViTien))
            {
                donViTien = DonViTienOptions.Vnd;
            }

            var ghiChu = GetImportCellValue(row, ImportHeaderGhiChu).Trim();
            var status = ExcelImportPreviewStatus.Valid;
            var message = string.Empty;

            if (string.IsNullOrWhiteSpace(soPhieu))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Thiếu số phiếu nhập.";
            }
            else if (!TryParseNgayNhapKhoFromExcel(ngayNhap, out _))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Ngày nhập kho không hợp lệ.";
            }
            else if (!nccLookup.ContainsKey(nhaCungCapText))
            {
                status = ExcelImportPreviewStatus.Error;
                message = $"Không tìm thấy nhà cung cấp '{nhaCungCapText}'.";
            }
            else if (!sanPhamLookup.ContainsKey(sanPhamText))
            {
                status = ExcelImportPreviewStatus.Error;
                message = $"Không tìm thấy sản phẩm '{sanPhamText}'.";
            }
            else if (!TryParsePositiveWholeNumber(slNhap, out _))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Số lượng nhập không hợp lệ.";
            }
            else if (!TryParsePositiveDecimal(donGiaNhap, donViTien, out _))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Đơn giá nhập không hợp lệ.";
            }
            else if (existingSoPhieuSet.Contains(soPhieu))
            {
                status = ExcelImportPreviewStatus.Warning;
                message = $"Số phiếu '{soPhieu}' đã tồn tại.";
            }

            previewRows.Add(new ExcelImportPreviewRow(
                DisplayIndex: index + 1,
                SourceIndex: index,
                ExcelRowNumber: row.RowNumber,
                Cells: [soPhieu, ngayNhap, nhaCungCapText, sanPhamText, slNhap, donGiaNhap, donViTien, ghiChu],
                Status: status,
                Message: message));
        }

        return previewRows;
    }

    private IReadOnlyDictionary<string, NhaCungCapListItemVm> BuildNhaCungCapLookup()
    {
        var lookup = new Dictionary<string, NhaCungCapListItemVm>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in nhaCungCapOptions)
        {
            AddLookupEntry(lookup, item.Ma_NCC, item);
            AddLookupEntry(lookup, item.Ten_NCC, item);
        }

        return lookup;
    }

    private IReadOnlyDictionary<string, SanPhamListItemVm> BuildSanPhamLookup()
    {
        var lookup = new Dictionary<string, SanPhamListItemVm>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in sanPhamOptions)
        {
            AddLookupEntry(lookup, item.Ma_San_Pham, item);
            AddLookupEntry(lookup, item.Ten_San_Pham, item);
        }

        return lookup;
    }

    private static void AddLookupEntry<TValue>(
        IDictionary<string, TValue> lookup,
        string? key,
        TValue value)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        var normalized = key.Trim();
        if (!lookup.ContainsKey(normalized))
        {
            lookup[normalized] = value;
        }
    }

    private static string GetImportCellValue(ExcelImportRow row, params string[] headers)
    {
        foreach (var header in headers)
        {
            var value = row.Get(header);
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return headers.Length > 0 ? row.Get(headers[0]) : string.Empty;
    }

    private static bool TryParseNgayNhapKhoFromExcel(string? value, out DateTime parsedDate)
    {
        parsedDate = default;
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var text = value.Trim();
        return DateTime.TryParseExact(
                   text,
                   ["dd/MM/yyyy", "d/M/yyyy", "yyyy-MM-dd"],
                   CultureInfo.InvariantCulture,
                   DateTimeStyles.None,
                   out parsedDate)
               || DateTime.TryParse(text, CultureInfo.GetCultureInfo("vi-VN"), DateTimeStyles.None, out parsedDate)
               || DateTime.TryParse(text, CultureInfo.InvariantCulture, DateTimeStyles.None, out parsedDate);
    }

    private async Task DownloadExcelAsync(string fileName, byte[] bytes)
    {
        await JS.InvokeVoidAsync(
            "blazorFileDownload.downloadFileFromBase64",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(bytes));
    }

    private static bool IsDuplicateImportMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
               || message.Contains("bị trùng", StringComparison.OrdinalIgnoreCase)
               || message.Contains("đã được", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildImportSummary(
        int successCount,
        IReadOnlyList<string> skippedDuplicates,
        IReadOnlyList<string> errors)
    {
        if (errors.Count == 0 && skippedDuplicates.Count == 0)
        {
            return $"Nhập Excel thành công {successCount} phiếu.";
        }

        if (errors.Count == 0 && skippedDuplicates.Count > 0)
        {
            var skippedText = string.Join(" | ", skippedDuplicates.Take(3));
            if (skippedDuplicates.Count > 3)
            {
                skippedText += $" | ... thêm {skippedDuplicates.Count - 3} phiếu trùng.";
            }

            return $"Đã nhập {successCount} phiếu. Bỏ qua {skippedDuplicates.Count} phiếu trùng: {skippedText}";
        }

        var firstErrors = string.Join(" | ", errors.Take(3));
        if (errors.Count > 3)
        {
            firstErrors += $" | ... thêm {errors.Count - 3} lỗi.";
        }

        var summary = $"Đã nhập {successCount} phiếu. Có {errors.Count} lỗi: {firstErrors}";
        if (skippedDuplicates.Count > 0)
        {
            summary += $" | Bỏ qua {skippedDuplicates.Count} phiếu trùng.";
        }

        return summary;
    }

    private static bool TryParseNgayNhapKhoText(string value, out DateTime parsedDate)
    {
        return DateTime.TryParseExact(
            value,
            "dd/MM/yyyy",
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out parsedDate);
    }

    private bool TryParseNgayNhapKho(out DateTime parsedDate)
    {
        if (string.IsNullOrWhiteSpace(ngayNhapKhoText))
        {
            parsedDate = default;
            return false;
        }

        return TryParseNgayNhapKhoText(ngayNhapKhoText.Trim(), out parsedDate);
    }

    private bool TryApplyLineNumericValues(out string message)
    {
        if (formModel.Chi_Tiets.Count == 0)
        {
            message = "Phiếu nhập phải có ít nhất 1 dòng chi tiết.";
            return false;
        }

        for (var i = 0; i < formModel.Chi_Tiets.Count; i++)
        {
            var lineNo = i + 1;
            var line = formModel.Chi_Tiets[i];

            if (!TryParsePositiveWholeNumber(line.SL_Nhap_Text, out var soLuong))
            {
                message = $"Dòng {lineNo}: Số lượng nhập phải là số nguyên lớn hơn 0.";
                return false;
            }

            if (soLuong > BusinessValidationRules.MaxQuantity)
            {
                message = $"Dòng {lineNo}: Số lượng nhập vượt quá giới hạn cho phép của hệ thống.";
                return false;
            }

            if (!TryParsePositiveDecimal(line.Don_Gia_Nhap_Text, formModel.Don_Vi_Tien, out var donGia))
            {
                message = $"Dòng {lineNo}: Đơn giá nhập phải là số lớn hơn 0.";
                return false;
            }

            if (donGia > BusinessValidationRules.MaxAmount)
            {
                message = $"Dòng {lineNo}: Đơn giá nhập vượt quá giới hạn cho phép của hệ thống.";
                return false;
            }

            if (!BusinessValidationRules.HasValidAmountScale(donGia, formModel.Don_Vi_Tien))
            {
                message = $"Dòng {lineNo}: {BuildAmountScaleMessage("Đơn giá nhập", formModel.Don_Vi_Tien)}";
                return false;
            }

            line.SL_Nhap = soLuong;
            line.Don_Gia_Nhap = DonViTienOptions.RoundAmount(donGia, formModel.Don_Vi_Tien);
        }

        message = string.Empty;
        return true;
    }

    private static bool TryParsePositiveWholeNumber(string? text, out decimal parsedValue)
    {
        parsedValue = 0m;
        if (!TryParseDecimalFlexible(text, preferSingleSeparatorAsDecimal: false, out var numericValue))
        {
            return false;
        }

        if (numericValue <= 0 || numericValue != decimal.Truncate(numericValue))
        {
            return false;
        }

        parsedValue = numericValue;
        return true;
    }

    private static bool TryParsePositiveDecimal(string? text, string? donViTien, out decimal parsedValue)
    {
        var preferSingleSeparatorAsDecimal = DonViTienOptions.UsesDecimalAmount(donViTien);
        if (!TryParseDecimalFlexible(text, preferSingleSeparatorAsDecimal, out parsedValue))
        {
            return false;
        }

        return parsedValue > 0;
    }

    private static bool TryParseDecimalFlexible(
        string? text,
        bool preferSingleSeparatorAsDecimal,
        out decimal parsedValue)
    {
        parsedValue = 0m;
        if (string.IsNullOrWhiteSpace(text))
        {
            return false;
        }

        var raw = text.Trim().Replace(" ", string.Empty, StringComparison.Ordinal);
        if (raw.StartsWith('+'))
        {
            raw = raw[1..];
        }

        if (raw.Length == 0 || raw.Any(ch => !char.IsDigit(ch) && ch is not ',' and not '.'))
        {
            return false;
        }

        string normalized;
        if (raw.Contains(',') && raw.Contains('.'))
        {
            normalized = NormalizeMixedSeparators(raw);
        }
        else if (raw.Contains(','))
        {
            normalized = NormalizeSingleSeparator(raw, ',', preferSingleSeparatorAsDecimal);
        }
        else if (raw.Contains('.'))
        {
            normalized = NormalizeSingleSeparator(raw, '.', preferSingleSeparatorAsDecimal);
        }
        else
        {
            normalized = raw;
        }

        return decimal.TryParse(
            normalized,
            NumberStyles.AllowDecimalPoint,
            CultureInfo.InvariantCulture,
            out parsedValue);
    }

    private static string NormalizeMixedSeparators(string raw)
    {
        var lastComma = raw.LastIndexOf(',');
        var lastDot = raw.LastIndexOf('.');
        var decimalSeparator = lastComma > lastDot ? ',' : '.';
        var thousandsSeparator = decimalSeparator == ',' ? '.' : ',';

        var withoutThousands = raw.Replace(thousandsSeparator.ToString(), string.Empty, StringComparison.Ordinal);
        var lastDecimalIndex = withoutThousands.LastIndexOf(decimalSeparator);
        if (lastDecimalIndex < 0)
        {
            return withoutThousands.Replace(decimalSeparator.ToString(), string.Empty, StringComparison.Ordinal);
        }

        var integerPart = withoutThousands[..lastDecimalIndex]
            .Replace(decimalSeparator.ToString(), string.Empty, StringComparison.Ordinal);
        var fractionPart = withoutThousands[(lastDecimalIndex + 1)..]
            .Replace(decimalSeparator.ToString(), string.Empty, StringComparison.Ordinal);

        return fractionPart.Length == 0
            ? integerPart
            : $"{integerPart}.{fractionPart}";
    }

    private static string NormalizeSingleSeparator(string raw, char separator, bool preferSingleSeparatorAsDecimal)
    {
        var parts = raw.Split(separator, StringSplitOptions.None);
        if (parts.Length == 1)
        {
            return raw;
        }

        if (parts.Any(part => part.Length == 0))
        {
            return raw;
        }

        if (parts.Length == 2)
        {
            if (preferSingleSeparatorAsDecimal)
            {
                return $"{parts[0]}.{parts[1]}";
            }

            return parts[1].Length == 3
                ? string.Concat(parts[0], parts[1])
                : $"{parts[0]}.{parts[1]}";
        }

        var integerPart = string.Concat(parts[..^1]);
        var fractionPart = parts[^1];

        return fractionPart.Length == 3
            ? string.Concat(integerPart, fractionPart)
            : $"{integerPart}.{fractionPart}";
    }

    private NhapKhoDetailEditorLineVm ToDetailEditorLine(NhapKhoDetailListItemVm source)
    {
        return new NhapKhoDetailEditorLineVm
        {
            Nhap_Kho_Raw_Data_ID = source.Nhap_Kho_Raw_Data_ID,
            San_Pham_ID = source.San_Pham_ID,
            Ma_San_Pham = source.Ma_San_Pham,
            Ten_San_Pham = source.Ten_San_Pham,
            SL_Nhap = source.SL_Nhap,
            Don_Gia_Nhap = source.Don_Gia_Nhap,
            SL_Nhap_Text = FormatQuantityForInput(source.SL_Nhap),
            Don_Gia_Nhap_Text = FormatAmountInput(source.Don_Gia_Nhap, CurrentDetailEditorDonViTien),
            IsEditing = false,
            IsNew = false
        };
    }

    private bool TryParseDetailEditorLine(
        NhapKhoDetailEditorLineVm line,
        string donViTien,
        out decimal soLuong,
        out decimal donGia,
        out string message)
    {
        if (!TryParsePositiveWholeNumber(line.SL_Nhap_Text, out soLuong))
        {
            message = "Số lượng nhập phải là số nguyên lớn hơn 0.";
            donGia = 0m;
            return false;
        }

        if (soLuong > BusinessValidationRules.MaxQuantity)
        {
            message = "Số lượng nhập vượt quá giới hạn cho phép của hệ thống.";
            donGia = 0m;
            return false;
        }

        if (!TryParsePositiveDecimal(line.Don_Gia_Nhap_Text, donViTien, out donGia))
        {
            message = "Đơn giá nhập phải là số lớn hơn 0.";
            return false;
        }

        if (donGia > BusinessValidationRules.MaxAmount)
        {
            message = "Đơn giá nhập vượt quá giới hạn cho phép của hệ thống.";
            return false;
        }

        if (!BusinessValidationRules.HasValidAmountScale(donGia, donViTien))
        {
            message = BuildAmountScaleMessage("Đơn giá nhập", donViTien);
            return false;
        }

        donGia = DonViTienOptions.RoundAmount(donGia, donViTien);
        message = string.Empty;
        return true;
    }

    private decimal GetDetailLineTriGia(NhapKhoDetailEditorLineVm line)
    {
        if (line.IsEditing)
        {
            var soLuong = TryParsePositiveWholeNumber(line.SL_Nhap_Text, out var parsedSoLuong) ? parsedSoLuong : 0m;
            var donGia = TryParsePositiveDecimal(line.Don_Gia_Nhap_Text, CurrentDetailEditorDonViTien, out var parsedDonGia)
                ? DonViTienOptions.RoundAmount(parsedDonGia, CurrentDetailEditorDonViTien)
                : 0m;
            if (!BusinessValidationRules.HasValidAmountScale(donGia, CurrentDetailEditorDonViTien))
            {
                return 0m;
            }

            return soLuong * donGia;
        }

        return line.SL_Nhap * line.Don_Gia_Nhap;
    }

    private static decimal GetDetailLineSoLuong(NhapKhoDetailEditorLineVm line)
    {
        return TryParsePositiveWholeNumber(line.SL_Nhap_Text, out var value) ? value : 0m;
    }

    private decimal GetDetailLineDonGia(NhapKhoDetailEditorLineVm line)
    {
        if (!TryParsePositiveDecimal(line.Don_Gia_Nhap_Text, CurrentDetailEditorDonViTien, out var value))
        {
            return 0m;
        }

        return BusinessValidationRules.HasValidAmountScale(value, CurrentDetailEditorDonViTien) ? value : 0m;
    }

    private static decimal GetLineSoLuong(NhapKhoRawDataUpsertVm line)
    {
        return TryParsePositiveWholeNumber(line.SL_Nhap_Text, out var value) ? value : 0m;
    }

    private decimal GetLineDonGia(NhapKhoRawDataUpsertVm line)
    {
        if (!TryParsePositiveDecimal(line.Don_Gia_Nhap_Text, formModel.Don_Vi_Tien, out var value))
        {
            return 0m;
        }

        return BusinessValidationRules.HasValidAmountScale(value, formModel.Don_Vi_Tien) ? value : 0m;
    }

    private decimal GetLineTriGia(NhapKhoRawDataUpsertVm line)
    {
        var soLuong = GetLineSoLuong(line);
        var donGia = DonViTienOptions.RoundAmount(GetLineDonGia(line), formModel.Don_Vi_Tien);
