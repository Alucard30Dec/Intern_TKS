@page "/nhap-kho"
@rendermode InteractiveServer
@implements IDisposable
@using System.Globalization
@using BlazorApp1.Infrastructure.Excel
@using BlazorApp1.Models.Kho
@using BlazorApp1.Models.Common
@using BlazorApp1.Models.NhaCungCap
@using BlazorApp1.Models.NhapKho
@using BlazorApp1.Models.SanPham
@using BlazorApp1.Services.Interfaces
@inject INhapKhoService NhapKhoService
@inject INhaCungCapService NhaCungCapService
@inject ISanPhamService SanPhamService
@inject IAppSelectionContextService AppSelectionContext
@inject IJSRuntime JS
@inject ILogger<NhapKhoPage> Logger

<PageTitle>Quản lý phiếu nhập kho</PageTitle>

<section class="import-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Quản lý phiếu nhập kho</h1>
        <div class="page-header__actions">
            <button type="button" class="app-button" style="display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;" @onclick="ExportTemplateAsync" disabled="@(isSaving || isImporting || isApplyingImport)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                <span>Xuất file mẫu</span>
            </button>
            <label class="app-button" style="position:relative;overflow:hidden;display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;@(isSaving || isImporting || isApplyingImport ? "pointer-events:none;opacity:0.65;cursor:wait;" : "cursor:pointer;")">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21V9" />
                    <path d="m17 14-5-5-5 5" />
                    <path d="M5 3h14" />
                </svg>
                <span>Nhập file excel</span>
                <InputFile style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;"
                           @key="importFileInputVersion"
                           OnChange="ImportExcelAsync"
                           accept=".xlsx"
                           disabled="@(isSaving || isImporting || isApplyingImport)" />
            </label>
            <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@(isSaving || isImporting || isApplyingImport)">
                Thêm phiếu nhập
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <ExcelImportPreviewDialog Visible="@showImportPreview"
                              FileName="@importPreviewFileName"
                              SheetName="@importPreviewSheetName"
                              ColumnHeaders="@ImportPreviewHeaders"
                              Rows="@importPreviewRows"
                              IsApplying="@isApplyingImport"
                              OnClose="CloseImportPreview"
                              OnConfirm="ApplyImportAsync" />

    <div class="import-layout import-layout--single">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách phiếu nhập (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Số phiếu, kho, nhà cung cấp" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Số phiếu</th>
                                    <th>Ngày nhập</th>
                                    <th>Kho</th>
                                    <th>NCC</th>
                                    <th class="data-table__number">Số dòng</th>
                                    <th class="data-table__number">Tổng trị giá</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(selectedNhapKhoId == item.Nhap_Kho_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        title="Bấm để mở phiếu nhập và chỉnh sửa"
                                        @onclick="() => StartEditAsync(item)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.So_Phieu_Nhap_Kho</td>
                                        <td>@item.Ngay_Nhap_Kho.ToString("dd/MM/yyyy")</td>
                                        <td class="data-table__name">@item.Ten_Kho</td>
                                        <td>@item.Ten_NCC</td>
                                        <td class="data-table__number">@item.So_Dong_Chi_Tiet</td>
                                        <td class="data-table__number">@FormatAmountWithCurrency(item.Tong_Tri_Gia, item.Don_Vi_Tien)</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => OpenPrintFormAsync(item.Nhap_Kho_ID)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    In
                                                </button>
                                                <button class="app-button app-button--ghost"
                                                        @onclick="() => StartDetailEditorAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Chi tiết
                                                </button>
                                                <button class="app-button app-button--secondary"
                                                        @onclick="() => StartEditAsync(item)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Sửa
                                                </button>
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Nhap_Kho_ID, item.So_Phieu_Nhap_Kho)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (selectedNhapKhoId.HasValue)
                {
                    <section class="detail-panel">
                        <header class="detail-panel__header">
                            <h3>Chi tiết phiếu nhập: @selectedSoPhieu</h3>
                            <span class="card__tag">Đơn vị tiền: @SelectedDonViTien</span>
                        </header>

                        @if (isDetailLoading)
                        {
                            <div class="state-box">Đang tải chi tiết...</div>
                        }
                        else if (selectedDetails.Count == 0)
                        {
                            <div class="state-box state-box--empty">Phiếu nhập chưa có dòng chi tiết.</div>
                        }
                        else
                        {
                            <div class="table-wrap">
                                <table class="detail-table">
                                    <thead>
                                        <tr>
                                            <th>STT</th>
                                            <th>Mã SP</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="detail-table__number">SL nhập</th>
                                            <th class="detail-table__number">Đơn giá</th>
                                            <th class="detail-table__number">Trị giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < selectedDetails.Count; i++)
                                        {
                                            var detail = selectedDetails[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@detail.Ma_San_Pham</td>
                                                <td>@detail.Ten_San_Pham</td>
                                                <td class="detail-table__number">@FormatQuantity(detail.SL_Nhap)</td>
                                                <td class="detail-table__number">@FormatAmount(detail.Don_Gia_Nhap, SelectedDonViTien)</td>
                                                <td class="detail-table__number">@FormatAmountWithCurrency(detail.Tri_Gia, SelectedDonViTien)</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="detail-table__number">@FormatAmountWithCurrency(selectedDetails.Sum(x => x.Tri_Gia), SelectedDonViTien)</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    </section>
                }
            </div>
        </section>
    </div>

    @if (IsFormVisible)
    {
        <div class="modal-overlay" @onclick="HandleModalBackdropClick">
            <section class="card card--form modal-card" @onclick:stopPropagation="true">
                <header class="card__header card__header--form">
                    <h2>@(isEditMode ? "Sửa phiếu nhập kho" : "Tạo phiếu nhập kho")</h2>
                    <div class="modal-header-actions">
                        <span class="card__tag">@(isEditMode ? "Chế độ chỉnh sửa" : "Chỉ thêm mới")</span>
                        <button type="button"
                                class="app-button app-button--ghost app-button--icon"
                                title="Đóng"
                                @onclick="CancelForm"
                                disabled="@isSaving">
                            ×
                        </button>
                    </div>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="NhapKhoForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-grid">
                                <div class="form-field form-field--code">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Số phiếu nhập <span class="required-mark">*</span></label>
                                        <span class="form-field__count">@((formModel.So_Phieu_Nhap_Kho?.Length ?? 0))/50</span>
                                    </div>
                                    <InputText class="form-field__input"
                                               @bind-Value="formModel.So_Phieu_Nhap_Kho"
                                               @oninput="HandleSoPhieuInput"
                                               maxlength="50"
                                               placeholder="Nhập số phiếu nhập kho" />
                                    <p class="form-field__hint">Không được để trống và phải duy nhất.</p>
                                    <ValidationMessage For="@(() => formModel.So_Phieu_Nhap_Kho)" />
                                </div>

                                <div class="form-field form-field--lookup">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Kho <span class="required-mark">*</span></label>
                                    </div>
                                    <InputSelect class="form-field__input" @bind-Value="formModel.Kho_ID">
                                        <option value="0">-- Chọn kho --</option>
                                        @foreach (var option in khoOptions)
                                        {
                                            <option value="@option.Kho_ID">@option.Ten_Kho</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => formModel.Kho_ID)" />
                                </div>

                                <div class="form-field form-field--lookup">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Nhà cung cấp <span class="required-mark">*</span></label>
                                    </div>
                                    <InputSelect class="form-field__input" @bind-Value="formModel.NCC_ID">
                                        <option value="0">-- Chọn nhà cung cấp --</option>
                                        @foreach (var option in nhaCungCapOptions)
                                        {
                                            <option value="@option.NCC_ID">@option.Ten_NCC (@option.Ma_NCC)</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => formModel.NCC_ID)" />
                                </div>

                                <div class="form-field form-field--date">
                                    <div class="form-field__head">
                                        <label class="form-field__label">Ngày nhập kho <span class="required-mark">*</span></label>
                                    </div>
                                    <InputText class="form-field__input"
                                               @bind-Value="ngayNhapKhoText"
                                               @oninput="HandleNgayNhapKhoInput"
                                               maxlength="10"
                                               placeholder="dd/MM/yyyy" />
                                    <p class="form-field__hint">Định dạng bắt buộc: dd/MM/yyyy.</p>
                                    <ValidationMessage For="@(() => formModel.Ngay_Nhap_Kho)" />
                                </div>
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhiChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <section class="line-section">
                                <header class="line-section__header">
                                    <h3>Chi tiết nhập kho</h3>
                                    @if (!isEditMode)
                                    {
                                        <div class="line-section__tools">
                                            <label class="currency-picker">
                                                <span class="currency-picker__label">Đơn vị tiền</span>
                                                <select class="currency-picker__input"
                                                        value="@formModel.Don_Vi_Tien"
                                                        @onchange="HandleFormDonViTienChanged"
                                                        disabled="@isSaving">
                                                    @foreach (var currency in SupportedCurrencies)
                                                    {
                                                        <option value="@currency">@currency</option>
                                                    }
                                                </select>
                                            </label>
                                            <button type="button" class="app-button app-button--secondary" @onclick="AddDetailRow" disabled="@isSaving">
                                                Thêm dòng
                                            </button>
                                        </div>
                                    }
                                </header>

                                <div class="table-wrap">
                                    <table class="line-table">
                                        <thead>
                                            <tr>
                                                <th class="line-table__index">STT</th>
                                                <th>Sản phẩm <span class="required-mark">*</span></th>
                                                <th>Đơn vị tính</th>
                                                <th class="line-table__number">SL nhập <span class="required-mark">*</span></th>
                                                <th class="line-table__number">Đơn giá nhập <span class="required-mark">*</span></th>
                                                <th class="line-table__number">Trị giá</th>
                                                @if (!isEditMode)
                                                {
                                                    <th class="line-table__actions">Thao tác</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < formModel.Chi_Tiets.Count; i++)
                                            {
                                                var index = i;
                                                var line = formModel.Chi_Tiets[index];
                                                <tr>
                                                    <td>@(index + 1)</td>
                                                    <td>
                                                        <InputSelect class="form-field__input"
                                                                     @bind-Value="line.San_Pham_ID"
                                                                     disabled="@isEditMode">
                                                            <option value="0">-- Chọn sản phẩm --</option>
                                                            @foreach (var option in sanPhamOptions)
                                                            {
                                                                <option value="@option.San_Pham_ID">@option.Ten_San_Pham (@option.Ma_San_Pham)</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td class="line-table__unit">
                                                        @GetDonViTinhBySanPhamId(line.San_Pham_ID)
                                                    </td>
                                                    <td>
                                                        @if (isEditMode)
                                                        {
                                                            <span class="line-table__number">@FormatQuantity(GetLineSoLuong(line))</span>
                                                        }
                                                        else
                                                        {
                                                            <div class="quantity-stepper">
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => DecreaseFormLineQuantity(line)"
                                                                        disabled="@isSaving">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input"
                                                                       value="@line.SL_Nhap_Text"
                                                                       @oninput="e => line.SL_Nhap_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => IncreaseFormLineQuantity(line)"
                                                                        disabled="@isSaving">
                                                                    +
                                                                </button>
                                                            </div>
                                                        }
                                                    </td>
                                                    <td>
                                                        <input class="form-field__input line-input--number"
                                                               value="@line.Don_Gia_Nhap_Text"
                                                               @oninput="e => line.Don_Gia_Nhap_Text = e.Value?.ToString() ?? string.Empty"
                                                               @onblur="() => NormalizeFormLineDonGiaText(line)"
                                                               disabled="@isEditMode"
                                                               inputmode="decimal"
                                                               placeholder="Nhập đơn giá" />
                                                    </td>
                                                    <td class="line-table__number">@FormatAmountWithCurrency(GetLineTriGia(line), formModel.Don_Vi_Tien)</td>
                                                    @if (!isEditMode)
                                                    {
                                                        <td>
                                                            <button type="button"
                                                                    class="app-button app-button--danger"
                                                                    @onclick="() => RemoveDetailRow(index)"
                                                                    disabled="@isSaving">
                                                                Xóa dòng
                                                            </button>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="5">Tổng trị giá</td>
                                                <td class="line-table__number">@FormatAmountWithCurrency(formModel.Chi_Tiets.Sum(GetLineTriGia), formModel.Don_Vi_Tien)</td>
                                                @if (!isEditMode)
                                                {
                                                    <td></td>
                                                }
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </section>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@(!HasRequiredLookupData || isSaving)">
                                    @(isSaving ? "Đang lưu..." : isEditMode ? "Lưu cập nhật" : "Lưu phiếu nhập")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        </div>
    }

    @if (isDetailEditorVisible && detailHeaderItem is not null)
    {
        <div class="modal-overlay" @onclick="HandleDetailEditorBackdropClick">
            <section class="card card--form modal-card modal-card--detail" @onclick:stopPropagation="true">
                <header class="card__header card__header--form">
                    <h2>Hiệu chỉnh chi tiết phiếu nhập</h2>
                    <div class="modal-header-actions">
                        <span class="card__tag">Bài 9</span>
                        <button type="button"
                                class="app-button app-button--ghost app-button--icon"
                                title="Đóng"
                                @onclick="CloseDetailEditor"
                                disabled="@isDetailLineSaving">
                            ×
                        </button>
                    </div>
                </header>

                <div class="card__body">
                    @if (isDetailEditorLoading)
                    {
                        <div class="state-box">Đang tải dữ liệu chi tiết phiếu nhập...</div>
                    }
                    else
                    {
                        <section class="header-info">
                            <h3 class="header-info__title">Thông tin phiếu nhập</h3>
                            <div class="header-info__grid">
                                <div class="header-info__item">
                                    <span class="header-info__label">Số phiếu nhập</span>
                                    <span class="header-info__value">@detailHeaderItem.So_Phieu_Nhap_Kho</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Ngày nhập kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ngay_Nhap_Kho.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Kho</span>
                                    <span class="header-info__value">@detailHeaderItem.Ten_Kho</span>
                                </div>
                                <div class="header-info__item">
                                    <span class="header-info__label">Nhà cung cấp</span>
                                    <span class="header-info__value">@detailHeaderItem.Ten_NCC</span>
                                </div>
                                <div class="header-info__item header-info__item--wide">
                                    <span class="header-info__label">Ghi chú</span>
                                    <span class="header-info__value">@(string.IsNullOrWhiteSpace(detailHeaderItem.Ghi_Chu) ? "Trống" : detailHeaderItem.Ghi_Chu)</span>
                                </div>
                            </div>
                        </section>

                        @if (!string.IsNullOrWhiteSpace(detailEditorMessage))
                        {
                            <div class="status-banner @(detailEditorMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                @detailEditorMessage
                            </div>
                        }

                        <section class="line-section">
                            <header class="line-section__header">
                                <h3>Lưới hiệu chỉnh chi tiết</h3>
                                <div class="line-section__tools">
                                    @if (!IsDetailEditorInEditMode)
                                    {
                                        <label class="currency-picker">
                                            <span class="currency-picker__label">Đơn vị tiền</span>
                                            <select class="currency-picker__input"
                                                    value="@CurrentDetailEditorDonViTien"
                                                    @onchange="HandleDetailEditorDonViTienChanged"
                                                    disabled="@isDetailLineSaving">
                                                @foreach (var currency in SupportedCurrencies)
                                                {
                                                    <option value="@currency">@currency</option>
                                                }
                                            </select>
                                        </label>
                                    }
                                    <button type="button"
                                            class="app-button app-button--secondary"
                                            @onclick="AddDetailEditorRow"
                                            disabled="@isDetailLineSaving">
                                        Thêm dòng
                                    </button>
                                </div>
                            </header>

                            <div class="table-wrap">
                                <table class="line-table line-table--editor">
                                    <thead>
                                        <tr>
                                            <th class="line-table__index">STT</th>
                                            <th>Mã sản phẩm</th>
                                            <th>Tên sản phẩm</th>
                                            <th class="line-table__number">Số lượng</th>
                                            <th class="line-table__number">Đơn giá</th>
                                            <th class="line-table__number">Trị giá</th>
                                            <th class="line-table__actions">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (detailEditorLines.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="7">
                                                    <span class="data-table__muted">Phiếu nhập chưa có dòng chi tiết.</span>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @for (var i = 0; i < detailEditorLines.Count; i++)
                                            {
                                                var line = detailEditorLines[i];
                                                <tr class="@(line.IsEditing ? "line-editor__row line-editor__row--editing" : "line-editor__row")">
                                                    <td>@(i + 1)</td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            <InputSelect class="form-field__input"
                                                                         @bind-Value="line.San_Pham_ID">
                                                                <option value="0">-- Chọn sản phẩm --</option>
                                                                @foreach (var option in sanPhamOptions)
                                                                {
                                                                    <option value="@option.San_Pham_ID">@option.Ma_San_Pham</option>
                                                                }
                                                            </InputSelect>
                                                        }
                                                        else
                                                        {
                                                            <span class="data-table__code-value">@line.Ma_San_Pham</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsNew && line.IsEditing)
                                                        {
                                                            @GetSanPhamNameById(line.San_Pham_ID)
                                                        }
                                                        else
                                                        {
                                                            @line.Ten_San_Pham
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <div class="quantity-stepper">
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => DecreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    −
                                                                </button>
                                                                <input class="quantity-stepper__input"
                                                                       value="@line.SL_Nhap_Text"
                                                                       @oninput="e => line.SL_Nhap_Text = KeepDigitsOnly(e.Value?.ToString())"
                                                                       inputmode="numeric"
                                                                       placeholder="0" />
                                                                <button type="button"
                                                                        class="quantity-stepper__button"
                                                                        @onclick="() => IncreaseDetailLineQuantity(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    +
                                                                </button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatQuantity(line.SL_Nhap)</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (line.IsEditing)
                                                        {
                                                            <input class="form-field__input line-input--number"
                                                                   value="@line.Don_Gia_Nhap_Text"
                                                                   @oninput="e => line.Don_Gia_Nhap_Text = e.Value?.ToString() ?? string.Empty"
                                                                   @onblur="() => NormalizeDetailLineDonGiaText(line)"
                                                                   inputmode="decimal"
                                                                   placeholder="Nhập đơn giá" />
                                                        }
                                                        else
                                                        {
                                                            <span class="line-table__number">@FormatAmount(line.Don_Gia_Nhap, CurrentDetailEditorDonViTien)</span>
                                                        }
                                                    </td>
                                                    <td class="line-table__number">@FormatAmountWithCurrency(GetDetailLineTriGia(line), CurrentDetailEditorDonViTien)</td>
                                                    <td>
                                                        <div class="action-group">
                                                            @if (line.IsEditing)
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--success"
                                                                        @onclick="() => SaveDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Lưu
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => CancelEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Hủy
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button"
                                                                        class="app-button app-button--secondary"
                                                                        @onclick="() => StartEditDetailLine(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Sửa
                                                                </button>
                                                                <button type="button"
                                                                        class="app-button app-button--danger"
                                                                        @onclick="() => DeleteDetailLineAsync(line)"
                                                                        disabled="@isDetailLineSaving">
                                                                    Xóa
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="5">Tổng trị giá</td>
                                            <td class="line-table__number">@FormatAmountWithCurrency(detailEditorLines.Sum(GetDetailLineTriGia), CurrentDetailEditorDonViTien)</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </section>
                    }
                </div>
            </section>
        </div>
    }
</section>

@code {
    private readonly List<NhapKhoListItemVm> items = [];
    private readonly List<KhoListItemVm> khoOptions = [];
    private readonly List<NhaCungCapListItemVm> nhaCungCapOptions = [];
    private readonly List<SanPhamListItemVm> sanPhamOptions = [];
    private readonly List<NhapKhoDetailListItemVm> selectedDetails = [];
    private readonly List<NhapKhoDetailEditorLineVm> detailEditorLines = [];
    private NhapKhoCreateVm formModel = new();
    private NhapKhoListItemVm? detailHeaderItem;
    private bool isLoading = true;
    private bool isSaving;
    private bool isImporting;
    private bool isApplyingImport;
    private int importFileInputVersion;
    private bool showImportPreview;
    private string importPreviewFileName = string.Empty;
    private string importPreviewSheetName = string.Empty;
    private List<ExcelImportPreviewRow> importPreviewRows = [];
    private List<ExcelImportRow> importSourceRows = [];
    private bool isDetailLoading;
    private bool isDetailEditorLoading;
    private bool isDetailEditorVisible;
    private bool isDetailLineSaving;
    private bool isCreateFormVisible;
    private bool isEditMode;
    private int? editingNhapKhoId;
    private int? selectedNhapKhoId;
    private string? selectedSoPhieu;
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string? detailEditorMessage;
    private bool detailEditorMessageIsError;
    private string searchKeyword = string.Empty;
    private string ngayNhapKhoText = string.Empty;
    private const string ImportHeaderSoPhieuNhap = "Số phiếu nhập";
    private const string ImportHeaderNgayNhapKho = "Ngày nhập kho";
    private const string ImportHeaderNhaCungCap = "Nhà cung cấp";
    private const string ImportHeaderSanPham = "Sản phẩm";
    private const string ImportHeaderSoLuongNhap = "Số lượng nhập";
    private const string ImportHeaderDonGiaNhap = "Đơn giá nhập";
    private const string ImportHeaderDonViTien = "Đơn vị tiền";
    private const string ImportHeaderGhiChu = "Ghi chú";

    private static readonly IReadOnlyList<string> ImportPreviewHeaders =
    [
        ImportHeaderSoPhieuNhap,
        ImportHeaderNgayNhapKho,
        ImportHeaderNhaCungCap,
        ImportHeaderSanPham,
        ImportHeaderSoLuongNhap,
        ImportHeaderDonGiaNhap,
        ImportHeaderDonViTien,
        ImportHeaderGhiChu
    ];
    private IReadOnlyList<string> SupportedCurrencies => DonViTienOptions.SupportedValues;
    private string CurrentDetailEditorDonViTien => DonViTienOptions.Normalize(detailHeaderItem?.Don_Vi_Tien);
    private string SelectedDonViTien =>
        items.FirstOrDefault(x => x.Nhap_Kho_ID == selectedNhapKhoId)?.Don_Vi_Tien ?? DonViTienOptions.Vnd;
    private bool IsDetailEditorInEditMode => detailEditorLines.Any(x => x.IsEditing);

    private bool IsFormVisible => isCreateFormVisible;
    private bool HasRequiredLookupData => khoOptions.Count > 0 && nhaCungCapOptions.Count > 0 && sanPhamOptions.Count > 0;

    private IReadOnlyList<NhapKhoListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();
            return items
                .Where(x =>
                    ContainsKeyword(x.So_Phieu_Nhap_Kho, keyword)
                    || ContainsKeyword(x.Ten_Kho, keyword)
                    || ContainsKeyword(x.Ten_NCC, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        AppSelectionContext.SelectionChanged += HandleSelectionChanged;
        await AppSelectionContext.EnsureInitializedAsync();
        await LoadDataAsync();
    }

    public void Dispose()
    {
        AppSelectionContext.SelectionChanged -= HandleSelectionChanged;
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var selectedKhoId = AppSelectionContext.SelectedKhoId;
            var getNhapKhoTask = NhapKhoService.GetAllAsync(selectedKhoId);
            var getNhaCungCapTask = NhaCungCapService.GetAllAsync();
            var getSanPhamTask = SanPhamService.GetAllAsync();

            await Task.WhenAll(getNhapKhoTask, getNhaCungCapTask, getSanPhamTask);

            items.Clear();
            items.AddRange(getNhapKhoTask.Result);

            khoOptions.Clear();
            khoOptions.AddRange(AppSelectionContext.KhoOptions);

            nhaCungCapOptions.Clear();
            nhaCungCapOptions.AddRange(getNhaCungCapTask.Result);

            sanPhamOptions.Clear();
            sanPhamOptions.AddRange(getSanPhamTask.Result);

            if (khoOptions.Count == 0)
            {
                pageMessage = "Tài khoản đang chọn chưa được phân quyền kho nào.";
                pageMessageIsError = true;
            }
            else if (!HasRequiredLookupData)
            {
                pageMessage = "Cần có dữ liệu Kho, Nhà cung cấp và Sản phẩm trước khi tạo phiếu nhập.";
                pageMessageIsError = true;
            }

            if (selectedNhapKhoId.HasValue)
            {
                var selectedExists = items.Any(x => x.Nhap_Kho_ID == selectedNhapKhoId.Value);
                if (!selectedExists)
                {
                    selectedNhapKhoId = null;
                    selectedSoPhieu = null;
                    selectedDetails.Clear();
                }
                else
                {
                    await LoadDetailsAsync(selectedNhapKhoId.Value, selectedSoPhieu);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load NhapKho page data failed.");
            pageMessage = "Không thể tải dữ liệu quản lý phiếu nhập kho.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho, Nhà cung cấp và Sản phẩm trước khi tạo phiếu nhập.";
            pageMessageIsError = true;
            return;
        }

        isCreateFormVisible = true;
        isEditMode = false;
        editingNhapKhoId = null;
        ResetFormModel();
    }

    private void CancelForm()
    {
        isCreateFormVisible = false;
        isEditMode = false;
        editingNhapKhoId = null;
        ResetFormModel();
        ClearFormMessage();
    }

    private void HandleModalBackdropClick()
    {
        if (isSaving)
        {
            return;
        }

        CancelForm();
    }

    private void ResetFormModel()
    {
        var defaultKhoId = AppSelectionContext.SelectedKhoId
            ?? khoOptions.FirstOrDefault()?.Kho_ID
            ?? 0;

        formModel = new NhapKhoCreateVm
        {
            Nhap_Kho_ID = 0,
            Kho_ID = defaultKhoId,
            Ngay_Nhap_Kho = DateTime.Today,
            Don_Vi_Tien = DonViTienOptions.Vnd
        };
        ReformatFormLineValues();
        ngayNhapKhoText = formModel.Ngay_Nhap_Kho.ToString("dd/MM/yyyy");
    }

    private void HandleSelectionChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();

            if (IsFormVisible && !isEditMode)
            {
                ApplySelectedKhoToForm();
            }

            StateHasChanged();
        });
    }

    private void ApplySelectedKhoToForm()
    {
        if (!AppSelectionContext.SelectedKhoId.HasValue)
        {
            return;
        }

        formModel.Kho_ID = AppSelectionContext.SelectedKhoId.Value;
    }

    private async Task StartEditAsync(NhapKhoListItemVm item)
    {
        if (isSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Kho, Nhà cung cấp và Sản phẩm trước khi sửa phiếu nhập.";
            pageMessageIsError = true;
            return;
        }

        try
        {
            var detailResult = await NhapKhoService.GetDetailsAsync(item.Nhap_Kho_ID);
            if (!detailResult.Success || detailResult.Data is null)
            {
                pageMessage = detailResult.Message;
                pageMessageIsError = true;
                return;
            }

            var donViTien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
            var detailRows = detailResult.Data
                .Select(x => new NhapKhoRawDataUpsertVm
                {
                    San_Pham_ID = x.San_Pham_ID,
                    SL_Nhap = x.SL_Nhap,
                    Don_Gia_Nhap = x.Don_Gia_Nhap,
                    SL_Nhap_Text = FormatQuantityForInput(x.SL_Nhap),
                    Don_Gia_Nhap_Text = FormatAmountInput(x.Don_Gia_Nhap, donViTien)
                })
                .ToList();

            formModel = new NhapKhoCreateVm
            {
                Nhap_Kho_ID = item.Nhap_Kho_ID,
                So_Phieu_Nhap_Kho = item.So_Phieu_Nhap_Kho,
                Kho_ID = item.Kho_ID,
                NCC_ID = item.NCC_ID,
                Ngay_Nhap_Kho = item.Ngay_Nhap_Kho,
                Don_Vi_Tien = donViTien,
                Ghi_Chu = item.Ghi_Chu,
                Chi_Tiets = detailRows
            };

            ReformatFormLineValues();

            ngayNhapKhoText = formModel.Ngay_Nhap_Kho.ToString("dd/MM/yyyy");
            isEditMode = true;
            editingNhapKhoId = item.Nhap_Kho_ID;
            isCreateFormVisible = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Start edit NhapKho failed. Nhap_Kho_ID={Nhap_Kho_ID}", item.Nhap_Kho_ID);
            pageMessage = "Không thể mở dữ liệu phiếu nhập để chỉnh sửa.";
            pageMessageIsError = true;
        }
    }

    private async Task StartDetailEditorAsync(NhapKhoListItemVm item)
    {
        if (isSaving || isDetailLineSaving)
        {
            return;
        }

        ClearPageMessage();
        ClearFormMessage();
        ClearDetailEditorMessage();

        item.Don_Vi_Tien = DonViTienOptions.Normalize(item.Don_Vi_Tien);
        detailHeaderItem = item;
        isDetailEditorVisible = true;

        await ReloadDetailEditorLinesAsync();
    }

    private async Task ReloadDetailEditorLinesAsync()
    {
        if (detailHeaderItem is null)
        {
            return;
        }

        isDetailEditorLoading = true;
        detailEditorLines.Clear();

        try
        {
            var result = await NhapKhoService.GetDetailsAsync(detailHeaderItem.Nhap_Kho_ID);
            if (!result.Success || result.Data is null)
            {
                detailEditorMessage = result.Message;
                detailEditorMessageIsError = true;
                return;
            }

            detailEditorLines.AddRange(result.Data.Select(ToDetailEditorLine));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load detail editor lines failed. Nhap_Kho_ID={Nhap_Kho_ID}", detailHeaderItem.Nhap_Kho_ID);
            detailEditorMessage = "Không thể tải dữ liệu hiệu chỉnh chi tiết phiếu nhập.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailEditorLoading = false;
        }
    }

    private void AddDetailEditorRow()
    {
        ClearDetailEditorMessage();

        if (detailHeaderItem is null)
        {
            detailEditorMessage = "Không tìm thấy thông tin phiếu nhập.";
            detailEditorMessageIsError = true;
            return;
        }

        if (detailEditorLines.Any(x => x.IsEditing))
        {
            detailEditorMessage = "Vui lòng lưu hoặc hủy dòng đang chỉnh sửa trước khi thêm dòng mới.";
            detailEditorMessageIsError = true;
            return;
        }

        detailEditorLines.Insert(0, new NhapKhoDetailEditorLineVm
        {
            IsNew = true,
            IsEditing = true,
            SL_Nhap = 1m,
            Don_Gia_Nhap = 0m,
            SL_Nhap_Text = "1",
            Don_Gia_Nhap_Text = FormatAmountInput(0m, CurrentDetailEditorDonViTien)
        });
    }

    private void StartEditDetailLine(NhapKhoDetailEditorLineVm line)
    {
        ClearDetailEditorMessage();

        if (detailEditorLines.Any(x => x != line && x.IsEditing))
        {
            detailEditorMessage = "Vui lòng lưu hoặc hủy dòng đang chỉnh sửa trước khi sửa dòng khác.";
            detailEditorMessageIsError = true;
            return;
        }

        line.IsEditing = true;
        line.SL_Nhap_Text = FormatQuantityForInput(line.SL_Nhap);
        line.Don_Gia_Nhap_Text = FormatAmountInput(line.Don_Gia_Nhap, CurrentDetailEditorDonViTien);
    }

    private void CancelEditDetailLine(NhapKhoDetailEditorLineVm line)
    {
        if (line.IsNew)
        {
            detailEditorLines.Remove(line);
            return;
        }

        line.IsEditing = false;
        line.SL_Nhap_Text = FormatQuantityForInput(line.SL_Nhap);
        line.Don_Gia_Nhap_Text = FormatAmountInput(line.Don_Gia_Nhap, CurrentDetailEditorDonViTien);
        ClearDetailEditorMessage();
    }

    private async Task SaveDetailLineAsync(NhapKhoDetailEditorLineVm line)
    {
        if (detailHeaderItem is null)
        {
            detailEditorMessage = "Không tìm thấy thông tin phiếu nhập.";
            detailEditorMessageIsError = true;
            return;
        }

        if (!TryParseDetailEditorLine(
                line,
                CurrentDetailEditorDonViTien,
                out var soLuong,
                out var donGia,
                out var validationMessage))
        {
            detailEditorMessage = validationMessage;
            detailEditorMessageIsError = true;
            return;
        }

        isDetailLineSaving = true;
        ClearDetailEditorMessage();

        try
        {
            ServiceResult result;
            if (line.IsNew)
            {
                if (line.San_Pham_ID <= 0)
                {
                    detailEditorMessage = "Mã sản phẩm không được để trống khi thêm dòng.";
                    detailEditorMessageIsError = true;
                    return;
                }

                result = await NhapKhoService.AddDetailAsync(detailHeaderItem.Nhap_Kho_ID, new NhapKhoDetailCreateVm
                {
                    San_Pham_ID = line.San_Pham_ID,
                    SL_Nhap = soLuong,
                    Don_Gia_Nhap = donGia
                });
            }
            else
            {
                result = await NhapKhoService.UpdateDetailAsync(new NhapKhoDetailUpdateVm
                {
                    Nhap_Kho_Raw_Data_ID = line.Nhap_Kho_Raw_Data_ID,
                    SL_Nhap = soLuong,
                    Don_Gia_Nhap = donGia
                });
            }

            detailEditorMessage = result.Message;
            detailEditorMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await ReloadDetailEditorLinesAsync();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save detail line failed. Nhap_Kho_ID={Nhap_Kho_ID}", detailHeaderItem.Nhap_Kho_ID);
            detailEditorMessage = "Không thể lưu dòng chi tiết do lỗi hệ thống.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailLineSaving = false;
        }
    }

    private async Task DeleteDetailLineAsync(NhapKhoDetailEditorLineVm line)
    {
        if (line.IsNew)
        {
            detailEditorLines.Remove(line);
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa dòng sản phẩm '{line.Ma_San_Pham}' khỏi phiếu nhập?");

        if (!confirmed)
        {
            return;
        }

        isDetailLineSaving = true;
        ClearDetailEditorMessage();

        try
        {
            var result = await NhapKhoService.DeleteDetailAsync(line.Nhap_Kho_Raw_Data_ID);
            detailEditorMessage = result.Message;
            detailEditorMessageIsError = !result.Success;

            if (!result.Success)
            {
                return;
            }

            await ReloadDetailEditorLinesAsync();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Delete detail line failed. Nhap_Kho_Raw_Data_ID={Nhap_Kho_Raw_Data_ID}", line.Nhap_Kho_Raw_Data_ID);
            detailEditorMessage = "Không thể xóa dòng chi tiết do lỗi hệ thống.";
            detailEditorMessageIsError = true;
        }
        finally
        {
            isDetailLineSaving = false;
        }
    }

    private void CloseDetailEditor()
    {
        if (isDetailLineSaving)
        {
            return;
        }

        isDetailEditorVisible = false;
        isDetailEditorLoading = false;
        detailHeaderItem = null;
        detailEditorLines.Clear();
        ClearDetailEditorMessage();
    }

    private void HandleDetailEditorBackdropClick()
    {
        if (isDetailLineSaving)
        {
            return;
        }

        CloseDetailEditor();
    }

    private void ClearDetailEditorMessage()
    {
        detailEditorMessage = null;
        detailEditorMessageIsError = false;
    }

    private void AddDetailRow()
    {
        formModel.Chi_Tiets.Add(new NhapKhoRawDataUpsertVm
        {
            SL_Nhap = 1m,
            SL_Nhap_Text = "1",
            Don_Gia_Nhap = 0m,
            Don_Gia_Nhap_Text = FormatAmountInput(0m, formModel.Don_Vi_Tien)
        });
    }

    private void DecreaseFormLineQuantity(NhapKhoRawDataUpsertVm line)
    {
        var current = Math.Max(1m, GetLineSoLuong(line));
        var next = Math.Max(1m, current - 1m);
        line.SL_Nhap_Text = FormatQuantityForInput(next);
    }

    private void IncreaseFormLineQuantity(NhapKhoRawDataUpsertVm line)
    {
        var current = Math.Max(0m, GetLineSoLuong(line));
        var next = Math.Min(BusinessValidationRules.MaxQuantity, current + 1m);
        line.SL_Nhap_Text = FormatQuantityForInput(next);
    }

    private void DecreaseDetailLineQuantity(NhapKhoDetailEditorLineVm line)
    {
        var current = Math.Max(1m, GetDetailLineSoLuong(line));
        var next = Math.Max(1m, current - 1m);
        line.SL_Nhap_Text = FormatQuantityForInput(next);
    }

    private void IncreaseDetailLineQuantity(NhapKhoDetailEditorLineVm line)
    {
        var current = Math.Max(0m, GetDetailLineSoLuong(line));
        var next = Math.Min(BusinessValidationRules.MaxQuantity, current + 1m);
        line.SL_Nhap_Text = FormatQuantityForInput(next);
    }

    private void RemoveDetailRow(int index)
    {
        if (index < 0 || index >= formModel.Chi_Tiets.Count)
        {
            return;
        }

        if (formModel.Chi_Tiets.Count == 1)
        {
            formMessage = "Phiếu nhập phải có ít nhất 1 dòng chi tiết.";
            formMessageIsError = true;
            return;
        }

        formModel.Chi_Tiets.RemoveAt(index);
    }

