            {
                Nhap_Kho_ID = detailHeaderItem.Nhap_Kho_ID,
                So_Phieu_Nhap_Kho = detailHeaderItem.So_Phieu_Nhap_Kho,
                Kho_ID = detailHeaderItem.Kho_ID,
