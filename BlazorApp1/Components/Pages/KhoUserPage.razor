@page "/phan-quyen/kho-user"
@rendermode InteractiveServer
@using System.Text
@using System.Text.Encodings.Web
@using BlazorApp1.Infrastructure.Excel
@using BlazorApp1.Models.Kho
@using BlazorApp1.Models.KhoUser
@using BlazorApp1.Services.Interfaces
@inject IKhoUserService KhoUserService
@inject IKhoService KhoService
@inject IJSRuntime JS
@inject ILogger<KhoUserPage> Logger

<PageTitle>Phân quyền kho-user</PageTitle>

<section class="warehouse-user-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Phân quyền kho-user</h1>
        <div class="page-header__actions">
            <button type="button" class="app-button" style="display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;" @onclick="ExportTemplateAsync" disabled="@(isSaving || isImporting || isApplyingImport)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                <span>Xuất file mẫu</span>
            </button>
            <label class="app-button" style="position:relative;overflow:hidden;display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;@(isSaving || isImporting || isApplyingImport ? "pointer-events:none;opacity:0.65;cursor:wait;" : "cursor:pointer;")">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21V9" />
                    <path d="m17 14-5-5-5 5" />
                    <path d="M5 3h14" />
                </svg>
                <span>Nhập file excel</span>
                <InputFile style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;"
                           @key="importFileInputVersion"
                           OnChange="ImportExcelAsync"
                           accept=".xlsx"
                           disabled="@(isSaving || isImporting || isApplyingImport)" />
            </label>
            <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@(isSaving || isImporting || isApplyingImport)">
                Thêm mới
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <ExcelImportPreviewDialog Visible="@showImportPreview"
                              FileName="@importPreviewFileName"
                              SheetName="@importPreviewSheetName"
                              ColumnHeaders="@ImportPreviewHeaders"
                              Rows="@importPreviewRows"
                              IsApplying="@isApplyingImport"
                              OnClose="CloseImportPreview"
                              OnConfirm="ApplyImportAsync" />

    <div class="warehouse-user-layout @(IsFormVisible ? string.Empty : "warehouse-user-layout--single")">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Mã đăng nhập hoặc kho" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th>Mã đăng nhập</th>
                                    <th>Kho</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(formModel.Kho_User_ID == item.Kho_User_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        @onclick="() => StartEditAsync(item.Kho_User_ID)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.Ma_Dang_Nhap</td>
                                        <td class="data-table__name">@item.Ten_Kho</td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.Kho_User_ID, item.Ma_Dang_Nhap, item.Ten_Kho)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @if (IsFormVisible)
        {
            <section class="card card--form">
                <header class="card__header card__header--form">
                    <h2>@FormTitle</h2>
                    <span class="card__tag">@FormModeLabel</span>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="KhoUserForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-field form-field--code">
                                <div class="form-field__head">
                                    <label class="form-field__label">Mã đăng nhập <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ma_Dang_Nhap?.Length ?? 0))/100</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ma_Dang_Nhap"
                                           @oninput="HandleMaDangNhapInput"
                                           maxlength="100"
                                           placeholder="Nhập mã đăng nhập" />
                                <p class="form-field__hint">Không được để trống.</p>
                                <ValidationMessage For="@(() => formModel.Ma_Dang_Nhap)" />
                            </div>

                            <div class="form-field form-field--lookup">
                                <div class="form-field__head">
                                    <label class="form-field__label">Kho <span class="required-mark">*</span></label>
                                </div>
                                <div class="combo-box">
                                    <div class="combo-box__control">
                                        <input class="form-field__input form-field__input--combo"
                                               value="@khoKeyword"
                                               @oninput="HandleKhoInput"
                                               @onfocus="OpenKhoDropdown"
                                               @onblur="HandleKhoBlurAsync"
                                               placeholder="Chọn hoặc nhập chữ để lọc kho"
                                               autocomplete="off" />
                                        <button type="button"
                                                class="combo-box__toggle"
                                                @onclick="ToggleKhoDropdown"
                                                tabindex="-1"
                                                aria-label="Mở danh sách kho">
                                            <span class="combo-box__caret @(isKhoDropdownOpen ? "combo-box__caret--open" : string.Empty)">⌄</span>
                                        </button>
                                    </div>
                                    @if (isKhoDropdownOpen)
                                    {
                                        <div class="combo-box__menu">
                                            @if (FilteredKhoOptions.Count == 0)
                                            {
                                                <div class="combo-box__empty">Không có kho phù hợp.</div>
                                            }
                                            else
                                            {
                                                @foreach (var option in FilteredKhoOptions)
                                                {
                                                    <button type="button"
                                                            class="combo-box__option @(option.Kho_ID == formModel.Kho_ID ? "combo-box__option--active" : string.Empty)"
                                                            @onclick="() => SelectKho(option)">
                                                        @((MarkupString)BuildHighlightedOptionHtml(FormatKhoOption(option), khoKeyword))
                                                    </button>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                                <p class="form-field__hint">Bộ mã đăng nhập và kho phải duy nhất.</p>
                                @if (!string.IsNullOrWhiteSpace(khoLookupMessage))
                                {
                                    <p class="form-field__lookup-warning">@khoLookupMessage</p>
                                }
                                <ValidationMessage For="@(() => formModel.Kho_ID)" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@(!HasKhoOptions || isSaving)">
                                    @(isSaving ? "Đang lưu..." : "Lưu")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        }
    </div>
</section>

@code {
    private readonly List<KhoUserListItemVm> items = [];
    private readonly List<KhoListItemVm> khoOptions = [];
    private KhoUserUpsertVm formModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isImporting;
    private bool isApplyingImport;
    private int importFileInputVersion;
    private bool showImportPreview;
    private string importPreviewFileName = string.Empty;
    private string importPreviewSheetName = string.Empty;
    private List<ExcelImportPreviewRow> importPreviewRows = [];
    private List<ExcelImportRow> importSourceRows = [];
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string searchKeyword = string.Empty;
    private string khoKeyword = string.Empty;
    private string? khoLookupMessage;
    private bool isKhoDropdownOpen;
    private FormMode currentFormMode = FormMode.None;
    private static readonly IReadOnlyList<string> ImportPreviewHeaders = ["Mã đăng nhập", "Kho"];
    private static readonly HtmlEncoder HtmlEncoder = HtmlEncoder.Default;

    private bool IsFormVisible => currentFormMode != FormMode.None;
    private bool IsEditing => currentFormMode == FormMode.Edit;
    private bool HasKhoOptions => khoOptions.Count > 0;
    private string FormTitle => IsEditing ? "Sửa phân quyền kho-user" : "Tạo phân quyền kho-user";
    private string FormModeLabel => IsEditing ? "Đang sửa" : "Đang tạo";

    private IReadOnlyList<KhoUserListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();
            return items
                .Where(x =>
                    ContainsKeyword(x.Ma_Dang_Nhap, keyword)
                    || ContainsKeyword(x.Ten_Kho, keyword))
                .ToList();
        }
    }

    private IReadOnlyList<KhoListItemVm> FilteredKhoOptions
    {
        get
        {
            var keyword = khoKeyword.Trim();
            if (string.IsNullOrWhiteSpace(keyword))
            {
                return khoOptions;
            }

            return khoOptions
                .Where(x =>
                    ContainsKeyword(x.Ten_Kho, keyword)
                    || ContainsKeyword(FormatKhoOption(x), keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var getKhoUserTask = KhoUserService.GetAllAsync();
            var getKhoTask = KhoService.GetAllAsync();

            await Task.WhenAll(getKhoUserTask, getKhoTask);

            items.Clear();
            items.AddRange(getKhoUserTask.Result);

            khoOptions.Clear();
            khoOptions.AddRange(getKhoTask.Result);

            if (IsFormVisible)
            {
                SyncKhoKeywordFromFormModel();
            }

            if (!HasKhoOptions)
            {
                pageMessage = "Cần có dữ liệu kho trước khi phân quyền.";
                pageMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load KhoUser list failed.");
            pageMessage = "Không thể tải danh sách phân quyền kho-user.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasKhoOptions)
        {
            pageMessage = "Cần có dữ liệu kho trước khi phân quyền.";
            pageMessageIsError = true;
            return;
        }

        currentFormMode = FormMode.Create;
        ResetFormModel();
    }

    private async Task StartEditAsync(int id)
    {
        ClearPageMessage();
        ClearFormMessage();

        var result = await KhoUserService.GetByIdAsync(id);
        if (!result.Success || result.Data is null)
        {
            pageMessage = result.Message;
            pageMessageIsError = true;
            return;
        }

        formModel = new KhoUserUpsertVm
        {
            Kho_User_ID = result.Data.Kho_User_ID,
            Ma_Dang_Nhap = result.Data.Ma_Dang_Nhap,
            Kho_ID = result.Data.Kho_ID
        };
        SyncKhoKeywordFromFormModel();
        currentFormMode = FormMode.Edit;
    }

    private async Task SaveAsync()
    {
        if (!HasKhoOptions)
        {
            formMessage = "Cần có dữ liệu kho trước khi lưu.";
            formMessageIsError = true;
            return;
        }

        TryApplyKhoKeywordSelection(showValidationMessage: true);
        if (formModel.Kho_ID <= 0)
        {
            formMessage = "Vui lòng chọn kho hợp lệ.";
            formMessageIsError = true;
            return;
        }

        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            var result = formModel.Kho_User_ID == 0
                ? await KhoUserService.CreateAsync(formModel)
                : await KhoUserService.UpdateAsync(formModel);

            formMessage = result.Message;
            formMessageIsError = !result.Success;
            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save KhoUser failed. Kho_User_ID={Kho_User_ID}", formModel.Kho_User_ID);
            formMessage = "Không thể lưu dữ liệu do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string maDangNhap, string tenKho)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa phân quyền '{maDangNhap} - {tenKho}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await KhoUserService.DeleteAsync(id);
        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (formModel.Kho_User_ID == id)
        {
            CancelForm();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

    private void CancelForm()
    {
        currentFormMode = FormMode.None;
        ResetFormModel();
        ClearFormMessage();
    }

    private void ResetFormModel()
    {
        formModel = new KhoUserUpsertVm();
        khoKeyword = string.Empty;
        khoLookupMessage = null;
        isKhoDropdownOpen = false;
    }

    private void ClearSearch()
    {
        searchKeyword = string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        searchKeyword = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleMaDangNhapInput(ChangeEventArgs args)
    {
        formModel.Ma_Dang_Nhap = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleKhoInput(ChangeEventArgs args)
    {
        khoKeyword = args.Value?.ToString() ?? string.Empty;
        khoLookupMessage = null;
        TryApplyKhoKeywordSelection(showValidationMessage: false);
        isKhoDropdownOpen = true;
    }

    private void OpenKhoDropdown(FocusEventArgs _)
    {
        isKhoDropdownOpen = true;
    }

    private async Task HandleKhoBlurAsync(FocusEventArgs _)
    {
        await Task.Delay(120);
        isKhoDropdownOpen = false;
        TryApplyKhoKeywordSelection(showValidationMessage: true);
    }

    private void ToggleKhoDropdown()
    {
        isKhoDropdownOpen = !isKhoDropdownOpen;
    }

    private void SelectKho(KhoListItemVm option)
    {
        formModel.Kho_ID = option.Kho_ID;
        khoKeyword = FormatKhoOption(option);
        khoLookupMessage = null;
        isKhoDropdownOpen = false;
    }

    private async Task ExportTemplateAsync()
    {
        try
        {
            var bytes = ExcelWorkbookHelper.CreateTemplate(
                "KhoUser",
                ["Mã đăng nhập", "Kho"],
                []);

            await DownloadExcelAsync("kho-user-template.xlsx", bytes);
            pageMessage = "Đã xuất file mẫu phân quyền kho-user.";
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Export KhoUser template failed.");
            pageMessage = "Không thể xuất file mẫu phân quyền kho-user.";
            pageMessageIsError = true;
        }
    }

    private async Task ImportExcelAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            pageMessage = "Chỉ hỗ trợ file Excel định dạng .xlsx.";
            pageMessageIsError = true;
            return;
        }

        isImporting = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var readResult = await ExcelWorkbookHelper.ReadRowsWithContextAsync(stream);
            var rows = readResult.Rows;
            if (rows.Count == 0)
            {
                pageMessage = "File Excel không có dữ liệu để nhập.";
                pageMessageIsError = true;
                return;
            }

            var khoByName = khoOptions
                .GroupBy(x => x.Ten_Kho, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

            var existingPairs = items
                .Where(x => !string.IsNullOrWhiteSpace(x.Ma_Dang_Nhap) && !string.IsNullOrWhiteSpace(x.Ten_Kho))
                .Select(x => $"{x.Ma_Dang_Nhap.Trim().ToUpperInvariant()}|{x.Ten_Kho.Trim().ToUpperInvariant()}")
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            importPreviewFileName = file.Name;
            importPreviewSheetName = string.IsNullOrWhiteSpace(readResult.SheetName) ? "Sheet1" : readResult.SheetName;
            importSourceRows = rows.ToList();
            importPreviewRows = BuildImportPreviewRows(rows, khoByName, existingPairs);
            showImportPreview = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import KhoUser from Excel failed.");
            pageMessage = $"Không thể nhập file Excel phân quyền kho-user: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isImporting = false;
            importFileInputVersion++;
        }
    }

    private async Task ApplyImportAsync()
    {
        var candidates = importPreviewRows
            .Where(x => x.CanImport)
            .ToList();

        if (candidates.Count == 0)
        {
            pageMessage = "Không có dòng hợp lệ để nhập.";
            pageMessageIsError = true;
            return;
        }

        isApplyingImport = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            var khoByName = khoOptions
                .GroupBy(x => x.Ten_Kho, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

            var successCount = 0;
            var skippedDuplicates = new List<string>();
            var errors = new List<string>();

            foreach (var preview in candidates)
            {
                if (preview.SourceIndex < 0 || preview.SourceIndex >= importSourceRows.Count)
                {
                    continue;
                }

                var row = importSourceRows[preview.SourceIndex];
                var maDangNhap = row.Get("Mã đăng nhập").Trim();
                var tenKho = row.Get("Kho").Trim();

                if (!khoByName.TryGetValue(tenKho, out var kho))
                {
                    errors.Add($"Dòng {row.RowNumber}: Không tìm thấy kho '{tenKho}'.");
                    continue;
                }

                var result = await KhoUserService.CreateAsync(new KhoUserUpsertVm
                {
                    Ma_Dang_Nhap = maDangNhap,
                    Kho_ID = kho.Kho_ID
                });

                if (result.Success)
                {
                    successCount++;
                }
                else if (IsDuplicateImportMessage(result.Message))
                {
                    skippedDuplicates.Add($"Dòng {row.RowNumber}: {result.Message}");
                }
                else
                {
                    errors.Add($"Dòng {row.RowNumber}: {result.Message}");
                }
            }

            await LoadDataAsync();
            pageMessage = BuildImportSummary(successCount, skippedDuplicates, errors);
            pageMessageIsError = errors.Count > 0;
            CloseImportPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Apply KhoUser import failed.");
            pageMessage = $"Không thể nhập dữ liệu từ file Excel: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isApplyingImport = false;
        }
    }

    private void CloseImportPreview()
    {
        showImportPreview = false;
        importPreviewFileName = string.Empty;
        importPreviewSheetName = string.Empty;
        importPreviewRows = [];
        importSourceRows = [];
    }

    private static List<ExcelImportPreviewRow> BuildImportPreviewRows(
        IReadOnlyList<ExcelImportRow> rows,
        IReadOnlyDictionary<string, KhoListItemVm> khoByName,
        ISet<string> existingPairs)
    {
        var previewRows = new List<ExcelImportPreviewRow>(rows.Count);
        var filePairs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        for (var index = 0; index < rows.Count; index++)
        {
            var row = rows[index];
            var maDangNhap = row.Get("Mã đăng nhập").Trim();
            var tenKho = row.Get("Kho").Trim();

            var status = ExcelImportPreviewStatus.Valid;
            var message = string.Empty;

            if (string.IsNullOrWhiteSpace(maDangNhap) || string.IsNullOrWhiteSpace(tenKho))
            {
                status = ExcelImportPreviewStatus.Error;
                message = "Mã đăng nhập và tên kho là bắt buộc.";
            }
            else if (!khoByName.ContainsKey(tenKho))
            {
                status = ExcelImportPreviewStatus.Error;
                message = $"Không tìm thấy kho '{tenKho}'.";
            }
            else
            {
                var pairKey = $"{maDangNhap.ToUpperInvariant()}|{tenKho.ToUpperInvariant()}";
                if (!filePairs.Add(pairKey))
                {
                    status = ExcelImportPreviewStatus.Warning;
                    message = "Dòng phân quyền bị trùng trong file.";
                }
                else if (existingPairs.Contains(pairKey))
                {
                    status = ExcelImportPreviewStatus.Warning;
                    message = "Phân quyền kho-user đã tồn tại.";
                }
            }

            previewRows.Add(new ExcelImportPreviewRow(
                DisplayIndex: index + 1,
                SourceIndex: index,
                ExcelRowNumber: row.RowNumber,
                Cells: [maDangNhap, tenKho],
                Status: status,
                Message: message));
        }

        return previewRows;
    }

    private void ClearPageMessage()
    {
        pageMessage = null;
        pageMessageIsError = false;
    }

    private void ClearFormMessage()
    {
        formMessage = null;
        formMessageIsError = false;
    }

    private static bool ContainsKeyword(string? source, string keyword)
    {
        return !string.IsNullOrWhiteSpace(source)
               && source.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private void TryApplyKhoKeywordSelection(bool showValidationMessage)
    {
        var keyword = khoKeyword.Trim();
        if (string.IsNullOrWhiteSpace(keyword))
        {
            formModel.Kho_ID = 0;
            if (showValidationMessage)
            {
                khoLookupMessage = "Vui lòng chọn kho.";
            }

            return;
        }

        var matched = khoOptions.FirstOrDefault(x =>
            string.Equals(x.Ten_Kho, keyword, StringComparison.OrdinalIgnoreCase)
            || string.Equals(FormatKhoOption(x), keyword, StringComparison.OrdinalIgnoreCase));

        if (matched is null)
        {
            formModel.Kho_ID = 0;
            if (showValidationMessage)
            {
                khoLookupMessage = $"Không tìm thấy kho '{keyword}'.";
            }

            return;
        }

        formModel.Kho_ID = matched.Kho_ID;
        khoKeyword = FormatKhoOption(matched);
        khoLookupMessage = null;
    }

    private void SyncKhoKeywordFromFormModel()
    {
        var kho = khoOptions.FirstOrDefault(x => x.Kho_ID == formModel.Kho_ID);
        khoKeyword = kho is null ? string.Empty : FormatKhoOption(kho);
        khoLookupMessage = null;
    }

    private static string FormatKhoOption(KhoListItemVm option)
    {
        return option.Ten_Kho;
    }

    private static string BuildHighlightedOptionHtml(string optionText, string keyword)
    {
        var safeText = optionText ?? string.Empty;
        var trimmedKeyword = keyword?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(trimmedKeyword))
        {
            return HtmlEncoder.Encode(safeText);
        }

        var result = new StringBuilder();
        var startIndex = 0;

        while (startIndex < safeText.Length)
        {
            var matchIndex = safeText.IndexOf(trimmedKeyword, startIndex, StringComparison.OrdinalIgnoreCase);
            if (matchIndex < 0)
            {
                result.Append(HtmlEncoder.Encode(safeText[startIndex..]));
                break;
            }

            if (matchIndex > startIndex)
            {
                result.Append(HtmlEncoder.Encode(safeText[startIndex..matchIndex]));
            }

            var matchedText = safeText.Substring(matchIndex, trimmedKeyword.Length);
            result.Append("<span class=\"combo-box__option-match\">");
            result.Append(HtmlEncoder.Encode(matchedText));
            result.Append("</span>");
            startIndex = matchIndex + trimmedKeyword.Length;
        }

        return result.ToString();
    }

    private async Task DownloadExcelAsync(string fileName, byte[] bytes)
    {
        await JS.InvokeVoidAsync(
            "blazorFileDownload.downloadFileFromBase64",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(bytes));
    }

    private static bool IsDuplicateImportMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
               || message.Contains("bị trùng", StringComparison.OrdinalIgnoreCase)
               || message.Contains("đã được", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildImportSummary(
        int successCount,
        IReadOnlyList<string> skippedDuplicates,
        IReadOnlyList<string> errors)
    {
        if (errors.Count == 0 && skippedDuplicates.Count == 0)
        {
            return $"Nhập Excel thành công {successCount} dòng.";
        }

        if (errors.Count == 0 && skippedDuplicates.Count > 0)
        {
            var skippedText = string.Join(" | ", skippedDuplicates.Take(3));
            if (skippedDuplicates.Count > 3)
            {
                skippedText += $" | ... thêm {skippedDuplicates.Count - 3} dòng trùng.";
            }

            return $"Đã nhập {successCount} dòng. Bỏ qua {skippedDuplicates.Count} dòng trùng: {skippedText}";
        }

        var firstErrors = string.Join(" | ", errors.Take(3));
        if (errors.Count > 3)
        {
            firstErrors += $" | ... thêm {errors.Count - 3} lỗi.";
        }

        var summary = $"Đã nhập {successCount} dòng. Có {errors.Count} lỗi: {firstErrors}";
        if (skippedDuplicates.Count > 0)
        {
            summary += $" | Bỏ qua {skippedDuplicates.Count} dòng trùng.";
        }

        return summary;
    }

