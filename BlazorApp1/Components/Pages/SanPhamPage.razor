    private async Task ImportExcelAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            pageMessage = "Chỉ hỗ trợ file Excel định dạng .xlsx.";
            pageMessageIsError = true;
            return;
        }

        isImporting = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var readResult = await ExcelWorkbookHelper.ReadRowsWithContextAsync(stream);
            var rows = readResult.Rows;
            if (rows.Count == 0)
            {
                pageMessage = "File Excel không có dữ liệu để nhập.";
                pageMessageIsError = true;
                return;
            }

            importPreviewFileName = file.Name;
            importPreviewSheetName = string.IsNullOrWhiteSpace(readResult.SheetName) ? "Sheet1" : readResult.SheetName;
            importSourceRows = rows.ToList();
            importResolutionBySourceIndex.Clear();
            RebuildSanPhamImportPreviewRows();
            showImportPreview = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Import SanPham from Excel failed.");
            pageMessage = $"Không thể nhập file Excel sản phẩm: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isImporting = false;
            importFileInputVersion++;
        }
    }

    private async Task ApplyImportAsync()
    {
        RebuildSanPhamImportPreviewRows();

        var skippedReasons = importPreviewRows
            .Where(x => x.Status == ExcelImportPreviewStatus.Error)
            .Select(x => $"Dòng {x.ExcelRowNumber}: {x.Message}")
            .ToList();

        var candidates = importPreviewRows
            .Where(x => x.CanImport)
            .ToList();

        if (candidates.Count == 0)
        {
            pageMessage = skippedReasons.Count > 0
                ? BuildImportSummary(0, skippedReasons)
                : "Không có dòng hợp lệ để nhập.";
            pageMessageIsError = true;
            return;
        }

        isApplyingImport = true;
        ClearPageMessage();
        ClearFormMessage();

        try
        {
            var successCount = 0;
            var errors = new List<string>();

            foreach (var preview in candidates)
            {
                if (preview.SourceIndex < 0 || preview.SourceIndex >= importSourceRows.Count)
                {
                    continue;
                }

                var row = importSourceRows[preview.SourceIndex];
                var maSp = row.Get("Mã").Trim();
                var tenSp = row.Get("Tên sản phẩm").Trim();
                var ghiChuRaw = row.Get("Ghi chú").Trim();
                var ghiChu = string.IsNullOrWhiteSpace(ghiChuRaw) ? null : ghiChuRaw;

                if (!importResolutionBySourceIndex.TryGetValue(preview.SourceIndex, out var resolutionState))
                {
                    var errorDetail = $"Dòng {row.RowNumber}: Không tìm thấy cấu hình loại sản phẩm/đơn vị tính.";
                    errors.Add(errorDetail);
                    skippedReasons.Add(errorDetail);
                    continue;
                }

                if (!resolutionState.SelectedLoaiSanPhamId.HasValue)
                {
                    var errorDetail = $"Dòng {row.RowNumber}: Chưa chọn loại sản phẩm.";
                    errors.Add(errorDetail);
                    skippedReasons.Add(errorDetail);
                    continue;
                }

                if (!resolutionState.SelectedDonViTinhId.HasValue)
                {
                    var errorDetail = $"Dòng {row.RowNumber}: Chưa chọn đơn vị tính.";
                    errors.Add(errorDetail);
                    skippedReasons.Add(errorDetail);
                    continue;
                }

                var result = await SanPhamService.CreateAsync(new SanPhamUpsertVm
                {
                    Ma_San_Pham = maSp,
                    Ten_San_Pham = tenSp,
                    Loai_San_Pham_ID = resolutionState.SelectedLoaiSanPhamId.Value,
                    Don_Vi_Tinh_ID = resolutionState.SelectedDonViTinhId.Value,
                    Ghi_Chu = ghiChu
                });

                if (result.Success)
                {
                    successCount++;
                }
                else if (IsDuplicateImportMessage(result.Message))
                {
                    skippedReasons.Add($"Dòng {row.RowNumber}: {result.Message}");
                }
                else
                {
                    var errorDetail = $"Dòng {row.RowNumber}: {result.Message}";
                    errors.Add(errorDetail);
                    skippedReasons.Add(errorDetail);
                }
            }

            await LoadDataAsync();
            pageMessage = BuildImportSummary(successCount, skippedReasons);
            pageMessageIsError = errors.Count > 0;
            CloseImportPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Apply SanPham import failed.");
            pageMessage = $"Không thể nhập dữ liệu từ file Excel: {ex.Message}";
            pageMessageIsError = true;
        }
        finally
        {
            isApplyingImport = false;
        }
    }

    private void CloseImportPreview()
    {
        showImportPreview = false;
        importPreviewFileName = string.Empty;
        importPreviewSheetName = string.Empty;
        importPreviewRows = [];
        importSourceRows = [];
