    private void RebuildSanPhamImportPreviewRows()
    {
        var lspByCode = loaiSanPhamOptions
            .GroupBy(x => x.Ma_LSP, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

        var lspByName = loaiSanPhamOptions
            .GroupBy(x => x.Ten_LSP, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

        var dvtByName = donViTinhOptions
            .GroupBy(x => x.Ten_Don_Vi_Tinh, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

        var existingProductCodes = items
            .Select(x => x.Ma_San_Pham?.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        importPreviewRows = BuildImportPreviewRows(importSourceRows, lspByCode, lspByName, dvtByName, existingProductCodes);
    }

    private List<ExcelImportPreviewRow> BuildImportPreviewRows(
        IReadOnlyList<ExcelImportRow> rows,
        IReadOnlyDictionary<string, LoaiSanPhamListItemVm> lspByCode,
        IReadOnlyDictionary<string, LoaiSanPhamListItemVm> lspByName,
        IReadOnlyDictionary<string, DonViTinhListItemVm> dvtByName,
        ISet<string> existingProductCodes)
    {
        var previewRows = new List<ExcelImportPreviewRow>(rows.Count);
        var fileCodes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var lspById = loaiSanPhamOptions.ToDictionary(x => x.Loai_San_Pham_ID);
        var dvtById = donViTinhOptions.ToDictionary(x => x.Don_Vi_Tinh_ID);

        for (var index = 0; index < rows.Count; index++)
        {
            var row = rows[index];
            var maSp = row.Get("Mã").Trim();
            var tenSp = row.Get("Tên sản phẩm").Trim();
            var loaiSanPhamInput = row.Get("Loại sản phẩm").Trim();
            var tenDvt = row.Get("Đơn vị tính").Trim();
            var ghiChu = row.Get("Ghi chú").Trim();

            if (!importResolutionBySourceIndex.TryGetValue(index, out var state))
            {
                state = new SanPhamImportResolutionState();
                importResolutionBySourceIndex[index] = state;
            }

            state.RawLoaiSanPham = loaiSanPhamInput;
            state.RawDonViTinh = tenDvt;

            LoaiSanPhamListItemVm? resolvedLoai = null;
            DonViTinhListItemVm? resolvedDonViTinh = null;
            var isLoaiResolvedFromFile = !string.IsNullOrWhiteSpace(loaiSanPhamInput)
                                         && TryResolveLoaiSanPham(loaiSanPhamInput, lspByCode, lspByName, out resolvedLoai);
            var isDonViTinhResolvedFromFile = !string.IsNullOrWhiteSpace(tenDvt)
                                              && dvtByName.TryGetValue(tenDvt, out resolvedDonViTinh);

            if (isLoaiResolvedFromFile && resolvedLoai is not null)
            {
                state.SelectedLoaiSanPhamId = resolvedLoai.Loai_San_Pham_ID;
            }
            else if (state.SelectedLoaiSanPhamId.HasValue && !lspById.ContainsKey(state.SelectedLoaiSanPhamId.Value))
            {
                state.SelectedLoaiSanPhamId = null;
            }

            if (isDonViTinhResolvedFromFile && resolvedDonViTinh is not null)
            {
                state.SelectedDonViTinhId = resolvedDonViTinh.Don_Vi_Tinh_ID;
            }
            else if (state.SelectedDonViTinhId.HasValue && !dvtById.ContainsKey(state.SelectedDonViTinhId.Value))
            {
                state.SelectedDonViTinhId = null;
            }

            state.ShouldRenderLoaiSanPhamCombo = string.IsNullOrWhiteSpace(loaiSanPhamInput) || !isLoaiResolvedFromFile;
            state.ShouldRenderDonViTinhCombo = string.IsNullOrWhiteSpace(tenDvt) || !isDonViTinhResolvedFromFile;

            var status = ExcelImportPreviewStatus.Valid;
            var messageParts = new List<string>();

            if (string.IsNullOrWhiteSpace(maSp)
                || string.IsNullOrWhiteSpace(tenSp))
            {
                messageParts.Add("Thiếu cột bắt buộc (mã SP, tên SP).");
            }

            if (state.ShouldRenderLoaiSanPhamCombo && !state.SelectedLoaiSanPhamId.HasValue)
            {
                messageParts.Add("Chưa chọn loại sản phẩm.");
            }

            if (state.ShouldRenderDonViTinhCombo && !state.SelectedDonViTinhId.HasValue)
            {
                messageParts.Add("Chưa chọn đơn vị tính.");
            }

            string message;
            if (messageParts.Count > 0)
            {
                status = ExcelImportPreviewStatus.Error;
                message = string.Join(" ", messageParts);
            }
            else if (!fileCodes.Add(maSp))
            {
                status = ExcelImportPreviewStatus.Warning;
                message = $"Mã sản phẩm '{maSp}' bị trùng trong file.";
            }
            else if (existingProductCodes.Contains(maSp))
            {
                status = ExcelImportPreviewStatus.Warning;
                message = $"Mã sản phẩm '{maSp}' đã tồn tại.";
            }
            else
            {
                message = string.Empty;
            }

            var loaiDisplay = state.SelectedLoaiSanPhamId.HasValue && lspById.TryGetValue(state.SelectedLoaiSanPhamId.Value, out var loaiById)
                ? $"{loaiById.Ten_LSP} ({loaiById.Ma_LSP})"
                : loaiSanPhamInput;

            var dvtDisplay = state.SelectedDonViTinhId.HasValue && dvtById.TryGetValue(state.SelectedDonViTinhId.Value, out var dvtBySelectedId)
                ? dvtBySelectedId.Ten_Don_Vi_Tinh
                : tenDvt;

            previewRows.Add(new ExcelImportPreviewRow(
                DisplayIndex: index + 1,
                SourceIndex: index,
                ExcelRowNumber: row.RowNumber,
                Cells: [maSp, tenSp, loaiDisplay, dvtDisplay, ghiChu],
                Status: status,
                Message: message));
        }

        return previewRows;
    }

