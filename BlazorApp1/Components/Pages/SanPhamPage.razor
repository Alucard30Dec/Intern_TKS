    private async Task AddMissingLoaiSanPhamAsync(int sourceIndex)
    {
        if (!importResolutionBySourceIndex.TryGetValue(sourceIndex, out var state))
        {
            return;
        }

        var rawValue = state.RawLoaiSanPham?.Trim();
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return;
        }

        state.IsAddingLoaiSanPham = true;
        try
        {
            var existedByName = loaiSanPhamOptions.FirstOrDefault(x => string.Equals(x.Ten_LSP, rawValue, StringComparison.OrdinalIgnoreCase));
            if (existedByName is not null)
            {
                state.SelectedLoaiSanPhamId = existedByName.Loai_San_Pham_ID;
                RebuildSanPhamImportPreviewRows();
                return;
            }

            var generatedCode = GenerateLoaiSanPhamCode(rawValue, loaiSanPhamOptions.Select(x => x.Ma_LSP));
            var createResult = await LoaiSanPhamService.CreateAsync(new LoaiSanPhamUpsertVm
            {
                Ma_LSP = generatedCode,
                Ten_LSP = rawValue
            });

            await ReloadLoaiSanPhamOptionsAsync();

            var matched = loaiSanPhamOptions.FirstOrDefault(x =>
                string.Equals(x.Ten_LSP, rawValue, StringComparison.OrdinalIgnoreCase)
                || string.Equals(x.Ma_LSP, generatedCode, StringComparison.OrdinalIgnoreCase));

            if (matched is not null)
            {
                state.SelectedLoaiSanPhamId = matched.Loai_San_Pham_ID;
                pageMessage = createResult.Success
                    ? $"Đã thêm mới loại sản phẩm '{matched.Ten_LSP}'."
                    : $"Đã dùng loại sản phẩm sẵn có '{matched.Ten_LSP}'.";
                pageMessageIsError = false;
            }
            else if (!createResult.Success)
            {
                pageMessage = $"Không thể thêm mới loại sản phẩm '{rawValue}': {createResult.Message}";
                pageMessageIsError = true;
            }

            RebuildSanPhamImportPreviewRows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Add missing LoaiSanPham from SanPham import preview failed. SourceIndex={SourceIndex}", sourceIndex);
            pageMessage = "Không thể thêm mới loại sản phẩm từ dữ liệu xem trước.";
            pageMessageIsError = true;
        }
        finally
        {
            state.IsAddingLoaiSanPham = false;
        }
    }

    private async Task AddMissingDonViTinhAsync(int sourceIndex)
    {
        if (!importResolutionBySourceIndex.TryGetValue(sourceIndex, out var state))
        {
            return;
        }

        var rawValue = state.RawDonViTinh?.Trim();
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return;
        }

        state.IsAddingDonViTinh = true;
        try
        {
            var existed = donViTinhOptions.FirstOrDefault(x => string.Equals(x.Ten_Don_Vi_Tinh, rawValue, StringComparison.OrdinalIgnoreCase));
            if (existed is not null)
            {
                state.SelectedDonViTinhId = existed.Don_Vi_Tinh_ID;
                RebuildSanPhamImportPreviewRows();
                return;
            }

            var createResult = await DonViTinhService.CreateAsync(new DonViTinhUpsertVm
            {
                Ten_Don_Vi_Tinh = rawValue
            });

            await ReloadDonViTinhOptionsAsync();

            var matched = donViTinhOptions.FirstOrDefault(x =>
                string.Equals(x.Ten_Don_Vi_Tinh, rawValue, StringComparison.OrdinalIgnoreCase));

            if (matched is not null)
            {
                state.SelectedDonViTinhId = matched.Don_Vi_Tinh_ID;
                pageMessage = createResult.Success
                    ? $"Đã thêm mới đơn vị tính '{matched.Ten_Don_Vi_Tinh}'."
                    : $"Đã dùng đơn vị tính sẵn có '{matched.Ten_Don_Vi_Tinh}'.";
                pageMessageIsError = false;
            }
            else if (!createResult.Success)
            {
                pageMessage = $"Không thể thêm mới đơn vị tính '{rawValue}': {createResult.Message}";
                pageMessageIsError = true;
            }

            RebuildSanPhamImportPreviewRows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Add missing DonViTinh from SanPham import preview failed. SourceIndex={SourceIndex}", sourceIndex);
            pageMessage = "Không thể thêm mới đơn vị tính từ dữ liệu xem trước.";
            pageMessageIsError = true;
        }
        finally
        {
            state.IsAddingDonViTinh = false;
        }
    }

    private async Task ReloadLoaiSanPhamOptionsAsync()
    {
        var latestOptions = await LoaiSanPhamService.GetAllAsync();
        loaiSanPhamOptions.Clear();
        loaiSanPhamOptions.AddRange(latestOptions);
    }

    private async Task ReloadDonViTinhOptionsAsync()
    {
        var latestOptions = await DonViTinhService.GetAllAsync();
        donViTinhOptions.Clear();
        donViTinhOptions.AddRange(latestOptions);
    }

    private static string GenerateLoaiSanPhamCode(string sourceName, IEnumerable<string?> existingCodes)
    {
        var normalized = sourceName.Normalize(NormalizationForm.FormD);
        var builder = new StringBuilder(normalized.Length);

        foreach (var ch in normalized)
        {
            var category = CharUnicodeInfo.GetUnicodeCategory(ch);
            if (category == UnicodeCategory.NonSpacingMark)
            {
                continue;
            }

            var upper = char.ToUpperInvariant(ch == 'đ' ? 'd' : ch);
            if (char.IsLetterOrDigit(upper))
            {
                builder.Append(upper);
            }
            else if (char.IsWhiteSpace(ch) && (builder.Length == 0 || builder[^1] != '-'))
            {
                builder.Append('-');
            }
        }

        var core = builder
            .ToString()
            .Trim('-');
        if (string.IsNullOrWhiteSpace(core))
        {
            core = "SANPHAM";
        }

        var candidate = $"LSP-{core}";
        if (candidate.Length > 50)
        {
            candidate = candidate[..50];
        }

        var existingSet = existingCodes
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!.Trim().ToUpperInvariant())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!existingSet.Contains(candidate))
        {
            return candidate;
        }

        for (var index = 2; index <= 9999; index++)
        {
            var suffix = $"-{index}";
            var maxCoreLength = Math.Max(1, 50 - "LSP-".Length - suffix.Length);
            var shortenedCore = core.Length > maxCoreLength ? core[..maxCoreLength] : core;
            var next = $"LSP-{shortenedCore}{suffix}";
            if (!existingSet.Contains(next))
            {
                return next;
            }
        }

        return $"LSP-{Guid.NewGuid():N}"[..50];
    }

    private static bool TryResolveLoaiSanPham(
        string input,
        IReadOnlyDictionary<string, LoaiSanPhamListItemVm> byCode,
        IReadOnlyDictionary<string, LoaiSanPhamListItemVm> byName,
        out LoaiSanPhamListItemVm loaiSanPham)
    {
        if (byCode.TryGetValue(input, out var byCodeMatch) && byCodeMatch is not null)
        {
            loaiSanPham = byCodeMatch;
            return true;
        }

        if (byName.TryGetValue(input, out var byNameMatch) && byNameMatch is not null)
        {
            loaiSanPham = byNameMatch;
            return true;
        }

        loaiSanPham = null!;
        return false;
    }

