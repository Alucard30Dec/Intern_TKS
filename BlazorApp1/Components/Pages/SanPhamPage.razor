@page "/danh-muc/san-pham"
@rendermode InteractiveServer
@using System.Globalization
@using System.Text
@using System.Text.Encodings.Web
@using BlazorApp1.Infrastructure.Excel
@using BlazorApp1.Models.DonViTinh
@using BlazorApp1.Models.LoaiSanPham
@using BlazorApp1.Models.SanPham
@using BlazorApp1.Services.Interfaces
@inject ISanPhamService SanPhamService
@inject ILoaiSanPhamService LoaiSanPhamService
@inject IDonViTinhService DonViTinhService
@inject IJSRuntime JS
@inject ILogger<SanPhamPage> Logger

<PageTitle>Sản phẩm</PageTitle>

<section class="product-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Sản phẩm</h1>
        <div class="page-header__actions">
            <button type="button" class="app-button" style="display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;" @onclick="ExportTemplateAsync" disabled="@(isSaving || isImporting || isApplyingImport)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                <span>Xuất file mẫu</span>
            </button>
            <label class="app-button" style="position:relative;overflow:hidden;display:inline-flex;align-items:center;justify-content:center;gap:0.42rem;box-sizing:border-box;width:150px;min-width:150px;max-width:150px;white-space:nowrap;background:#ffffff;border:1px solid #6dc7bf;color:#0f8b84;@(isSaving || isImporting || isApplyingImport ? "pointer-events:none;opacity:0.65;cursor:wait;" : "cursor:pointer;")">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21V9" />
                    <path d="m17 14-5-5-5 5" />
                    <path d="M5 3h14" />
                </svg>
                <span>Nhập file excel</span>
                <InputFile style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;"
                           @key="importFileInputVersion"
                           OnChange="ImportExcelAsync"
                           accept=".xlsx"
                           disabled="@(isSaving || isImporting || isApplyingImport)" />
            </label>
            <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@(isSaving || isImporting || isApplyingImport)">
                Thêm mới
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <ExcelImportPreviewDialog Visible="@showImportPreview"
                              FileName="@importPreviewFileName"
                              SheetName="@importPreviewSheetName"
                              ColumnHeaders="@ImportPreviewHeaders"
                              Rows="@importPreviewRows"
                              IsApplying="@isApplyingImport"
                              OnClose="CloseImportPreview"
                              OnConfirm="ApplyImportAsync">
        <CellTemplate Context="cell">
            @if (cell.CellIndex == 2)
            {
                var state = GetImportResolutionState(cell.Row.SourceIndex);
                if (state is not null && state.ShouldRenderLoaiSanPhamCombo)
                {
                    <div class="import-preview-editor">
                        <select class="import-preview-editor__select"
                                value="@(state.SelectedLoaiSanPhamId?.ToString() ?? string.Empty)"
                                @onchange="args => HandleLoaiSanPhamSelectionChanged(cell.Row.SourceIndex, args)"
                                disabled="@(isApplyingImport || state.IsAddingLoaiSanPham)">
                            <option value="">-- Chọn loại sản phẩm --</option>
                            @foreach (var option in loaiSanPhamOptions)
                            {
                                <option value="@option.Loai_San_Pham_ID">@option.Ten_LSP (@option.Ma_LSP)</option>
                            }
                        </select>
                        @if (!string.IsNullOrWhiteSpace(state.RawLoaiSanPham))
                        {
                            <div class="import-preview-editor__hint">
                                Giá trị trong file: <strong>@state.RawLoaiSanPham</strong>
                            </div>
                            <button type="button"
                                    class="import-preview-editor__button"
                                    @onclick="() => AddMissingLoaiSanPhamAsync(cell.Row.SourceIndex)"
                                    disabled="@(isApplyingImport || state.IsAddingLoaiSanPham)">
                                @(state.IsAddingLoaiSanPham ? "Đang thêm..." : "Áp dụng thêm mới")
                            </button>
                        }
                    </div>
                }
                else
                {
                    @GetDisplayCellText(cell.CellValue)
                }
            }
            else if (cell.CellIndex == 3)
            {
                var state = GetImportResolutionState(cell.Row.SourceIndex);
                if (state is not null && state.ShouldRenderDonViTinhCombo)
                {
                    <div class="import-preview-editor">
                        <select class="import-preview-editor__select"
                                value="@(state.SelectedDonViTinhId?.ToString() ?? string.Empty)"
                                @onchange="args => HandleDonViTinhSelectionChanged(cell.Row.SourceIndex, args)"
                                disabled="@(isApplyingImport || state.IsAddingDonViTinh)">
                            <option value="">-- Chọn đơn vị tính --</option>
                            @foreach (var option in donViTinhOptions)
                            {
                                <option value="@option.Don_Vi_Tinh_ID">@option.Ten_Don_Vi_Tinh</option>
                            }
                        </select>
                        @if (!string.IsNullOrWhiteSpace(state.RawDonViTinh))
                        {
                            <div class="import-preview-editor__hint">
                                Giá trị trong file: <strong>@state.RawDonViTinh</strong>
                            </div>
                            <button type="button"
                                    class="import-preview-editor__button"
                                    @onclick="() => AddMissingDonViTinhAsync(cell.Row.SourceIndex)"
                                    disabled="@(isApplyingImport || state.IsAddingDonViTinh)">
                                @(state.IsAddingDonViTinh ? "Đang thêm..." : "Áp dụng thêm mới")
                            </button>
                        }
                    </div>
                }
                else
                {
                    @GetDisplayCellText(cell.CellValue)
                }
            }
            else
            {
                @GetDisplayCellText(cell.CellValue)
            }
        </CellTemplate>
    </ExcelImportPreviewDialog>

    <div class="product-layout @(IsFormVisible ? string.Empty : "product-layout--single")">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Mã, tên, loại hoặc đơn vị tính" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th class="data-table__code">Mã</th>
                                    <th class="data-table__name-col">Tên sản phẩm</th>
                                    <th>Loại sản phẩm</th>
                                    <th>Đơn vị tính</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(formModel.San_Pham_ID == item.San_Pham_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        @onclick="() => StartEditAsync(item.San_Pham_ID)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.Ma_San_Pham</td>
                                        <td class="data-table__name">@item.Ten_San_Pham</td>
                                        <td>@item.Ten_LSP</td>
                                        <td>@item.Ten_Don_Vi_Tinh</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.San_Pham_ID, item.Ten_San_Pham)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @if (IsFormVisible)
        {
            <section class="card card--form">
                <header class="card__header card__header--form">
                    <h2>@FormTitle</h2>
                    <span class="card__tag">@FormModeLabel</span>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="SanPhamForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-field form-field--code">
                                <div class="form-field__head">
                                    <label class="form-field__label">Mã sản phẩm <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ma_San_Pham?.Length ?? 0))/50</span>
                                </div>
                                <InputText class="form-field__input form-field__input--single-line"
                                           @bind-Value="formModel.Ma_San_Pham"
                                           @oninput="HandleMaInput"
                                           maxlength="50"
                                           placeholder="Nhập mã sản phẩm" />
                                <p class="form-field__hint">Mã viết ngắn gọn, không trùng.</p>
                                <ValidationMessage For="@(() => formModel.Ma_San_Pham)" />
                            </div>

                            <div class="form-field form-field--name">
                                <div class="form-field__head">
                                    <label class="form-field__label">Tên sản phẩm <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ten_San_Pham?.Length ?? 0))/200</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ten_San_Pham"
                                           @oninput="HandleTenInput"
                                           maxlength="200"
                                           placeholder="Nhập tên sản phẩm" />
                                <p class="form-field__hint">Tên hiển thị của sản phẩm.</p>
                                <ValidationMessage For="@(() => formModel.Ten_San_Pham)" />
                            </div>

                            <div class="form-field form-field--lookup">
                                <div class="form-field__head">
                                    <label class="form-field__label">Loại sản phẩm <span class="required-mark">*</span></label>
                                </div>
                                <div class="combo-box">
                                    <div class="combo-box__control">
                                        <input class="form-field__input form-field__input--single-line form-field__input--combo"
                                               value="@loaiSanPhamKeyword"
                                               @oninput="HandleLoaiSanPhamInput"
                                               @onfocus="OpenLoaiSanPhamDropdown"
                                               @onblur="HandleLoaiSanPhamBlurAsync"
                                               autocomplete="off" />
                                        <button type="button"
                                                class="combo-box__toggle"
                                                @onclick="ToggleLoaiSanPhamDropdown"
                                                tabindex="-1"
                                                aria-label="Mở danh sách loại sản phẩm">
                                            <span class="combo-box__caret @(isLoaiSanPhamDropdownOpen ? "combo-box__caret--open" : string.Empty)">⌄</span>
                                        </button>
                                    </div>
                                    @if (isLoaiSanPhamDropdownOpen)
                                    {
                                        <div class="combo-box__menu">
                                            @if (FilteredLoaiSanPhamOptions.Count == 0)
                                            {
                                                <div class="combo-box__empty">Không có loại sản phẩm phù hợp.</div>
                                            }
                                            else
                                            {
                                                @foreach (var option in FilteredLoaiSanPhamOptions)
                                                {
                                                    <button type="button"
                                                            class="combo-box__option @(option.Loai_San_Pham_ID == formModel.Loai_San_Pham_ID ? "combo-box__option--active" : string.Empty)"
                                                            @onclick="() => SelectLoaiSanPham(option)">
                                                        @((MarkupString)BuildHighlightedOptionHtml(FormatLoaiSanPhamOption(option), loaiSanPhamKeyword))
                                                    </button>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                                <p class="form-field__hint">Bắt buộc chọn từ danh mục loại sản phẩm.</p>
                                @if (!string.IsNullOrWhiteSpace(loaiSanPhamLookupMessage))
                                {
                                    <p class="form-field__lookup-warning">@loaiSanPhamLookupMessage</p>
                                }
                                <ValidationMessage For="@(() => formModel.Loai_San_Pham_ID)" />
                            </div>

                            <div class="form-field form-field--lookup">
                                <div class="form-field__head">
                                    <label class="form-field__label">Đơn vị tính <span class="required-mark">*</span></label>
                                </div>
                                <div class="combo-box">
                                    <div class="combo-box__control">
                                        <input class="form-field__input form-field__input--single-line form-field__input--combo"
                                               value="@donViTinhKeyword"
                                               @oninput="HandleDonViTinhInput"
                                               @onfocus="OpenDonViTinhDropdown"
                                               @onblur="HandleDonViTinhBlurAsync"
                                               autocomplete="off" />
                                        <button type="button"
                                                class="combo-box__toggle"
                                                @onclick="ToggleDonViTinhDropdown"
                                                tabindex="-1"
                                                aria-label="Mở danh sách đơn vị tính">
                                            <span class="combo-box__caret @(isDonViTinhDropdownOpen ? "combo-box__caret--open" : string.Empty)">⌄</span>
                                        </button>
                                    </div>
                                    @if (isDonViTinhDropdownOpen)
                                    {
                                        <div class="combo-box__menu">
                                            @if (FilteredDonViTinhOptions.Count == 0)
                                            {
                                                <div class="combo-box__empty">Không có đơn vị tính phù hợp.</div>
                                            }
                                            else
                                            {
                                                @foreach (var option in FilteredDonViTinhOptions)
                                                {
                                                    <button type="button"
                                                            class="combo-box__option @(option.Don_Vi_Tinh_ID == formModel.Don_Vi_Tinh_ID ? "combo-box__option--active" : string.Empty)"
                                                            @onclick="() => SelectDonViTinh(option)">
                                                        @((MarkupString)BuildHighlightedOptionHtml(FormatDonViTinhOption(option), donViTinhKeyword))
                                                    </button>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                                <p class="form-field__hint">Bắt buộc chọn từ danh mục đơn vị tính.</p>
                                @if (!string.IsNullOrWhiteSpace(donViTinhLookupMessage))
                                {
                                    <p class="form-field__lookup-warning">@donViTinhLookupMessage</p>
                                }
                                <ValidationMessage For="@(() => formModel.Don_Vi_Tinh_ID)" />
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhi_ChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <p class="form-field__hint">Tùy chọn. Dùng để mô tả ngắn.</p>
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <div class="form-actions">
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                                <button type="submit" class="app-button app-button--success" disabled="@(!HasRequiredLookupData || isSaving)">
                                    @(isSaving ? "Đang lưu..." : "Lưu")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        }
    </div>
</section>

@code {
    private static readonly HtmlEncoder HtmlEncoder = HtmlEncoder.Default;
    private readonly List<SanPhamListItemVm> items = [];
    private readonly List<LoaiSanPhamListItemVm> loaiSanPhamOptions = [];
    private readonly List<DonViTinhListItemVm> donViTinhOptions = [];
    private SanPhamUpsertVm formModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool isImporting;
    private bool isApplyingImport;
    private int importFileInputVersion;
    private bool showImportPreview;
    private string importPreviewFileName = string.Empty;
    private string importPreviewSheetName = string.Empty;
    private List<ExcelImportPreviewRow> importPreviewRows = [];
    private List<ExcelImportRow> importSourceRows = [];
    private readonly Dictionary<int, SanPhamImportResolutionState> importResolutionBySourceIndex = [];
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string searchKeyword = string.Empty;
    private string loaiSanPhamKeyword = string.Empty;
    private string donViTinhKeyword = string.Empty;
    private string? loaiSanPhamLookupMessage;
    private string? donViTinhLookupMessage;
    private bool isLoaiSanPhamDropdownOpen;
    private bool isDonViTinhDropdownOpen;
    private FormMode currentFormMode = FormMode.None;
    private static readonly IReadOnlyList<string> ImportPreviewHeaders = ["Mã", "Tên sản phẩm", "Loại sản phẩm", "Đơn vị tính", "Ghi chú"];

    private bool IsFormVisible => currentFormMode != FormMode.None;
    private bool IsEditing => currentFormMode == FormMode.Edit;
    private bool HasRequiredLookupData => loaiSanPhamOptions.Count > 0 && donViTinhOptions.Count > 0;
    private string FormTitle => IsEditing ? "Sửa sản phẩm" : "Tạo sản phẩm";
    private string FormModeLabel => IsEditing ? "Đang sửa" : "Đang tạo";

    private IReadOnlyList<SanPhamListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();

            // Loc tren bo nho de cap nhat UI tuc thi theo oninput, khong tao round-trip DB cho moi ky tu.
            return items
                .Where(x =>
                    ContainsKeyword(x.Ma_San_Pham, keyword)
                    || ContainsKeyword(x.Ten_San_Pham, keyword)
                    || ContainsKeyword(x.Ten_LSP, keyword)
                    || ContainsKeyword(x.Ten_Don_Vi_Tinh, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    private IReadOnlyList<LoaiSanPhamListItemVm> FilteredLoaiSanPhamOptions
    {
        get
        {
            var keyword = loaiSanPhamKeyword.Trim();
            if (string.IsNullOrWhiteSpace(keyword))
            {
                return loaiSanPhamOptions;
            }

            return loaiSanPhamOptions
                .Where(x =>
                    ContainsKeyword(x.Ma_LSP, keyword)
                    || ContainsKeyword(x.Ten_LSP, keyword)
                    || ContainsKeyword(FormatLoaiSanPhamOption(x), keyword))
                .ToList();
        }
    }

    private IReadOnlyList<DonViTinhListItemVm> FilteredDonViTinhOptions
    {
        get
        {
            var keyword = donViTinhKeyword.Trim();
            if (string.IsNullOrWhiteSpace(keyword))
            {
                return donViTinhOptions;
            }

            return donViTinhOptions
                .Where(x =>
                    ContainsKeyword(x.Ten_Don_Vi_Tinh, keyword)
                    || ContainsKeyword(FormatDonViTinhOption(x), keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var getSanPhamTask = SanPhamService.GetAllAsync();
            var getLoaiSanPhamTask = LoaiSanPhamService.GetAllAsync();
            var getDonViTinhTask = DonViTinhService.GetAllAsync();

            await Task.WhenAll(getSanPhamTask, getLoaiSanPhamTask, getDonViTinhTask);

            items.Clear();
            items.AddRange(getSanPhamTask.Result);

            loaiSanPhamOptions.Clear();
            loaiSanPhamOptions.AddRange(getLoaiSanPhamTask.Result);

            donViTinhOptions.Clear();
            donViTinhOptions.AddRange(getDonViTinhTask.Result);

            if (IsFormVisible)
            {
                SyncLookupKeywordsFromFormModel();
            }

            if (!HasRequiredLookupData)
            {
                pageMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi thêm sản phẩm.";
                pageMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load SanPham list failed.");
            pageMessage = "Không thể tải danh mục sản phẩm.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi thêm sản phẩm.";
            pageMessageIsError = true;
            return;
        }

        currentFormMode = FormMode.Create;
        ResetFormModel();
    }

    private async Task StartEditAsync(int id)
    {
        ClearPageMessage();
        ClearFormMessage();

        var result = await SanPhamService.GetByIdAsync(id);

        if (!result.Success || result.Data is null)
        {
            pageMessage = result.Message;
            pageMessageIsError = true;
            return;
        }

        formModel = new SanPhamUpsertVm
        {
            San_Pham_ID = result.Data.San_Pham_ID,
            Ma_San_Pham = result.Data.Ma_San_Pham,
            Ten_San_Pham = result.Data.Ten_San_Pham,
            Loai_San_Pham_ID = result.Data.Loai_San_Pham_ID,
            Don_Vi_Tinh_ID = result.Data.Don_Vi_Tinh_ID,
            Ghi_Chu = result.Data.Ghi_Chu
        };
        SyncLookupKeywordsFromFormModel();
        currentFormMode = FormMode.Edit;
    }

    private async Task SaveAsync()
    {
        if (!HasRequiredLookupData)
        {
            formMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi lưu.";
            formMessageIsError = true;
            return;
        }

        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            var result = formModel.San_Pham_ID == 0
                ? await SanPhamService.CreateAsync(formModel)
                : await SanPhamService.UpdateAsync(formModel);

            formMessage = result.Message;
            formMessageIsError = !result.Success;

            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save SanPham failed. San_Pham_ID={San_Pham_ID}", formModel.San_Pham_ID);
            formMessage = "Không thể lưu dữ liệu do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string tenSanPham)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa sản phẩm '{tenSanPham}' khỏi danh sách?");

        if (!confirmed)
        {
            return;
        }

        var result = await SanPhamService.DeleteAsync(id);

        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
