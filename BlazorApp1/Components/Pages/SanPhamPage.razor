    private static string BuildHighlightedOptionHtml(string optionText, string keyword)
    {
        var safeText = optionText ?? string.Empty;
        var trimmedKeyword = keyword?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(trimmedKeyword))
        {
            return HtmlEncoder.Encode(safeText);
        }

        var result = new StringBuilder();
        var startIndex = 0;

        while (startIndex < safeText.Length)
        {
            var matchIndex = safeText.IndexOf(trimmedKeyword, startIndex, StringComparison.OrdinalIgnoreCase);
            if (matchIndex < 0)
            {
                result.Append(HtmlEncoder.Encode(safeText[startIndex..]));
                break;
            }

            if (matchIndex > startIndex)
            {
                result.Append(HtmlEncoder.Encode(safeText[startIndex..matchIndex]));
            }

            var matchedText = safeText.Substring(matchIndex, trimmedKeyword.Length);
            result.Append("<span class=\"combo-box__option-match\">");
            result.Append(HtmlEncoder.Encode(matchedText));
            result.Append("</span>");
            startIndex = matchIndex + trimmedKeyword.Length;
        }

        return result.ToString();
    }

