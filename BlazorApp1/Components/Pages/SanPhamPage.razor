    }

    private static bool IsDuplicateImportMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
               || message.Contains("bị trùng", StringComparison.OrdinalIgnoreCase)
               || message.Contains("đã được", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildImportSummary(
        int successCount,
        IReadOnlyList<string> skippedReasons)
    {
        if (skippedReasons.Count == 0)
        {
            return $"Đã nhập {successCount} dòng.";
        }

        var reasonGroups = skippedReasons
            .Select(ExtractImportSkipReasonLabel)
            .GroupBy(x => x, StringComparer.OrdinalIgnoreCase)
            .Select(group => new
            {
                Reason = group.First(),
                Count = group.Count()
            })
            .OrderByDescending(x => x.Count)
            .ThenBy(x => x.Reason, StringComparer.CurrentCultureIgnoreCase)
            .ToList();

        var breakdown = string.Join(", ", reasonGroups.Select(x => $"{x.Count} dòng {x.Reason}"));
        return $"Đã nhập {successCount} dòng, bỏ qua {skippedReasons.Count} dòng: {breakdown}.";
    }

    private static string ExtractImportSkipReasonLabel(string detail)
    {
        var reason = detail ?? string.Empty;
        var separatorIndex = reason.IndexOf(':');
        if (separatorIndex >= 0 && separatorIndex < reason.Length - 1)
        {
            reason = reason[(separatorIndex + 1)..];
        }

        reason = reason.Trim().TrimEnd('.');
        if (string.IsNullOrWhiteSpace(reason))
        {
            return "không rõ lý do";
        }

        if (reason.Contains("Mã sản phẩm đã tồn tại", StringComparison.OrdinalIgnoreCase))
        {
            return "trùng mã SP";
        }

        if (reason.Contains("đã tồn tại", StringComparison.OrdinalIgnoreCase)
            || reason.Contains("bị trùng", StringComparison.OrdinalIgnoreCase))
        {
            return "trùng dữ liệu";
        }

        if (reason.Contains("Thiếu cột bắt buộc", StringComparison.OrdinalIgnoreCase))
        {
            return "thiếu mã SP hoặc tên SP";
        }

        if (reason.Contains("Chưa chọn loại sản phẩm", StringComparison.OrdinalIgnoreCase))
        {
            return "thiếu loại sản phẩm";
        }

        if (reason.Contains("Chưa chọn đơn vị tính", StringComparison.OrdinalIgnoreCase))
        {
            return "thiếu đơn vị tính";
        }

        if (reason.Contains("Không tìm thấy loại sản phẩm", StringComparison.OrdinalIgnoreCase))
        {
            return "loại sản phẩm chưa có";
        }

        if (reason.Contains("Không tìm thấy đơn vị tính", StringComparison.OrdinalIgnoreCase))
        {
            return "đơn vị tính chưa có";
        }

        return reason;
    }

