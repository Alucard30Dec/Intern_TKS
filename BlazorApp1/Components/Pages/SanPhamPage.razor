    private void TryApplyLoaiSanPhamKeywordSelection(bool showValidationMessage)
    {
        var keyword = loaiSanPhamKeyword.Trim();
        if (string.IsNullOrWhiteSpace(keyword))
        {
            formModel.Loai_San_Pham_ID = 0;
            if (showValidationMessage)
            {
                loaiSanPhamLookupMessage = "Vui lòng chọn loại sản phẩm.";
            }

            return;
        }

        var matched = loaiSanPhamOptions.FirstOrDefault(x =>
            string.Equals(x.Ten_LSP, keyword, StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.Ma_LSP, keyword, StringComparison.OrdinalIgnoreCase)
            || string.Equals(FormatLoaiSanPhamOption(x), keyword, StringComparison.OrdinalIgnoreCase));

        if (matched is null)
        {
            formModel.Loai_San_Pham_ID = 0;
            if (showValidationMessage)
            {
                loaiSanPhamLookupMessage = $"Không tìm thấy loại sản phẩm '{keyword}'.";
            }

            return;
        }

        formModel.Loai_San_Pham_ID = matched.Loai_San_Pham_ID;
        loaiSanPhamKeyword = FormatLoaiSanPhamOption(matched);
        loaiSanPhamLookupMessage = null;
    }

