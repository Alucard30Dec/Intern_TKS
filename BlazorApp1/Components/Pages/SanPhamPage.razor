@page "/danh-muc/san-pham"
@rendermode InteractiveServer
@using BlazorApp1.Models.DonViTinh
@using BlazorApp1.Models.LoaiSanPham
@using BlazorApp1.Models.SanPham
@using BlazorApp1.Services.Interfaces
@inject ISanPhamService SanPhamService
@inject ILoaiSanPhamService LoaiSanPhamService
@inject IDonViTinhService DonViTinhService
@inject IJSRuntime JS
@inject ILogger<SanPhamPage> Logger

<PageTitle>Sản phẩm</PageTitle>

<section class="product-page">
    @{
        var filteredItems = FilteredItems;
    }

    <header class="page-header">
        <h1>Sản phẩm</h1>
        <button type="button" class="app-button app-button--primary" @onclick="StartCreate" disabled="@isSaving">
            Thêm mới
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(pageMessage))
    {
        <div class="status-banner @(pageMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
            @pageMessage
        </div>
    }

    <div class="product-layout @(IsFormVisible ? string.Empty : "product-layout--single")">
        <section class="card card--list">
            <header class="card__header card__header--toolbar">
                <h2>Danh sách (@filteredItems.Count)</h2>
                <div class="toolbar">
                    <label class="search-field">
                        <span class="search-field__label">Tìm kiếm</span>
                        <input class="search-field__input"
                               value="@searchKeyword"
                               @oninput="HandleSearchInput"
                               placeholder="Mã, tên, loại hoặc đơn vị tính" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(searchKeyword))
                    {
                        <button type="button" class="app-button app-button--ghost" @onclick="ClearSearch">
                            Xóa
                        </button>
                    }
                </div>
            </header>

            <div class="card__body card__body--table">
                @if (isLoading)
                {
                    <div class="state-box">Đang tải dữ liệu...</div>
                }
                else if (items.Count == 0)
                {
                    <div class="state-box state-box--empty">Chưa có dữ liệu.</div>
                }
                else if (filteredItems.Count == 0)
                {
                    <div class="state-box state-box--empty">Không có kết quả phù hợp.</div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="data-table__index">STT</th>
                                    <th class="data-table__code">Mã</th>
                                    <th class="data-table__name-col">Tên sản phẩm</th>
                                    <th>Loại sản phẩm</th>
                                    <th>Đơn vị tính</th>
                                    <th>Ghi chú</th>
                                    <th class="data-table__actions">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < filteredItems.Count; i++)
                                {
                                    var item = filteredItems[i];

                                    <tr class="@(formModel.San_Pham_ID == item.San_Pham_ID ? "data-table__row data-table__row--active" : "data-table__row")"
                                        @onclick="() => StartEditAsync(item.San_Pham_ID)">
                                        <td>@(i + 1)</td>
                                        <td class="data-table__code-value">@item.Ma_San_Pham</td>
                                        <td class="data-table__name">@item.Ten_San_Pham</td>
                                        <td>@item.Ten_LSP</td>
                                        <td>@item.Ten_Don_Vi_Tinh</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.Ghi_Chu))
                                            {
                                                <span class="data-table__muted">Trống</span>
                                            }
                                            else
                                            {
                                                @item.Ghi_Chu
                                            }
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <button class="app-button app-button--danger"
                                                        @onclick="() => DeleteAsync(item.San_Pham_ID, item.Ten_San_Pham)"
                                                        @onclick:stopPropagation="true"
                                                        disabled="@isSaving">
                                                    Xóa
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @if (IsFormVisible)
        {
            <section class="card card--form">
                <header class="card__header card__header--form">
                    <h2>@FormTitle</h2>
                    <span class="card__tag">@FormModeLabel</span>
                </header>

                <div class="card__body">
                    <div class="form-shell">
                        <EditForm Model="formModel" OnValidSubmit="SaveAsync" FormName="SanPhamForm">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(formMessage))
                            {
                                <div class="status-banner @(formMessageIsError ? "status-banner--error" : "status-banner--success")" role="alert">
                                    @formMessage
                                </div>
                            }

                            <div class="form-field form-field--code">
                                <div class="form-field__head">
                                    <label class="form-field__label">Mã sản phẩm <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ma_San_Pham?.Length ?? 0))/50</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ma_San_Pham"
                                           @oninput="HandleMaInput"
                                           maxlength="50"
                                           placeholder="Nhập mã sản phẩm" />
                                <p class="form-field__hint">Mã viết ngắn gọn, không trùng.</p>
                                <ValidationMessage For="@(() => formModel.Ma_San_Pham)" />
                            </div>

                            <div class="form-field form-field--name">
                                <div class="form-field__head">
                                    <label class="form-field__label">Tên sản phẩm <span class="required-mark">*</span></label>
                                    <span class="form-field__count">@((formModel.Ten_San_Pham?.Length ?? 0))/200</span>
                                </div>
                                <InputText class="form-field__input"
                                           @bind-Value="formModel.Ten_San_Pham"
                                           @oninput="HandleTenInput"
                                           maxlength="200"
                                           placeholder="Nhập tên sản phẩm" />
                                <p class="form-field__hint">Tên hiển thị của sản phẩm.</p>
                                <ValidationMessage For="@(() => formModel.Ten_San_Pham)" />
                            </div>

                            <div class="form-field form-field--lookup">
                                <div class="form-field__head">
                                    <label class="form-field__label">Loại sản phẩm <span class="required-mark">*</span></label>
                                </div>
                                <InputSelect class="form-field__input"
                                             @bind-Value="formModel.Loai_San_Pham_ID">
                                    <option value="0">-- Chọn loại sản phẩm --</option>
                                    @foreach (var option in loaiSanPhamOptions)
                                    {
                                        <option value="@option.Loai_San_Pham_ID">@option.Ten_LSP (@option.Ma_LSP)</option>
                                    }
                                </InputSelect>
                                <p class="form-field__hint">Bắt buộc chọn từ danh mục loại sản phẩm.</p>
                                <ValidationMessage For="@(() => formModel.Loai_San_Pham_ID)" />
                            </div>

                            <div class="form-field form-field--lookup">
                                <div class="form-field__head">
                                    <label class="form-field__label">Đơn vị tính <span class="required-mark">*</span></label>
                                </div>
                                <InputSelect class="form-field__input"
                                             @bind-Value="formModel.Don_Vi_Tinh_ID">
                                    <option value="0">-- Chọn đơn vị tính --</option>
                                    @foreach (var option in donViTinhOptions)
                                    {
                                        <option value="@option.Don_Vi_Tinh_ID">@option.Ten_Don_Vi_Tinh</option>
                                    }
                                </InputSelect>
                                <p class="form-field__hint">Bắt buộc chọn từ danh mục đơn vị tính.</p>
                                <ValidationMessage For="@(() => formModel.Don_Vi_Tinh_ID)" />
                            </div>

                            <div class="form-field form-field--note">
                                <div class="form-field__head">
                                    <label class="form-field__label">Ghi chú</label>
                                    <span class="form-field__count">@((formModel.Ghi_Chu?.Length ?? 0))/255</span>
                                </div>
                                <InputTextArea class="form-field__input form-field__input--multiline"
                                               @bind-Value="formModel.Ghi_Chu"
                                               @oninput="HandleGhi_ChuInput"
                                               maxlength="255"
                                               placeholder="Nhập ghi chú" />
                                <p class="form-field__hint">Tùy chọn. Dùng để mô tả ngắn.</p>
                                <ValidationMessage For="@(() => formModel.Ghi_Chu)" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="app-button app-button--success" disabled="@(!HasRequiredLookupData || isSaving)">
                                    @(isSaving ? "Đang lưu..." : "Lưu")
                                </button>
                                <button type="button" class="app-button app-button--secondary" @onclick="CancelForm" disabled="@isSaving">
                                    Hủy
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </section>
        }
    </div>
</section>

@code {
    private readonly List<SanPhamListItemVm> items = [];
    private readonly List<LoaiSanPhamListItemVm> loaiSanPhamOptions = [];
    private readonly List<DonViTinhListItemVm> donViTinhOptions = [];
    private SanPhamUpsertVm formModel = new();
    private bool isLoading = true;
    private bool isSaving;
    private string? pageMessage;
    private bool pageMessageIsError;
    private string? formMessage;
    private bool formMessageIsError;
    private string searchKeyword = string.Empty;
    private FormMode currentFormMode = FormMode.None;

    private bool IsFormVisible => currentFormMode != FormMode.None;
    private bool IsEditing => currentFormMode == FormMode.Edit;
    private bool HasRequiredLookupData => loaiSanPhamOptions.Count > 0 && donViTinhOptions.Count > 0;
    private string FormTitle => IsEditing ? "Sửa sản phẩm" : "Tạo sản phẩm";
    private string FormModeLabel => IsEditing ? "Đang sửa" : "Đang tạo";

    private IReadOnlyList<SanPhamListItemVm> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchKeyword))
            {
                return items;
            }

            var keyword = searchKeyword.Trim();

            // Loc tren bo nho de cap nhat UI tuc thi theo oninput, khong tao round-trip DB cho moi ky tu.
            return items
                .Where(x =>
                    ContainsKeyword(x.Ma_San_Pham, keyword)
                    || ContainsKeyword(x.Ten_San_Pham, keyword)
                    || ContainsKeyword(x.Ten_LSP, keyword)
                    || ContainsKeyword(x.Ten_Don_Vi_Tinh, keyword)
                    || ContainsKeyword(x.Ghi_Chu, keyword))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            ClearPageMessage();
            ClearFormMessage();

            var getSanPhamTask = SanPhamService.GetAllAsync();
            var getLoaiSanPhamTask = LoaiSanPhamService.GetAllAsync();
            var getDonViTinhTask = DonViTinhService.GetAllAsync();

            await Task.WhenAll(getSanPhamTask, getLoaiSanPhamTask, getDonViTinhTask);

            items.Clear();
            items.AddRange(getSanPhamTask.Result);

            loaiSanPhamOptions.Clear();
            loaiSanPhamOptions.AddRange(getLoaiSanPhamTask.Result);

            donViTinhOptions.Clear();
            donViTinhOptions.AddRange(getDonViTinhTask.Result);

            if (!HasRequiredLookupData)
            {
                pageMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi thêm sản phẩm.";
                pageMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load SanPham list failed.");
            pageMessage = "Không thể tải danh mục sản phẩm.";
            pageMessageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        ClearPageMessage();
        ClearFormMessage();

        if (!HasRequiredLookupData)
        {
            pageMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi thêm sản phẩm.";
            pageMessageIsError = true;
            return;
        }

        currentFormMode = FormMode.Create;
        ResetFormModel();
    }

    private async Task StartEditAsync(int id)
    {
        ClearPageMessage();
        ClearFormMessage();

        var result = await SanPhamService.GetByIdAsync(id);

        if (!result.Success || result.Data is null)
        {
            pageMessage = result.Message;
            pageMessageIsError = true;
            return;
        }

        formModel = new SanPhamUpsertVm
        {
            San_Pham_ID = result.Data.San_Pham_ID,
            Ma_San_Pham = result.Data.Ma_San_Pham,
            Ten_San_Pham = result.Data.Ten_San_Pham,
            Loai_San_Pham_ID = result.Data.Loai_San_Pham_ID,
            Don_Vi_Tinh_ID = result.Data.Don_Vi_Tinh_ID,
            Ghi_Chu = result.Data.Ghi_Chu
        };
        currentFormMode = FormMode.Edit;
    }

    private async Task SaveAsync()
    {
        if (!HasRequiredLookupData)
        {
            formMessage = "Cần có dữ liệu Loại sản phẩm và Đơn vị tính trước khi lưu.";
            formMessageIsError = true;
            return;
        }

        isSaving = true;
        ClearFormMessage();
        ClearPageMessage();

        try
        {
            var result = formModel.San_Pham_ID == 0
                ? await SanPhamService.CreateAsync(formModel)
                : await SanPhamService.UpdateAsync(formModel);

            formMessage = result.Message;
            formMessageIsError = !result.Success;

            if (!result.Success)
            {
                return;
            }

            await LoadDataAsync();
            CancelForm();
            pageMessage = result.Message;
            pageMessageIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save SanPham failed. San_Pham_ID={San_Pham_ID}", formModel.San_Pham_ID);
            formMessage = "Không thể lưu dữ liệu do lỗi hệ thống.";
            formMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(int id, string tenSanPham)
    {
        ClearPageMessage();
        ClearFormMessage();

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Xóa sản phẩm '{tenSanPham}' khỏi danh sách hiển thị? Dữ liệu vẫn được lưu trong hệ thống.");

        if (!confirmed)
        {
            return;
        }

        var result = await SanPhamService.DeleteAsync(id);

        pageMessage = result.Message;
        pageMessageIsError = !result.Success;

        if (!result.Success)
        {
            return;
        }

        if (formModel.San_Pham_ID == id)
        {
            CancelForm();
        }

        await LoadDataAsync();
        pageMessage = result.Message;
        pageMessageIsError = false;
    }

    private void CancelForm()
    {
        currentFormMode = FormMode.None;
        ResetFormModel();
        ClearFormMessage();
    }

    private void ResetFormModel()
    {
        formModel = new SanPhamUpsertVm();
    }

    private void ClearSearch()
    {
        searchKeyword = string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        searchKeyword = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleMaInput(ChangeEventArgs args)
    {
        // Dung oninput de bo dem ky tu cap nhat ngay khi go/phim xoa.
        formModel.Ma_San_Pham = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleTenInput(ChangeEventArgs args)
    {
        // Dung oninput de bo dem ky tu cap nhat ngay khi go/phim xoa.
        formModel.Ten_San_Pham = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleGhi_ChuInput(ChangeEventArgs args)
    {
        // Dung oninput de bo dem ky tu cap nhat ngay khi go/phim xoa.
        formModel.Ghi_Chu = args.Value?.ToString();
    }

    private void ClearPageMessage()
    {
        pageMessage = null;
        pageMessageIsError = false;
    }

    private void ClearFormMessage()
    {
        formMessage = null;
        formMessageIsError = false;
    }

    private static bool ContainsKeyword(string? source, string keyword)
    {
        return !string.IsNullOrWhiteSpace(source)
               && source.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private enum FormMode
    {
        None = 0,
        Create = 1,
        Edit = 2
    }
}
